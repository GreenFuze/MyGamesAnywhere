{
  "plugin_id": "game-source-epic",
  "plugin_version": "1.0.0",
  "api_major": 1,
  "capabilities": ["source"],
  "provides": ["source.games.list", "plugin.check_config"],
  "exec": "epic-source.exe",
  "default_timeout_ms": 180000,
  "max_concurrency": 1,
  "config": {
    "authorization_code": {
      "type": "string",
      "required": false,
      "x-secret": true,
      "x-help-url": "https://www.epicgames.com/id/api/redirect?clientId=34a02cf8f4414e29b15921876da36f9a&responseType=code",
      "description": "Paste the authorizationCode value from Epic Games"
    }
  }
}
