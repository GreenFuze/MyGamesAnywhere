{
  "plugin_id": "game-source-google-drive",
  "plugin_version": "2.1.0",
  "api_major": 1,
  "capabilities": ["source"],
  "provides": ["source.filesystem.list", "source.file.materialize", "plugin.check_config", "auth.oauth.callback", "source.browse"],
  "exec": "drive.exe",
  "default_timeout_ms": 600000,
  "max_concurrency": 2,
  "config": {
    "include_paths": {
      "type": "array",
      "required": true,
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "required": true },
          "recursive": { "type": "boolean" }
        }
      }
    }
  }
}
