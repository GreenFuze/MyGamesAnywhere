{
  "plugin_id": "sync-settings-google-drive",
  "plugin_version": "2.0.0",
  "api_major": 1,
  "capabilities": ["storage"],
  "provides": ["storage.backup", "storage.restore"],
  "exec": "drive.exe",
  "default_timeout_ms": 600000,
  "max_concurrency": 1,
  "config": {
    "backup_folder_id": { "type": "string", "default": "" }
  }
}
