{
  "plugin_id": "sync-settings-google-drive",
  "plugin_version": "2.0.0",
  "api_major": 1,
  "capabilities": ["sync"],
  "provides": ["sync.push", "sync.pull"],
  "exec": "drive.exe",
  "default_timeout_ms": 600000,
  "max_concurrency": 1,
  "config": {
    "sync_path": { "type": "string", "default": "Games/mga_sync" },
    "max_versions": { "type": "number", "default": 10 }
  }
}
