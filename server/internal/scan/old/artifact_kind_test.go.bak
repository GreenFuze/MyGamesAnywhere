package scan

import (
	"testing"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

func TestDetectArtifactKinds_nilSlice_noOp(t *testing.T) {
	DetectArtifactKinds(nil)
}

func TestDetectArtifactKinds_directories_getUnknown(t *testing.T) {
	a := &core.Artifact{Path: "/tmp/foo", IsDir: true, Extension: ""}
	DetectArtifactKinds([]*core.Artifact{a})
	if a.Kind != core.ArtifactKindUnknown {
		t.Errorf("directory expected unknown_artifact, got %q", a.Kind)
	}
}

func TestDetectArtifactKinds_executableExtensions(t *testing.T) {
	tests := []struct {
		ext  string
		kind core.ArtifactKind
	}{
		{".exe", core.ArtifactKindWindowsExecutable},
		{".com", core.ArtifactKindDOSExecutable},
		{".bat", core.ArtifactKindScriptLauncher},
	}
	for _, tt := range tests {
		a := &core.Artifact{Extension: tt.ext, IsFile: true}
		DetectArtifactKinds([]*core.Artifact{a})
		if a.Kind != tt.kind {
			t.Errorf("ext %q: expected %q, got %q", tt.ext, tt.kind, a.Kind)
		}
	}
}

func TestDetectArtifactKinds_archiveExtensions(t *testing.T) {
	for _, ext := range []string{".zip", ".7z", ".rar"} {
		a := &core.Artifact{Extension: ext, IsFile: true}
		DetectArtifactKinds([]*core.Artifact{a})
		if a.Kind != core.ArtifactKindArchive {
			t.Errorf("ext %q: expected archive, got %q", ext, a.Kind)
		}
	}
}

func TestDetectArtifactKinds_discExtensions(t *testing.T) {
	tests := []struct {
		ext  string
		kind core.ArtifactKind
	}{
		{".iso", core.ArtifactKindDiscImage},
		{".cue", core.ArtifactKindDiscDescriptor},
		{".bin", core.ArtifactKindDiscTrack},
		{".chd", core.ArtifactKindDiscImage},
	}
	for _, tt := range tests {
		a := &core.Artifact{Extension: tt.ext, IsFile: true}
		DetectArtifactKinds([]*core.Artifact{a})
		if a.Kind != tt.kind {
			t.Errorf("ext %q: expected %q, got %q", tt.ext, tt.kind, a.Kind)
		}
	}
}

func TestDetectArtifactKinds_dataAssetExtensions(t *testing.T) {
	tests := []struct {
		ext  string
		kind core.ArtifactKind
	}{
		{".sfo", core.ArtifactKindGameData},
		{".png", core.ArtifactKindImageAsset},
		{".pdf", core.ArtifactKindManualOrDocument},
		{".mp3", core.ArtifactKindAudioMedia},
	}
	for _, tt := range tests {
		a := &core.Artifact{Extension: tt.ext, IsFile: true}
		DetectArtifactKinds([]*core.Artifact{a})
		if a.Kind != tt.kind {
			t.Errorf("ext %q: expected %q, got %q", tt.ext, tt.kind, a.Kind)
		}
	}
}

func TestDetectArtifactKinds_unknownExtension(t *testing.T) {
	a := &core.Artifact{Extension: ".xyz", IsFile: true}
	DetectArtifactKinds([]*core.Artifact{a})
	if a.Kind != core.ArtifactKindUnknown {
		t.Errorf("expected unknown_artifact, got %q", a.Kind)
	}
}

func TestDetectArtifactKinds_emptyExtension(t *testing.T) {
	a := &core.Artifact{Extension: "", IsFile: true}
	DetectArtifactKinds([]*core.Artifact{a})
	if a.Kind != core.ArtifactKindUnknown {
		t.Errorf("expected unknown_artifact for empty ext, got %q", a.Kind)
	}
}
