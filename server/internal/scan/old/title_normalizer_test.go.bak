package scan

import (
	"testing"
)

func TestRawTitleFromName(t *testing.T) {
	if got := RawTitleFromName("Game_Name.v1.exe"); got != "game name v1" {
		t.Errorf("RawTitleFromName: got %q", got)
	}
}

func TestNormalizeTitle_extractsAddonMarkers(t *testing.T) {
	res := NormalizeTitle("lego batman 3 season pass")
	if len(res.AddonMarkers) == 0 {
		t.Error("expected addon marker season pass")
	}
	if res.BaseTitle == "" {
		t.Error("expected non-empty base title")
	}
}

func TestNormalizeTitle_collapseSpaces(t *testing.T) {
	res := NormalizeTitle("  multiple   spaces  ")
	if res.Normalized != "multiple spaces" {
		t.Errorf("expected collapsed spaces, got %q", res.Normalized)
	}
}

func TestNormalizeTitle_empty(t *testing.T) {
	res := NormalizeTitle("")
	if res.Normalized != "" || res.BaseTitle != "" {
		t.Errorf("expected empty result, got %+v", res)
	}
}
