package scan

import (
	"path/filepath"
	"testing"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

func artifactWith(id, path, name, ext string, isDir bool, kind core.ArtifactKind) *core.Artifact {
	return &core.Artifact{
		ArtifactID: id,
		Path:       path,
		Name:       name,
		Extension:  ext,
		IsFile:     !isDir,
		IsDir:      isDir,
		Kind:       kind,
		ParentPath: filepath.Dir(path),
	}
}

func TestAssemblePackages_C1_multipartInstaller(t *testing.T) {
	artifacts := []*core.Artifact{
		artifactWith("exe1", "/d/setup.exe", "setup.exe", ".exe", false, core.ArtifactKindWindowsExecutable),
		artifactWith("bin1", "/d/setup-1.bin", "setup-1.bin", ".bin", false, core.ArtifactKindDiscTrack),
		artifactWith("bin2", "/d/setup-2.bin", "setup-2.bin", ".bin", false, core.ArtifactKindDiscTrack),
	}
	for i := range artifacts {
		artifacts[i].ParentPath = "/d"
		artifacts[i].SiblingNames = []string{"setup.exe", "setup-1.bin", "setup-2.bin"}
	}
	pkgs := AssemblePackages(artifacts)
	if len(pkgs) != 1 {
		t.Fatalf("expected 1 package, got %d", len(pkgs))
	}
	if pkgs[0].PackageKind != core.PackageKindMultipartInstaller {
		t.Errorf("expected multipart_installer, got %q", pkgs[0].PackageKind)
	}
	if pkgs[0].RootArtifactID != "exe1" {
		t.Errorf("root expected exe1, got %q", pkgs[0].RootArtifactID)
	}
	if len(pkgs[0].MemberArtifactIDs) != 3 {
		t.Errorf("expected 3 members, got %d", len(pkgs[0].MemberArtifactIDs))
	}
}

func TestAssemblePackages_C3_singleISO(t *testing.T) {
	artifacts := []*core.Artifact{
		artifactWith("iso1", "/d/game.iso", "game.iso", ".iso", false, core.ArtifactKindDiscImage),
	}
	artifacts[0].ParentPath = "/d"
	pkgs := AssemblePackages(artifacts)
	if len(pkgs) != 1 {
		t.Fatalf("expected 1 package, got %d", len(pkgs))
	}
	if pkgs[0].PackageKind != core.PackageKindOpticalDiscImage {
		t.Errorf("expected optical_disc_image, got %q", pkgs[0].PackageKind)
	}
}

func TestAssemblePackages_C7_archiveCandidate(t *testing.T) {
	artifacts := []*core.Artifact{
		artifactWith("z1", "/d/game.zip", "game.zip", ".zip", false, core.ArtifactKindArchive),
	}
	artifacts[0].ParentPath = "/d"
	pkgs := AssemblePackages(artifacts)
	if len(pkgs) != 1 {
		t.Fatalf("expected 1 package, got %d", len(pkgs))
	}
	if pkgs[0].PackageKind != core.PackageKindArchiveCandidate {
		t.Errorf("expected archive_candidate, got %q", pkgs[0].PackageKind)
	}
}

func TestAssemblePackages_C6_extractedConsole(t *testing.T) {
	dir := artifactWith("dir1", "/d/PS3Game", "PS3Game", "", true, core.ArtifactKindUnknown)
	dir.ParentPath = "/d"
	child := artifactWith("ps3game", "/d/PS3Game/PS3_GAME", "PS3_GAME", "", true, core.ArtifactKindUnknown)
	child.ParentPath = "/d/PS3Game"
	artifacts := []*core.Artifact{dir, child}
	pkgs := AssemblePackages(artifacts)
	if len(pkgs) != 1 {
		t.Fatalf("expected 1 package, got %d", len(pkgs))
	}
	if pkgs[0].PackageKind != core.PackageKindExtractedConsoleGameDirectory {
		t.Errorf("expected extracted_console_game_directory, got %q", pkgs[0].PackageKind)
	}
}

func TestAssemblePackages_empty(t *testing.T) {
	pkgs := AssemblePackages(nil)
	if pkgs != nil {
		t.Errorf("expected nil, got %v", pkgs)
	}
	pkgs = AssemblePackages([]*core.Artifact{})
	if pkgs != nil {
		t.Errorf("expected nil for empty slice, got %v", pkgs)
	}
}
