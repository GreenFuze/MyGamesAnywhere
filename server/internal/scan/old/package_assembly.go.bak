package scan

import (
	"path/filepath"
	"regexp"
	"strings"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

// AssemblePackages runs Phase C rules on artifacts and returns packages. Each artifact is in at most one package.
// Rules run in order: C1, C2, C3, C6, C5, C4, C9, C7, C8. Consumed artifacts are excluded from later rules.
func AssemblePackages(artifacts []*core.Artifact) []*core.Package {
	if len(artifacts) == 0 {
		return nil
	}
	byParent := make(map[string][]*core.Artifact)
	for _, a := range artifacts {
		if a == nil {
			continue
		}
		parent := a.ParentPath
		byParent[parent] = append(byParent[parent], a)
	}
	consumed := make(map[string]bool)
	var packages []*core.Package

	// C1: multipart installer (stem.exe + stem-1.bin, stem-2.bin, ...)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsFile || a.Kind != core.ArtifactKindWindowsExecutable {
			continue
		}
		stem := strings.TrimSuffix(a.Name, filepath.Ext(a.Name))
		parent := a.ParentPath
		siblings := byParent[parent]
		var bins []*core.Artifact
		for _, s := range siblings {
			if consumed[s.ArtifactID] || !s.IsFile {
				continue
			}
			if s.Kind != core.ArtifactKindDiscTrack {
				continue
			}
			if matchMultipartBin(stem, s.Name) {
				bins = append(bins, s)
			}
		}
		if len(bins) == 0 {
			continue
		}
		memberIDs := []string{a.ArtifactID}
		requiredIDs := []string{a.ArtifactID}
		for _, b := range bins {
			memberIDs = append(memberIDs, b.ArtifactID)
			requiredIDs = append(requiredIDs, b.ArtifactID)
			consumed[b.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindMultipartInstaller,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: requiredIDs,
		})
	}

	// C2: cue/bin optical disc package
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsFile || a.Kind != core.ArtifactKindDiscDescriptor {
			continue
		}
		if strings.ToLower(filepath.Ext(a.Name)) != ".cue" {
			continue
		}
		parent := a.ParentPath
		siblings := byParent[parent]
		var bins []*core.Artifact
		for _, s := range siblings {
			if consumed[s.ArtifactID] || !s.IsFile || s.Kind != core.ArtifactKindDiscTrack {
				continue
			}
			ext := strings.ToLower(filepath.Ext(s.Name))
			if ext == ".bin" {
				bins = append(bins, s)
			}
		}
		memberIDs := []string{a.ArtifactID}
		requiredIDs := []string{a.ArtifactID}
		for _, b := range bins {
			memberIDs = append(memberIDs, b.ArtifactID)
			requiredIDs = append(requiredIDs, b.ArtifactID)
			consumed[b.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindOpticalDiscSet,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: requiredIDs,
		})
	}

	// C3: single ISO package
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsFile || a.Kind != core.ArtifactKindDiscImage {
			continue
		}
		if strings.ToLower(filepath.Ext(a.Name)) != ".iso" {
			continue
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindOpticalDiscImage,
			MemberArtifactIDs:         []string{a.ArtifactID},
			RequiredMemberArtifactIDs: []string{a.ArtifactID},
		})
	}

	// C6: extracted console game directory (PS3_GAME, PARAM.SFO, etc.)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsDir {
			continue
		}
		children := byParent[a.Path]
		if !hasExtractedConsoleSignature(children) {
			continue
		}
		memberIDs := []string{a.ArtifactID}
		for _, c := range children {
			memberIDs = append(memberIDs, c.ArtifactID)
			consumed[c.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindExtractedConsoleGameDirectory,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: memberIDs,
		})
	}

	// C5: DOS game directory (.exe/.com/.bat + DOS-era data)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsDir {
			continue
		}
		children := byParent[a.Path]
		if !hasDOSGameSignature(children) {
			continue
		}
		memberIDs := []string{a.ArtifactID}
		for _, c := range children {
			memberIDs = append(memberIDs, c.ArtifactID)
			consumed[c.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindDOSGameDirectory,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: memberIDs,
		})
	}

	// C4: portable native game directory (executable + assets, self-contained)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsDir {
			continue
		}
		children := byParent[a.Path]
		if !hasPortableGameSignature(children) {
			continue
		}
		memberIDs := []string{a.ArtifactID}
		for _, c := range children {
			memberIDs = append(memberIDs, c.ArtifactID)
			consumed[c.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindPortableGameDirectory,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: memberIDs,
		})
	}

	// C9: extras collection (manuals, images, soundtracks, etc. only)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsDir {
			continue
		}
		children := byParent[a.Path]
		if !hasExtrasOnlySignature(children) {
			continue
		}
		memberIDs := []string{a.ArtifactID}
		for _, c := range children {
			memberIDs = append(memberIDs, c.ArtifactID)
			consumed[c.ArtifactID] = true
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindExtrasCollection,
			MemberArtifactIDs:         memberIDs,
			RequiredMemberArtifactIDs: memberIDs,
		})
	}

	// C7: archive as package root (archive_candidate)
	for _, a := range artifacts {
		if consumed[a.ArtifactID] || !a.IsFile || a.Kind != core.ArtifactKindArchive {
			continue
		}
		consumed[a.ArtifactID] = true
		packages = append(packages, &core.Package{
			PackageID:                 a.ArtifactID,
			RootArtifactID:            a.ArtifactID,
			PackageKind:               core.PackageKindArchiveCandidate,
			MemberArtifactIDs:         []string{a.ArtifactID},
			RequiredMemberArtifactIDs: []string{a.ArtifactID},
		})
	}

	// C8: MAME-style single archive (already covered as archive_candidate; C8 says "if single archive is whole payload and no multipart" - we treat single archives as C7 archive_candidate; C8 can refine later)
	// No additional pass: single archives without multipart companions were not consumed by C1, so they get C7. Done.

	return packages
}

func matchMultipartBin(stem, name string) bool {
	ext := filepath.Ext(name)
	if strings.ToLower(ext) != ".bin" {
		return false
	}
	base := strings.TrimSuffix(name, ext)
	return strings.HasPrefix(base, stem+"-") && regexp.MustCompile(`^[0-9]+$`).MatchString(strings.TrimPrefix(base, stem+"-"))
}

func hasExtractedConsoleSignature(children []*core.Artifact) bool {
	names := make(map[string]bool)
	for _, c := range children {
		names[c.Name] = true
	}
	return names["PS3_GAME"] || names["PS3_DISC.SFB"] || names["PARAM.SFO"]
}

func hasDOSGameSignature(children []*core.Artifact) bool {
	hasExe := false
	hasData := false
	for _, c := range children {
		if c.IsDir {
			continue
		}
		ext := strings.ToLower(c.Extension)
		if ext == ".exe" || ext == ".com" || ext == ".bat" {
			hasExe = true
		}
		if ext == ".dat" || ext == ".drv" || ext == ".def" || ext == ".voc" || ext == ".cmf" {
			hasData = true
		}
	}
	return hasExe && hasData
}

func hasPortableGameSignature(children []*core.Artifact) bool {
	hasExe := false
	hasAsset := false
	for _, c := range children {
		if c.IsDir {
			continue
		}
		switch c.Kind {
		case core.ArtifactKindWindowsExecutable, core.ArtifactKindDOSExecutable, core.ArtifactKindScriptLauncher:
			hasExe = true
		case core.ArtifactKindGameData, core.ArtifactKindImageAsset, core.ArtifactKindAudioMedia, core.ArtifactKindManualOrDocument:
			hasAsset = true
		}
	}
	return hasExe && hasAsset
}

func hasExtrasOnlySignature(children []*core.Artifact) bool {
	for _, c := range children {
		if c.IsDir {
			return false
		}
		switch c.Kind {
		case core.ArtifactKindManualOrDocument, core.ArtifactKindImageAsset, core.ArtifactKindAudioMedia:
			continue
		case core.ArtifactKindWindowsExecutable, core.ArtifactKindDOSExecutable, core.ArtifactKindScriptLauncher,
			core.ArtifactKindArchive, core.ArtifactKindDiscImage, core.ArtifactKindDiscDescriptor, core.ArtifactKindDiscTrack:
			return false
		default:
			// game_data, unknown etc. - allow as extras
		}
	}
	return len(children) > 0
}
