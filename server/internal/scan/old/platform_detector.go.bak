package scan

import (
	"path/filepath"
	"strings"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

// DetectPlatform sets game.Platform from path hints, package structure, and title.
func DetectPlatform(game *core.Game, pkg *core.Package, artifacts []*core.Artifact, pathHints *core.PathHints) {
	if game == nil {
		return
	}
	p := platformFromPathHints(pathHints)
	if p != core.PlatformUnknown {
		game.Platform = p
		return
	}
	normalizedTitle := strings.ToLower(game.Title)
	p = platformFromTitle(normalizedTitle)
	if p != core.PlatformUnknown {
		game.Platform = p
		return
	}
	p = platformFromPackageStructure(pkg, artifacts)
	if p != core.PlatformUnknown {
		game.Platform = p
		return
	}
	game.Platform = core.PlatformUnknown
}

func platformFromPathHints(h *core.PathHints) core.Platform {
	if h == nil || h.Platform == "" {
		return core.PlatformUnknown
	}
	switch strings.ToLower(strings.TrimSpace(h.Platform)) {
	case "windows_pc", "pc", "windows":
		return core.PlatformWindowsPC
	case "ms_dos", "dos":
		return core.PlatformMSDOS
	case "arcade":
		return core.PlatformArcade
	case "gba":
		return core.PlatformGBA
	case "ps1", "playstation", "psx":
		return core.PlatformPS1
	case "ps2", "playstation2":
		return core.PlatformPS2
	case "ps3", "playstation3":
		return core.PlatformPS3
	case "psp":
		return core.PlatformPSP
	case "xbox_360", "xbox360":
		return core.PlatformXbox360
	case "scummvm":
		return core.PlatformScummVM
	default:
		return core.PlatformUnknown
	}
}

func platformFromTitle(title string) core.Platform {
	if title == "" {
		return core.PlatformUnknown
	}
	if strings.Contains(title, "ps2") || strings.Contains(title, "playstation 2") {
		return core.PlatformPS2
	}
	if strings.Contains(title, "ps1") || strings.Contains(title, "playstation 1") || strings.Contains(title, "psx") {
		return core.PlatformPS1
	}
	if strings.Contains(title, "ps3") || strings.Contains(title, "playstation 3") {
		return core.PlatformPS3
	}
	if strings.Contains(title, "psp") {
		return core.PlatformPSP
	}
	if strings.Contains(title, "gba") || strings.Contains(title, "game boy advance") {
		return core.PlatformGBA
	}
	if strings.Contains(title, "xbox 360") || strings.Contains(title, "xbox360") {
		return core.PlatformXbox360
	}
	if strings.Contains(title, "scummvm") {
		return core.PlatformScummVM
	}
	if strings.Contains(title, "arcade") {
		return core.PlatformArcade
	}
	if strings.Contains(title, "dos") || strings.Contains(title, "ms-dos") {
		return core.PlatformMSDOS
	}
	return core.PlatformUnknown
}

func platformFromPackageStructure(pkg *core.Package, artifacts []*core.Artifact) core.Platform {
	if pkg == nil {
		return core.PlatformUnknown
	}
	artifactByID := make(map[string]*core.Artifact)
	for _, a := range artifacts {
		if a != nil {
			artifactByID[a.ArtifactID] = a
		}
	}
	root := artifactByID[pkg.RootArtifactID]
	switch pkg.PackageKind {
	case core.PackageKindOpticalDiscSet, core.PackageKindOpticalDiscImage:
		if root != nil {
			ext := strings.ToLower(filepath.Ext(root.Name))
			if ext == ".cue" {
				return core.PlatformPS1
			}
			if ext == ".iso" {
				return core.PlatformUnknown
			}
		}
	case core.PackageKindDOSGameDirectory:
		return core.PlatformMSDOS
	case core.PackageKindMultipartInstaller, core.PackageKindPortableGameDirectory:
		return core.PlatformWindowsPC
	default:
		return core.PlatformUnknown
	}
	return core.PlatformUnknown
}
