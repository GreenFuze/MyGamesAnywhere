package scan

import (
	"regexp"
	"strings"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

// addonMarkerKind returns the game kind and addon kind label if the title contains addon markers.
func addonMarkerKind(title string) (core.GameKind, string) {
	if title == "" {
		return "", ""
	}
	lower := strings.ToLower(title)
	switch {
	case strings.Contains(lower, "season pass"):
		return core.GameKindDLC, "season_pass"
	case strings.Contains(lower, "character pack"):
		return core.GameKindAddon, "character_pack"
	case strings.Contains(lower, "bundle pack"):
		return core.GameKindAddon, "bundle_pack"
	case strings.Contains(lower, "level pack"):
		return core.GameKindAddon, "level_pack"
	case strings.Contains(lower, "expansion"):
		return core.GameKindExpansion, "expansion"
	case strings.Contains(lower, "bonus content"):
		return core.GameKindAddon, "bonus_content"
	case strings.Contains(lower, "soundtrack"):
		return core.GameKindAddon, "soundtrack"
	case strings.Contains(lower, "artbook"):
		return core.GameKindAddon, "artbook"
	case strings.Contains(lower, "patch"):
		return core.GameKindPatch, "patch"
	case strings.Contains(lower, "update"):
		return core.GameKindPatch, "update"
	case strings.Contains(lower, "dlc"):
		return core.GameKindDLC, "dlc"
	default:
		return "", ""
	}
}

// packageKindToDefaultKind returns the default game kind for a package kind.
func packageKindToDefaultKind(k core.PackageKind) core.GameKind {
	switch k {
	case core.PackageKindPortableGameDirectory, core.PackageKindDOSGameDirectory, core.PackageKindExtractedConsoleGameDirectory:
		return core.GameKindBaseGame
	case core.PackageKindMultipartInstaller:
		return core.GameKindBaseGame
	case core.PackageKindOpticalDiscSet, core.PackageKindOpticalDiscImage:
		return core.GameKindBaseGame
	case core.PackageKindArchiveCandidate:
		return core.GameKindUnknown
	case core.PackageKindExtrasCollection:
		return core.GameKindExtras
	default:
		return core.GameKindUnknown
	}
}

// GamesFromPackages converts packages and artifacts into Games with Kind, Title, PackageKind, RootPath set.
// Game ID is set to PackageID. Platform and ParentGameID are set later.
func GamesFromPackages(packages []*core.Package, artifacts []*core.Artifact) []*core.Game {
	artifactByID := make(map[string]*core.Artifact)
	for _, a := range artifacts {
		if a != nil {
			artifactByID[a.ArtifactID] = a
		}
	}

	var games []*core.Game
	for _, p := range packages {
		if p == nil {
			continue
		}
		root := artifactByID[p.RootArtifactID]
		title := ""
		if root != nil {
			title = RawTitleFromName(root.Name)
		}
		res := NormalizeTitle(title)

		var kind core.GameKind
		if k, _ := addonMarkerKind(title); k != "" {
			kind = k
		} else if p.PackageKind == core.PackageKindExtrasCollection {
			kind = core.GameKindExtras
		} else {
			kind = packageKindToDefaultKind(p.PackageKind)
			if kind == "" {
				kind = core.GameKindUnknown
			}
		}

		rootPath := ""
		if root != nil {
			rootPath = root.Path
		}

		gameTitle := res.Normalized
		if gameTitle == "" {
			gameTitle = title
		}
		g := &core.Game{
			ID:          p.PackageID,
			Title:       gameTitle,
			PackageKind: p.PackageKind,
			RootPath:    rootPath,
			Kind:        kind,
			Status:      "found",
		}
		games = append(games, g)
	}
	return games
}

func isBaseKind(k core.GameKind) bool {
	return k == core.GameKindBaseGame
}

// BindAddonsToBase sets ParentGameID on addon/dlc/patch/expansion games using title containment and sibling proximity.
func BindAddonsToBase(games []*core.Game, packages []*core.Package, artifacts []*core.Artifact) {
	packageByID := make(map[string]*core.Package)
	for _, p := range packages {
		if p != nil {
			packageByID[p.PackageID] = p
		}
	}
	artifactByID := make(map[string]*core.Artifact)
	for _, a := range artifacts {
		if a != nil {
			artifactByID[a.ArtifactID] = a
		}
	}
	gameByID := make(map[string]*core.Game)
	for _, g := range games {
		if g != nil {
			gameByID[g.ID] = g
		}
	}

	baseGameIDs := make(map[string]bool)
	for _, g := range games {
		if g != nil && isBaseKind(g.Kind) {
			baseGameIDs[g.ID] = true
		}
	}

	addonKinds := map[core.GameKind]bool{
		core.GameKindAddon: true, core.GameKindDLC: true,
		core.GameKindExpansion: true, core.GameKindPatch: true,
	}

	for _, g := range games {
		if g == nil || !addonKinds[g.Kind] {
			continue
		}
		baseTitle := stripAddonMarkersFromTitle(g.Title)
		baseID := baseGameByTitleContainment(g.ID, baseTitle, games, baseGameIDs)
		if baseID == "" {
			baseID = baseGameBySiblingProximity(g, packageByID, artifactByID, gameByID, baseGameIDs)
		}
		if baseID != "" {
			g.ParentGameID = baseID
		}
	}
}

func stripAddonMarkersFromTitle(title string) string {
	s := strings.ToLower(title)
	for _, m := range []string{"season pass", "dlc", "character pack", "bundle pack", "level pack", "expansion", "bonus content", "soundtrack", "artbook", "update", "patch"} {
		s = strings.ReplaceAll(s, m, " ")
	}
	return strings.TrimSpace(regexp.MustCompile(`\s+`).ReplaceAllString(s, " "))
}

func baseGameByTitleContainment(addonGameID, addonBaseTitle string, games []*core.Game, baseGameIDs map[string]bool) string {
	if addonBaseTitle == "" {
		return ""
	}
	for _, g := range games {
		if g == nil || !baseGameIDs[g.ID] || g.ID == addonGameID {
			continue
		}
		if g.Title == "" {
			continue
		}
		if strings.Contains(strings.ToLower(g.Title), addonBaseTitle) || strings.Contains(addonBaseTitle, strings.ToLower(g.Title)) {
			return g.ID
		}
	}
	return ""
}

func baseGameBySiblingProximity(addon *core.Game, packageByID map[string]*core.Package, artifactByID map[string]*core.Artifact, gameByID map[string]*core.Game, baseGameIDs map[string]bool) string {
	p := packageByID[addon.ID]
	if p == nil {
		return ""
	}
	root := artifactByID[p.RootArtifactID]
	if root == nil {
		return ""
	}
	parentPath := root.ParentPath
	for pkgID, pkg := range packageByID {
		if pkg == nil || pkgID == addon.ID {
			continue
		}
		g := gameByID[pkgID]
		if g == nil || !baseGameIDs[g.ID] {
			continue
		}
		rootA := artifactByID[pkg.RootArtifactID]
		if rootA != nil && rootA.ParentPath == parentPath {
			return g.ID
		}
	}
	return ""
}
