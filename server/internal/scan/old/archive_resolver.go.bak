package scan

import (
	"archive/zip"
	"path/filepath"
	"strings"

	"github.com/GreenFuze/MyGamesAnywhere/server/internal/core"
)

// ListArchiveMembers lists top-level member names in a ZIP archive. Path must be a local file path.
// Returns nil, nil if not a zip or on error (caller can leave role unknown).
func ListArchiveMembers(path string) ([]string, error) {
	r, err := zip.OpenReader(path)
	if err != nil {
		return nil, err
	}
	defer r.Close()
	var names []string
	seen := make(map[string]bool)
	for _, f := range r.File {
		top := topLevelName(f.Name)
		if top != "" && !seen[top] {
			seen[top] = true
			names = append(names, top)
		}
	}
	return names, nil
}

func topLevelName(name string) string {
	name = strings.TrimPrefix(name, "/")
	idx := strings.Index(name, "/")
	if idx >= 0 {
		return name[:idx]
	}
	return name
}

// ClassifyArchiveByMembers returns the operational role for an archive based on member names (Phase J).
func ClassifyArchiveByMembers(memberNames []string) core.OperationalRole {
	if len(memberNames) == 0 {
		return core.OperationalRoleUnknown
	}
	lowerNames := make([]string, len(memberNames))
	for i, n := range memberNames {
		lowerNames[i] = strings.ToLower(n)
	}
	if hasInstallerLikeMembers(lowerNames) {
		return core.OperationalRoleInstaller
	}
	if hasPortableGameMembers(lowerNames) {
		return core.OperationalRolePortableGame
	}
	if hasRomLikeMembers(lowerNames) {
		return core.OperationalRoleEmulatorRom
	}
	if hasExtrasLikeMembers(lowerNames) {
		return core.OperationalRoleExtras
	}
	return core.OperationalRoleUnknown
}

func hasInstallerLikeMembers(names []string) bool {
	for _, n := range names {
		base := strings.ToLower(filepath.Base(n))
		if base == "setup.exe" || base == "install.exe" || base == "installer.exe" ||
			strings.HasPrefix(base, "unins") || strings.HasPrefix(base, "setup ") {
			return true
		}
	}
	return false
}

func hasPortableGameMembers(names []string) bool {
	hasExe := false
	hasOther := false
	for _, n := range names {
		ext := strings.ToLower(filepath.Ext(n))
		if ext == ".exe" {
			hasExe = true
		} else if ext != "" && ext != ".txt" && ext != ".url" {
			hasOther = true
		}
	}
	if len(names) == 1 && hasExe {
		return true
	}
	for _, n := range names {
		if strings.HasSuffix(strings.ToLower(n), ".exe") {
			hasExe = true
			break
		}
	}
	for _, n := range names {
		ext := filepath.Ext(strings.ToLower(n))
		if ext == ".dll" || ext == ".dat" || ext == ".bin" || ext == ".pak" {
			hasOther = true
			break
		}
	}
	return hasExe && (hasOther || len(names) > 2)
}

var romExtensions = map[string]bool{
	".nes": true, ".smc": true, ".sfc": true, ".gba": true, ".gb": true, ".gbc": true,
	".z64": true, ".n64": true, ".v64": true, ".nds": true, ".iso": true, ".cue": true,
	".bin": true, ".rom": true, ".a26": true, ".a78": true,
}

func hasRomLikeMembers(names []string) bool {
	for _, n := range names {
		ext := strings.ToLower(filepath.Ext(n))
		if romExtensions[ext] {
			return true
		}
	}
	return false
}

func hasExtrasLikeMembers(names []string) bool {
	manualOrMedia := 0
	for _, n := range names {
		ext := strings.ToLower(filepath.Ext(n))
		if ext == ".pdf" || ext == ".txt" || ext == ".jpg" || ext == ".png" || ext == ".mp3" || ext == ".flac" {
			manualOrMedia++
		}
	}
	return manualOrMedia >= len(names)/2+1
}
