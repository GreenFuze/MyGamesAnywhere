<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Daylight theme — light color tokens.
    Values mirror the web CSS variables in server/frontend/src/theme/presets.ts.
  -->

  <!-- Base colors -->
  <Color x:Key="MgaBgColor">#f0f2f8</Color>
  <Color x:Key="MgaSurfaceColor">#ffffff</Color>
  <Color x:Key="MgaElevatedColor">#e8eaf2</Color>
  <Color x:Key="MgaBorderColor">#d0d4e8</Color>
  <Color x:Key="MgaTextColor">#1a1a2e</Color>
  <Color x:Key="MgaMutedColor">#6b6e8a</Color>
  <Color x:Key="MgaAccentColor">#0080cc</Color>
  <Color x:Key="MgaAccentMutedColor">#cce5f5</Color>
  <Color x:Key="MgaAccentGlowColor">#0080cc30</Color>
  <Color x:Key="MgaDangerColor">#dc2626</Color>
  <Color x:Key="MgaSuccessColor">#16a34a</Color>
  <Color x:Key="MgaWarningColor">#d97706</Color>

  <!-- Sidebar -->
  <Color x:Key="MgaSidebarBgColor">#e4e8f5</Color>
  <Color x:Key="MgaSidebarActiveColor">#cdd5ef</Color>

  <!-- Overlay / scrim -->
  <Color x:Key="MgaOverlayColor">#80f0f2f8</Color>

</ResourceDictionary>
