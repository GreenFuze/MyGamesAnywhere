<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             x:Class="MGA.Desktop.Controls.TitleBar"
             x:DataType="vm:MainWindowViewModel"
             Height="48">

  <!--
    Fixed-width column layout:
      Col 0: 220px — logo + app name
      Col 1: *     — drag region (search removed; use Library search instead)
      Col 2: 138px — chrome buttons (3 × 46px)

    DragRegion sits behind all interactive controls (IsHitTestVisible on logo
    prevents it intercepting clicks on the draggable area).
  -->
  <Grid ColumnDefinitions="220,*,138"
        Background="{DynamicResource MgaSurfaceBrush}">

    <!-- ── Col 0: Logo + app name ──────────────────────────────── -->
    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                Spacing="10"
                Margin="14,0,0,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False">
      <Image Source="/Assets/mga.ico" Width="20" Height="20"/>
      <TextBlock Text="MyGamesAnywhere"
                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                 FontSize="{DynamicResource MgaFontSizeMd}"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <!-- ── Full-width drag region (Col 0-2) — declared before chrome buttons
         so that buttons render on top (higher Z-order) and receive clicks ── -->
    <Border Name="DragRegion"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Background="Transparent"/>

    <!-- ── Col 2: Chrome buttons (min / max / close) ─────────────── -->
    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch">

      <Button Name="MinimizeButton"
              Classes="chrome"
              Width="46"
              Height="48"
              ToolTip.Tip="Minimize">
        <TextBlock Text="&#x2013;"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Button>

      <Button Name="MaximizeButton"
              Classes="chrome"
              Width="46"
              Height="48"
              ToolTip.Tip="Maximize / Restore">
        <TextBlock Text="&#x25A1;"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Button>

      <Button Name="CloseButton"
              Classes="chrome close"
              Width="46"
              Height="48"
              ToolTip.Tip="Close">
        <TextBlock Text="&#x2715;"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Button>

    </StackPanel>

  </Grid>
</UserControl>
