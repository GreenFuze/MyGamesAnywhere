<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             x:Class="MGA.Desktop.Controls.TitleBar"
             x:DataType="vm:MainWindowViewModel"
             Height="48">

  <!--
    Custom title bar.
    The entire bar is a drag region except for the window chrome buttons (right end).
    IsHitTestVisible is managed in code-behind: Chrome buttons are excluded from drag.
  -->
  <Grid ColumnDefinitions="Auto,*,Auto,Auto"
        Background="{DynamicResource MgaSurfaceBrush}"
        IsHitTestVisible="True">

    <!-- Drag region covers the whole bar; the chrome buttons sit on top with IsHitTestVisible=True -->
    <Border Grid.ColumnSpan="4"
            Name="DragRegion"
            Background="Transparent"/>

    <!-- Left: logo + app name -->
    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                Spacing="10"
                Margin="16,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False">
      <Image Source="/Assets/mga.ico" Width="20" Height="20"/>
      <TextBlock Text="MyGamesAnywhere"
                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                 FontSize="{DynamicResource MgaFontSizeMd}"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Center: global search box -->
    <TextBox Grid.Column="1"
             Name="GlobalSearchBox"
             Text="{Binding GlobalSearchText}"
             PlaceholderText="Search games…"
             MaxWidth="400"
             Margin="8,6"
             VerticalAlignment="Center"
             IsHitTestVisible="True"
             FontSize="{DynamicResource MgaFontSizeSm}"
             Background="{DynamicResource MgaElevatedBrush}"
             BorderThickness="0"
             CornerRadius="{DynamicResource MgaRadiusFull}"
             Padding="14,6">
      <TextBox.KeyBindings>
        <KeyBinding Gesture="Return" Command="{Binding GlobalSearchCommand}"/>
      </TextBox.KeyBindings>
    </TextBox>

    <!-- Server URL indicator (col 2) -->
    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                Spacing="6"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False"
                IsVisible="{Binding ActiveServerUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="●"
                 Foreground="{DynamicResource MgaSuccessBrush}"
                 FontSize="8"
                 VerticalAlignment="Center"/>
      <TextBlock Text="{Binding ActiveServerUrl}"
                 Foreground="{DynamicResource MgaMutedBrush}"
                 FontSize="{DynamicResource MgaFontSizeSm}"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Right: window chrome buttons (NOT part of drag region) -->
    <StackPanel Grid.Column="3"
                Orientation="Horizontal"
                Spacing="0"
                Margin="0,0,4,0"
                VerticalAlignment="Stretch"
                IsHitTestVisible="True"
                Name="ChromeButtons">

      <!-- Minimize -->
      <Button Name="MinimizeButton"
              Classes="ghost chrome"
              Width="46" Height="48"
              ToolTip.Tip="Minimize">
        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets,Segoe UI Symbol" FontSize="10"/>
      </Button>

      <!-- Maximize / Restore -->
      <Button Name="MaximizeButton"
              Classes="ghost chrome"
              Width="46" Height="48"
              ToolTip.Tip="Maximize">
        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets,Segoe UI Symbol" FontSize="10"/>
      </Button>

      <!-- Close -->
      <Button Name="CloseButton"
              Classes="ghost chrome close"
              Width="46" Height="48"
              ToolTip.Tip="Close">
        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets,Segoe UI Symbol" FontSize="10"/>
      </Button>
    </StackPanel>

  </Grid>
</UserControl>
