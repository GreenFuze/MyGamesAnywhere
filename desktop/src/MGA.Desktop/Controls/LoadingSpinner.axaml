<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MGA.Desktop.Controls.LoadingSpinner"
             Width="32" Height="32">

  <!--
    Rotating arc spinner.
    An Ellipse with a short StrokeDashArray segment rotates using a looping
    RotateTransform animation on its parent Panel.
  -->
  <Panel Width="32" Height="32" RenderTransformOrigin="50%,50%">

    <!-- Faint full-circle track -->
    <Ellipse Width="26" Height="26"
             Stroke="{DynamicResource MgaBorderBrush}"
             StrokeThickness="3"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>

    <!-- Spinning arc segment -->
    <Ellipse Name="SpinArc"
             Width="26" Height="26"
             Stroke="{DynamicResource MgaAccentBrush}"
             StrokeThickness="3"
             StrokeDashArray="6,18"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             RenderTransformOrigin="50%,50%">
      <Ellipse.RenderTransform>
        <RotateTransform Angle="0"/>
      </Ellipse.RenderTransform>
      <Ellipse.Styles>
        <Style Selector="Ellipse#SpinArc">
          <Style.Animations>
            <Animation Duration="0:0:0.9" IterationCount="INFINITE" Easing="LinearEasing">
              <KeyFrame Cue="0%">
                <Setter Property="RotateTransform.Angle" Value="0"/>
              </KeyFrame>
              <KeyFrame Cue="100%">
                <Setter Property="RotateTransform.Angle" Value="360"/>
              </KeyFrame>
            </Animation>
          </Style.Animations>
        </Style>
      </Ellipse.Styles>
    </Ellipse>

  </Panel>
</UserControl>
