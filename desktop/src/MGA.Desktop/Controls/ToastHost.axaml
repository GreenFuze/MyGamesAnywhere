<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:MGA.Desktop.Services"
             x:Class="MGA.Desktop.Controls.ToastHost"
             IsHitTestVisible="False"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Margin="0,0,24,24"
             Width="340">

  <!--
    Stacked toast notifications.
    Items are added/removed by ToastService; each fades in and auto-dismisses.
  -->
  <ItemsControl Name="ToastList"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom">
    <ItemsControl.ItemTemplate>
      <DataTemplate x:DataType="svc:ToastMessage">
        <Border Name="ToastCard"
                Classes="card"
                Margin="0,6,0,0"
                IsHitTestVisible="True"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
            </Transitions>
          </Border.Transitions>
          <Grid ColumnDefinitions="4,*" RowDefinitions="Auto,Auto">
            <!-- Tone accent bar -->
            <Border Grid.Column="0" Grid.RowSpan="2"
                    CornerRadius="3,0,0,3"
                    Width="4"
                    Margin="-16,-16,8,-16"
                    Name="ToneBar"/>
            <!-- Title -->
            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="{Binding Title}"
                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                       FontSize="{DynamicResource MgaFontSizeSm}"/>
            <!-- Description (optional) -->
            <TextBlock Grid.Column="1" Grid.Row="1"
                       Text="{Binding Description}"
                       Classes="muted"
                       IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0"/>
          </Grid>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>

</UserControl>
