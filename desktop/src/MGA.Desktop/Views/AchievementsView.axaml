<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.AchievementsView"
             x:DataType="vm:AchievementsViewModel">

  <!--
    Two panels share the same root DockPanel; only one is visible at a time:
      - Dashboard panel: summary stats + By Source + By Game (SelectedGame == null)
      - Explorer panel:  per-game achievement sets + search/filter (SelectedGame != null)
  -->
  <Panel>

    <!-- ======================================================================
         DASHBOARD PANEL — visible when no game is selected
         ====================================================================== -->
    <DockPanel IsVisible="{Binding SelectedGame, Converter={x:Static ObjectConverters.IsNull}}">

      <!-- ── Fixed header ── -->
      <StackPanel DockPanel.Dock="Top"
                  Margin="32,32,32,16"
                  Spacing="12">

        <!-- Heading row: title + refresh button -->
        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <TextBlock Text="Achievements" Classes="heading"/>
          <Button Classes="primary"
                  Command="{Binding RefreshCommand}"
                  Content="↻ Refresh"
                  IsEnabled="{Binding !IsRefreshing}"
                  VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Unlock summary -->
        <TextBlock Classes="muted">
          <Run Text="{Binding UnlockedAchievements}"/>
          <Run Text=" / "/>
          <Run Text="{Binding TotalAchievements}"/>
          <Run Text=" unlocked ("/>
          <Run Text="{Binding UnlockPercent}"/>
          <Run Text=")"/>
        </TextBlock>

      </StackPanel>

      <!-- ── Refresh progress card (SSE-driven) ── -->
      <Border DockPanel.Dock="Top"
              Classes="card"
              Margin="32,0,32,8"
              Padding="16,12"
              IsVisible="{Binding IsRefreshing}">
        <StackPanel Spacing="8">

          <!-- Spinner + status text -->
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <controls:LoadingSpinner/>
            <TextBlock Text="{Binding RefreshProgressText}"
                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>

          <!-- Progress bar -->
          <ProgressBar Minimum="0"
                       Maximum="{Binding RefreshProgressMax}"
                       Value="{Binding RefreshProgressValue}"
                       Height="6"
                       CornerRadius="{DynamicResource MgaRadiusFull}"
                       Foreground="{DynamicResource MgaAccentBrush}"
                       Background="{DynamicResource MgaElevatedBrush}"/>

          <!-- Rate-limit waiting message -->
          <TextBlock IsVisible="{Binding IsRefreshWaiting}"
                     Text="{Binding RefreshWaitingMessage}"
                     Classes="muted"
                     FontSize="{DynamicResource MgaFontSizeSm}"/>

          <!-- Warning count (shown when warnings accumulate) -->
          <TextBlock IsVisible="{Binding HasRefreshWarnings}"
                     Text="{Binding RefreshWarningCount, StringFormat='⚠ {0} warning(s) so far'}"
                     Foreground="{DynamicResource MgaWarningBrush}"
                     FontSize="{DynamicResource MgaFontSizeSm}"/>

        </StackPanel>
      </Border>

      <!-- ── Loading spinner ── -->
      <Border DockPanel.Dock="Top"
              IsVisible="{Binding IsLoading}"
              HorizontalAlignment="Center"
              Margin="0,24">
        <controls:LoadingSpinner/>
      </Border>

      <!-- ── Scrollable body ── -->
      <ScrollViewer IsVisible="{Binding !IsLoading}">
        <StackPanel Margin="32,0,32,32" Spacing="24">

          <!-- By Source -->
          <StackPanel Spacing="8">
            <TextBlock Text="By Source" Classes="subheading"/>

            <ItemsControl ItemsSource="{Binding Systems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AchievementSystemRowModel">
                  <Border Classes="card" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="*,Auto">

                      <!-- Source name + progress bar + count -->
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding Source}"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                        <TextBlock Classes="muted">
                          <Run Text="{Binding Unlocked}"/>
                          <Run Text=" / "/>
                          <Run Text="{Binding Total}"/>
                          <Run Text=" ("/>
                          <Run Text="{Binding PercentText}"/>
                          <Run Text=")"/>
                        </TextBlock>
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding Total}"
                                     Value="{Binding Unlocked}"
                                     Height="6"
                                     CornerRadius="{DynamicResource MgaRadiusFull}"
                                     Foreground="{DynamicResource MgaAccentBrush}"
                                     Background="{DynamicResource MgaElevatedBrush}"
                                     Margin="0,4,0,0"/>
                      </StackPanel>

                      <!-- Points (shown only when source has points) -->
                      <StackPanel Grid.Column="1"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right"
                                  Margin="16,0,0,0"
                                  Spacing="2"
                                  IsVisible="{Binding TotalPoints}">
                        <TextBlock Text="{Binding EarnedPoints}"
                                   FontWeight="{DynamicResource MgaFontWeightBold}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TotalPoints, StringFormat='/ {0} pts'}"
                                   Classes="muted"
                                   HorizontalAlignment="Right"/>
                      </StackPanel>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- By Game -->
          <StackPanel Spacing="8">
            <TextBlock Text="By Game" Classes="subheading"/>

            <ItemsControl ItemsSource="{Binding Games}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AchievementGameRowModel">
                  <Border Classes="card" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="48,*,Auto,Auto">

                      <!-- Thumbnail -->
                      <Border Grid.Column="0"
                              Width="40" Height="56"
                              CornerRadius="{DynamicResource MgaRadiusSm}"
                              ClipToBounds="True"
                              Background="{DynamicResource MgaElevatedBrush}"
                              Margin="0,0,12,0">
                        <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                                 Stretch="UniformToFill"/>
                      </Border>

                      <!-- Title + progress bar -->
                      <StackPanel Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Spacing="4">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                   TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding Total}"
                                     Value="{Binding Unlocked}"
                                     Height="5"
                                     CornerRadius="{DynamicResource MgaRadiusFull}"
                                     Foreground="{DynamicResource MgaSuccessBrush}"
                                     Background="{DynamicResource MgaElevatedBrush}"/>
                      </StackPanel>

                      <!-- Count + percent -->
                      <StackPanel Grid.Column="2"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right"
                                  Margin="16,0,0,0"
                                  Spacing="2">
                        <TextBlock FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                   HorizontalAlignment="Right">
                          <Run Text="{Binding Unlocked}"/>
                          <Run Text="/"/>
                          <Run Text="{Binding Total}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding PercentText}"
                                   Classes="muted"
                                   HorizontalAlignment="Right"/>
                      </StackPanel>

                      <!-- View achievements button -->
                      <Button Grid.Column="3"
                              Classes="ghost"
                              Content="View →"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"
                              Command="{Binding $parent[ItemsControl].((vm:AchievementsViewModel)DataContext).SelectGameCommand}"
                              CommandParameter="{Binding}"/>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

    </DockPanel>

    <!-- ======================================================================
         EXPLORER PANEL — visible when a game is selected
         ====================================================================== -->
    <DockPanel IsVisible="{Binding SelectedGame, Converter={x:Static ObjectConverters.IsNotNull}}">

      <!-- ── Fixed header ── -->
      <Border DockPanel.Dock="Top" Padding="32,28,32,0">
        <StackPanel Spacing="12">

          <!-- Back button + game title -->
          <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button Classes="ghost"
                    Content="← Back"
                    Command="{Binding CloseDetailCommand}"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedGame.Title}"
                       Classes="heading"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Unlock summary for the selected game -->
          <TextBlock Classes="muted">
            <Run Text="{Binding SelectedGame.Unlocked}"/>
            <Run Text=" / "/>
            <Run Text="{Binding SelectedGame.Total}"/>
            <Run Text=" unlocked ("/>
            <Run Text="{Binding SelectedGame.PercentText}"/>
            <Run Text=")"/>
          </TextBlock>

          <!-- Search + filter row -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
            <TextBox Text="{Binding AchievementSearchText}"
                     PlaceholderText="Search achievements…"
                     Width="280"
                     CornerRadius="{DynamicResource MgaRadiusFull}"
                     Background="{DynamicResource MgaElevatedBrush}"
                     BorderThickness="0"
                     Padding="14,6"/>
            <ComboBox ItemsSource="{Binding AchievementFilterOptions}"
                      SelectedIndex="{Binding AchievementFilterIndex}"
                      Width="140"
                      VerticalAlignment="Center"/>
          </StackPanel>

        </StackPanel>
      </Border>

      <!-- ── Loading spinner ── -->
      <Border DockPanel.Dock="Top"
              IsVisible="{Binding IsLoadingExplorer}"
              HorizontalAlignment="Center"
              Margin="0,32">
        <controls:LoadingSpinner/>
      </Border>

      <!-- ── Per-source sets ── -->
      <ScrollViewer IsVisible="{Binding !IsLoadingExplorer}"
                    Margin="32,16,32,32">
        <ItemsControl ItemsSource="{Binding ExplorerSets}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AchievementSetRowViewModel">
              <StackPanel Spacing="8" Margin="0,0,0,24">

                <!-- Set header: source label + points (if any) -->
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding HeaderLabel}"
                               Classes="subheading"/>
                    <TextBlock IsVisible="{Binding Platform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Classes="muted"
                               FontSize="{DynamicResource MgaFontSizeXs}"
                               Text="{Binding Platform}"/>
                  </StackPanel>
                  <!-- Points badge (shown when source tracks points) -->
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="4"
                              VerticalAlignment="Center"
                              IsVisible="{Binding TotalPoints}">
                    <TextBlock Text="{Binding EarnedPoints}"
                               FontWeight="{DynamicResource MgaFontWeightBold}"/>
                    <TextBlock Text="{Binding TotalPoints, StringFormat='/ {0} pts'}"
                               Classes="muted"/>
                  </StackPanel>
                </Grid>

                <!-- Achievement rows -->
                <ItemsControl ItemsSource="{Binding Achievements}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AchievementRowModel">
                      <Border Classes="card"
                              Margin="0,0,0,4"
                              Background="{DynamicResource MgaSurfaceBrush}">
                        <Grid ColumnDefinitions="52,*,Auto">

                          <!-- Icon (locked ↔ unlocked) -->
                          <Border Grid.Column="0"
                                  Width="44" Height="44"
                                  CornerRadius="{DynamicResource MgaRadiusSm}"
                                  ClipToBounds="True"
                                  Background="{DynamicResource MgaElevatedBrush}"
                                  Margin="0,0,12,0">
                            <asyncImage:AdvancedImage Source="{Binding IconUrl}"
                                                     Stretch="UniformToFill"
                                                     IsVisible="{Binding IconUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          </Border>

                          <!-- Title + description + unlock date -->
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Spacing="2">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Description}"
                                       Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeSm}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0"
                                        IsVisible="{Binding Unlocked}">
                              <TextBlock Text="✓ Unlocked"
                                         Foreground="{DynamicResource MgaSuccessBrush}"
                                         FontSize="{DynamicResource MgaFontSizeXs}"
                                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                              <TextBlock Text="{Binding UnlockedAt}"
                                         Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"
                                         IsVisible="{Binding UnlockedAt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                          </StackPanel>

                          <!-- Points + rarity -->
                          <StackPanel Grid.Column="2"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Margin="12,0,0,0"
                                      Spacing="2">
                            <TextBlock IsVisible="{Binding Points}"
                                       Text="{Binding Points, StringFormat='{}{0} pts'}"
                                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock IsVisible="{Binding RarityText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Text="{Binding RarityText}"
                                       Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"
                                       HorizontalAlignment="Right"
                                       ToolTip.Tip="Rarity (% of players who unlocked this)"/>
                          </StackPanel>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </DockPanel>

  </Panel>

</UserControl>
