<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:svc="using:MGA.Desktop.Services"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.GameDetailView"
             x:DataType="vm:GameDetailViewModel">

  <DockPanel>

    <!-- ======================================================================
         Loading state — centered spinner
         ====================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,64">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ======================================================================
         Sticky page header — always visible, docked at top
         ====================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding !IsLoading}"
            Background="#0a0810"
            BorderBrush="{DynamicResource MgaBorderBrush}"
            BorderThickness="0,0,0,1"
            Height="48"
            Padding="8,0">
      <Grid ColumnDefinitions="Auto,*,Auto"
            VerticalAlignment="Center">

        <!-- Left: back button with arrow and accent glow -->
        <Button Grid.Column="0"
                Classes="ghost"
                Command="{Binding GoBackCommand}"
                VerticalAlignment="Center"
                Padding="10,6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="←"
                       FontSize="16"
                       Foreground="{DynamicResource MgaAccentBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="Back"
                       FontSize="{DynamicResource MgaFontSizeSm}"
                       Foreground="{DynamicResource MgaTextBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Centre: game title (truncated) -->
        <TextBlock Grid.Column="1"
                   Text="{Binding Title}"
                   FontSize="{DynamicResource MgaFontSizeSm}"
                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                   Foreground="{DynamicResource MgaTextBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,80,0"/>

      </Grid>
    </Border>

    <!-- ======================================================================
         Main content (hidden while loading)
         ====================================================================== -->
    <ScrollViewer Name="ContentScroller"
                  IsVisible="{Binding !IsLoading}"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel HorizontalAlignment="Stretch">

        <!-- ================================================================
             Hero image area with cinematic frosted overlay
             ================================================================ -->
        <Grid Height="340">

          <!-- Hero background image (full-bleed, async-loaded) -->
          <Border ClipToBounds="True"
                  Background="{DynamicResource MgaElevatedBrush}">
            <asyncImage:AdvancedImage Source="{Binding HeroImageUrl}"
                                      Stretch="UniformToFill"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
          </Border>

          <!-- Top vignette (subtle dark from top) -->
          <Border VerticalAlignment="Top" Height="80">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#88000000" Offset="0"/>
                <GradientStop Color="#00000000" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Bottom frosted gradient overlay -->
          <Border VerticalAlignment="Bottom" Height="180">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#00000000" Offset="0"/>
                <GradientStop Color="#AA0c0a10" Offset="0.5"/>
                <GradientStop Color="#EE0c0a10" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>

            <!-- Title, platform badge, and favorite indicator inside the overlay -->
            <StackPanel VerticalAlignment="Bottom"
                        Margin="24,0,24,20"
                        Spacing="8">

              <!-- Title -->
              <TextBlock Text="{Binding Title}"
                         FontSize="{DynamicResource MgaFontSize2xl}"
                         FontWeight="{DynamicResource MgaFontWeightBold}"
                         Foreground="#FFFFFF"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="2"/>

              <!-- Platform badge + favorite row -->
              <StackPanel Orientation="Horizontal" Spacing="10">

                <!-- Platform badge with dynamic platform color -->
                <Border Background="{Binding PlatformBadgeColor}"
                        CornerRadius="{DynamicResource MgaRadiusFull}"
                        Padding="10,4">
                  <TextBlock Text="{Binding FormattedPlatform}"
                             FontSize="{DynamicResource MgaFontSizeXs}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             Foreground="#FFFFFF"
                             IsVisible="{Binding FormattedPlatform,
                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Border>

                <!-- Favorite indicator -->
                <Border Background="#33F5C518"
                        CornerRadius="{DynamicResource MgaRadiusFull}"
                        Padding="10,4"
                        IsVisible="{Binding Favorite}">
                  <TextBlock Text="★ Favorite"
                             FontSize="{DynamicResource MgaFontSizeXs}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             Foreground="{DynamicResource MgaWarningBrush}"/>
                </Border>

              </StackPanel>
            </StackPanel>
          </Border>

        </Grid>

        <!-- ================================================================
             Action bar — styled row with primary action + secondary actions
             ================================================================ -->
        <Border Margin="0,0,0,0"
                Background="{DynamicResource MgaSurfaceBrush}"
                BorderBrush="{DynamicResource MgaBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
          <Grid ColumnDefinitions="*,Auto">

            <!-- LEFT: Primary / install actions -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">

              <!-- ── EMULATED GAME PATH (platform requires native emulation) ─── -->
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsEmulatedGame}">

                <!-- Computing state spinner -->
                <controls:LoadingSpinner Width="16" Height="16"
                                         IsVisible="{Binding IsComputingEmulationState}"/>

                <!-- Play via emulator (emulator is ready) -->
                <StackPanel Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding CanPlayViaEmulator}">

                  <!-- Primary play button -->
                  <Button Classes="primary"
                          Command="{Binding LaunchWithEmulatorCommand}"
                          ToolTip.Tip="{Binding PrimaryEmulatorLabel}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="▶" FontSize="13" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding PrimaryEmulatorLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>

                  <!-- Config picker ComboBox — only visible when >1 config available -->
                  <ComboBox ItemsSource="{Binding EmulatorConfigs}"
                            SelectedItem="{Binding SelectedEmulatorConfig, Mode=TwoWay}"
                            IsVisible="{Binding HasMultipleEmulatorConfigs}"
                            VerticalAlignment="Center"
                            MinWidth="150"
                            ToolTip.Tip="Choose emulator configuration">
                    <ComboBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type svc:EmulatorConfig}">
                        <TextBlock Text="{Binding DisplayName}"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>

                </StackPanel>

                <!-- Locate/Install button (packed game, not yet located on device) -->
                <Button Classes="primary"
                        Command="{Binding LocateEmulatedGameCommand}"
                        IsVisible="{Binding NeedsEmulatedInstall}"
                        ToolTip.Tip="Point to where this game is installed on this device">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Locate Install" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Setup Emulator button (no emulator configured for this platform) -->
                <Button Classes="ghost"
                        Command="{Binding SetupEmulatorCommand}"
                        IsVisible="{Binding NeedsEmulatorSetup}"
                        ToolTip.Tip="No emulator configured for this platform. Go to Settings → Emulators.">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource MgaWarningBrush}"/>
                    <TextBlock Text="Setup Emulator" VerticalAlignment="Center"
                               Foreground="{DynamicResource MgaWarningBrush}"/>
                  </StackPanel>
                </Button>

                <!-- BIOS Missing button -->
                <Button Classes="ghost"
                        Command="{Binding OpenBiosManagerCommand}"
                        IsVisible="{Binding NeedsBiosSetup}"
                        ToolTip.Tip="{Binding MissingBiosMessage}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⚠" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource MgaWarningBrush}"/>
                    <TextBlock Text="BIOS Missing" VerticalAlignment="Center"
                               Foreground="{DynamicResource MgaWarningBrush}"/>
                  </StackPanel>
                </Button>

                <!-- Uninstall button (MGA-managed install only) -->
                <Button Classes="ghost"
                        Command="{Binding UninstallEmulatedGameCommand}"
                        IsVisible="{Binding CanUninstallEmulatedGame}"
                        ToolTip.Tip="Remove this game from this device">
                  <TextBlock Text="✕ Uninstall"
                             FontSize="{DynamicResource MgaFontSizeSm}"
                             Foreground="{DynamicResource MgaMutedBrush}"/>
                </Button>

              </StackPanel>

              <!-- ── STOREFRONT / WINDOWS NATIVE PATH ──────────────────────── -->
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !IsEmulatedGame}">

                <!-- "Detecting…" spinner while detection is running -->
                <Border VerticalAlignment="Center"
                        IsVisible="{Binding IsDetectingInstall}">
                  <TextBlock Text="Detecting install…"
                             Classes="muted"
                             FontSize="{DynamicResource MgaFontSizeXs}"
                             VerticalAlignment="Center"/>
                </Border>

                <!-- Launch button -->
                <Button Classes="primary"
                        Command="{Binding LaunchGameCommand}"
                        IsVisible="{Binding IsInstalled}"
                        ToolTip.Tip="{Binding InstallStatus.ExePath}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="▶" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Launch" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Install button -->
                <Button Classes="primary"
                        Command="{Binding InstallGameCommand}"
                        IsVisible="{Binding CanInstallGame}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⬇" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Install" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Install client -->
                <Button Classes="ghost"
                        Command="{Binding OpenClientDownloadCommand}"
                        IsVisible="{Binding NeedsClientInstall}"
                        ToolTip.Tip="{Binding ClientDownloadUrl}">
                  <TextBlock>
                    <Run Text="⬇ "/>
                    <Run Text="{Binding ClientMissingMessage}"/>
                  </TextBlock>
                </Button>

                <!-- Browse for exe -->
                <Button Classes="ghost"
                        Command="{Binding PickExePathCommand}"
                        Content="📂 Browse exe"
                        IsVisible="{Binding NeedsManualBind}"/>

                <!-- Open install folder -->
                <Button Classes="ghost"
                        Command="{Binding OpenInstallFolderCommand}"
                        Content="📁 Folder"
                        IsVisible="{Binding IsInstalled}"
                        ToolTip.Tip="{Binding InstallStatus.InstallPath}"/>

                <!-- Installed badge -->
                <Border Background="#1A3db8ff"
                        BorderBrush="#443db8ff"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MgaRadiusFull}"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsInstalled}">
                  <TextBlock Text="✓ Installed"
                             Foreground="{DynamicResource MgaAccentBrush}"
                             FontSize="{DynamicResource MgaFontSizeXs}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                </Border>

              </StackPanel>

            </StackPanel>

            <!-- RIGHT: secondary actions -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">

              <!-- Favorite toggle -->
              <Button Classes="ghost"
                      Command="{Binding ToggleFavoriteCommand}"
                      ToolTip.Tip="Remove from favorites"
                      IsVisible="{Binding Favorite}"
                      Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="★" FontSize="14" Foreground="{DynamicResource MgaWarningBrush}" VerticalAlignment="Center"/>
                  <TextBlock Text="Favorite" FontSize="12" Foreground="{DynamicResource MgaWarningBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Classes="ghost"
                      Command="{Binding ToggleFavoriteCommand}"
                      ToolTip.Tip="Add to favorites"
                      IsVisible="{Binding !Favorite}"
                      Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="☆" FontSize="14" Foreground="{DynamicResource MgaMutedBrush}" VerticalAlignment="Center"/>
                  <TextBlock Text="Favorite" FontSize="12" Foreground="{DynamicResource MgaMutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <!-- Metadata refresh -->
              <Button Classes="ghost"
                      Command="{Binding RefreshMetadataCommand}"
                      ToolTip.Tip="Refresh metadata from online providers"
                      IsEnabled="{Binding !IsRefreshingMetadata}"
                      Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="↻" FontSize="14" Foreground="{DynamicResource MgaMutedBrush}" VerticalAlignment="Center"/>
                  <TextBlock Text="Refresh" FontSize="12" Foreground="{DynamicResource MgaMutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <!-- Media manager -->
              <Button Classes="ghost"
                      Command="{Binding OpenMediaManagerCommand}"
                      ToolTip.Tip="Manage cover art and media"
                      IsVisible="{Binding HasMedia}"
                      Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="🖼" FontSize="13" VerticalAlignment="Center"/>
                  <TextBlock Text="Media" FontSize="12" Foreground="{DynamicResource MgaMutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

            </StackPanel>
          </Grid>
        </Border>

        <!-- ================================================================
             Media carousel — screenshots and header images
             ================================================================ -->
        <Border Margin="0,16,0,0"
                IsVisible="{Binding HasScreenshots}">
          <StackPanel Spacing="10">

            <!-- Section label -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0">
              <Border Width="3" Height="14"
                      Background="{DynamicResource MgaAccentBrush}"
                      CornerRadius="2"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Media"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Horizontal scrollable carousel -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="24,0,24,4">
              <ItemsControl ItemsSource="{Binding Screenshots}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:MediaItemModel">
                    <Border CornerRadius="{DynamicResource MgaRadiusMd}"
                            ClipToBounds="True"
                            Background="{DynamicResource MgaElevatedBrush}"
                            BorderBrush="{DynamicResource MgaBorderBrush}"
                            BorderThickness="1"
                            Width="288" Height="162">
                      <asyncImage:AdvancedImage Source="{Binding Url}"
                                               Stretch="UniformToFill"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </StackPanel>
        </Border>

        <!-- ================================================================
             Achievement summary row (only visible when game has achievements)
             ================================================================ -->
        <Border Margin="24,12,24,0"
                Classes="card"
                IsVisible="{Binding HasAchievements}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="🏆" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="{Binding AchievementUnlocked}"/>
              <Run Text=" / "/>
              <Run Text="{Binding AchievementTotal}"/>
              <Run Text=" achievements"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- ================================================================
             Metadata panel — description + key/value grid
             ================================================================ -->
        <Border Margin="24,16,24,0"
                Classes="card">
          <StackPanel Spacing="16">

            <!-- Description -->
            <StackPanel Spacing="8"
                        IsVisible="{Binding Description,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="3" Height="13"
                        Background="{DynamicResource MgaAccentBrush}"
                        CornerRadius="2"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Description"
                           FontSize="{DynamicResource MgaFontSizeSm}"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                           Foreground="{DynamicResource MgaTextBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{Binding Description}"
                         TextWrapping="Wrap"
                         LineHeight="22"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         FontSize="{DynamicResource MgaFontSizeSm}"/>
            </StackPanel>

            <!-- Divider -->
            <Border Height="1"
                    Background="{DynamicResource MgaBorderBrush}"
                    IsVisible="{Binding Description,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Key-value metadata grid — label column is uppercase muted, value is full text -->
            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

              <!-- Genres -->
              <TextBlock Grid.Row="0" Grid.Column="0"
                         Text="GENRES"
                         FontSize="{DynamicResource MgaFontSizeXs}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         Margin="0,0,0,10"
                         VerticalAlignment="Top"
                         IsVisible="{Binding GenresText,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <TextBlock Grid.Row="0" Grid.Column="1"
                         Text="{Binding GenresText}"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,10"
                         IsVisible="{Binding GenresText,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Release Date -->
              <TextBlock Grid.Row="1" Grid.Column="0"
                         Text="RELEASED"
                         FontSize="{DynamicResource MgaFontSizeXs}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding ReleaseDate,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <TextBlock Grid.Row="1" Grid.Column="1"
                         Text="{Binding ReleaseDate}"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding ReleaseDate,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Developer -->
              <TextBlock Grid.Row="2" Grid.Column="0"
                         Text="DEVELOPER"
                         FontSize="{DynamicResource MgaFontSizeXs}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding Developer,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <TextBlock Grid.Row="2" Grid.Column="1"
                         Text="{Binding Developer}"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding Developer,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Publisher -->
              <TextBlock Grid.Row="3" Grid.Column="0"
                         Text="PUBLISHER"
                         FontSize="{DynamicResource MgaFontSizeXs}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding Publisher,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <TextBlock Grid.Row="3" Grid.Column="1"
                         Text="{Binding Publisher}"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding Publisher,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Rating -->
              <TextBlock Grid.Row="4" Grid.Column="0"
                         Text="RATING"
                         FontSize="{DynamicResource MgaFontSizeXs}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaMutedBrush}"
                         IsVisible="{Binding HasRating}"/>
              <StackPanel Grid.Row="4" Grid.Column="1"
                          Orientation="Horizontal" Spacing="6"
                          IsVisible="{Binding HasRating}">
                <TextBlock Text="{Binding Rating, StringFormat='{}{0:0.0}'}"
                           FontSize="{DynamicResource MgaFontSizeSm}"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                           Foreground="{DynamicResource MgaWarningBrush}"/>
                <TextBlock Text="/ 10"
                           FontSize="{DynamicResource MgaFontSizeXs}"
                           Foreground="{DynamicResource MgaMutedBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>

            </Grid>

          </StackPanel>
        </Border>

        <!-- ================================================================
             External Links
             ================================================================ -->
        <Border Margin="24,12,24,0"
                Classes="card"
                IsVisible="{Binding HasExternalLinks}">
          <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="3" Height="13"
                      Background="{DynamicResource MgaAccentBrush}"
                      CornerRadius="2"
                      VerticalAlignment="Center"/>
              <TextBlock Text="External Links"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding ExternalLinks}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExternalLinkViewModel">
                  <Button Classes="ghost"
                          Margin="0,0,8,0"
                          Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).OpenExternalLinkCommand}"
                          CommandParameter="{Binding .}"
                          IsEnabled="{Binding HasUrl}">
                    <TextBlock>
                      <Run Text="{Binding DisplaySource}"/>
                      <Run Text=" ↗" Foreground="{DynamicResource MgaAccentBrush}"/>
                    </TextBlock>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ================================================================
             Source Games
             ================================================================ -->
        <Border Margin="24,12,24,24"
                Classes="card"
                IsVisible="{Binding HasSourceGames}">
          <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="3" Height="13"
                      Background="{DynamicResource MgaAccentBrush}"
                      CornerRadius="2"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Sources"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                         Foreground="{DynamicResource MgaTextBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding SourceGames}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SourceGameRowViewModel">
                  <Border Padding="0,8"
                          BorderThickness="0,0,0,1"
                          BorderBrush="{DynamicResource MgaBorderBrush}">
                    <StackPanel Spacing="0">

                      <!-- ── Main row: title (left) + status/actions (right) ── -->
                      <Grid ColumnDefinitions="*,Auto">

                        <!-- Left: raw title + metadata line -->
                        <StackPanel Grid.Column="0" Spacing="2">
                          <TextBlock Text="{Binding RawTitle}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding IntegrationLabel}" Classes="muted"/>
                            <TextBlock Text="·" Classes="muted"/>
                            <TextBlock Text="{Binding Platform}" Classes="muted"/>
                            <TextBlock Text="·" Classes="muted"/>
                            <TextBlock Text="{Binding FileSummary}" Classes="muted"/>
                          </StackPanel>
                        </StackPanel>

                        <!-- Right: status badge + action buttons -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Spacing="4"
                                    Margin="12,0,0,0">

                          <!-- Status badge -->
                          <Border Background="{DynamicResource MgaElevatedBrush}"
                                  CornerRadius="{DynamicResource MgaRadiusSm}"
                                  Padding="6,2"
                                  HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Status}" Classes="muted" FontSize="11"/>
                          </Border>

                          <!-- Normal action strip (hidden while delete or merge is pending) -->
                          <StackPanel Orientation="Horizontal"
                                      Spacing="4"
                                      HorizontalAlignment="Right"
                                      IsVisible="{Binding !IsDeletePending}">
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⌥ Split"
                                    ToolTip.Tip="Detach this source into its own game entry"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).SplitSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⊕ Merge"
                                    ToolTip.Tip="Move this source into another game"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).RequestMergeSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⊘ Unpin"
                                    ToolTip.Tip="Remove the canonical pin for this source"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ClearPinCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Foreground="{DynamicResource MgaDangerBrush}"
                                    Content="🗑 Delete"
                                    ToolTip.Tip="Hard-delete this source and its files"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).RequestDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                          </StackPanel>

                          <!-- Inline delete confirmation strip -->
                          <StackPanel Orientation="Horizontal"
                                      Spacing="4"
                                      HorizontalAlignment="Right"
                                      IsVisible="{Binding IsDeletePending}">
                            <TextBlock Text="Delete files?"
                                       Classes="muted"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Foreground="{DynamicResource MgaDangerBrush}"
                                    Content="✓ Confirm"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ConfirmDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="✕ Cancel"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).CancelDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                          </StackPanel>

                        </StackPanel>
                      </Grid>

                      <!-- ── File paths — shown when source has local files ── -->
                      <Border Margin="0,4,0,0"
                              Background="{DynamicResource MgaElevatedBrush}"
                              CornerRadius="4"
                              Padding="8,6"
                              IsVisible="{Binding HasFiles}">
                        <StackPanel Spacing="4">

                          <!-- File count badge -->
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Background="{DynamicResource MgaAccentMutedBrush}"
                                    CornerRadius="3"
                                    Padding="5,1">
                              <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="#FFFFFF">
                                <Run Text="{Binding FileCount}"/>
                                <Run Text=" file(s)"/>
                              </TextBlock>
                            </Border>
                          </StackPanel>

                          <!-- File path list -->
                          <TextBox Text="{Binding FormattedFilePaths}"
                                   IsReadOnly="True"
                                   FontFamily="Cascadia Mono,Consolas,Courier New"
                                   FontSize="10"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Padding="0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MgaMutedBrush}"
                                   MaxHeight="120"/>

                        </StackPanel>
                      </Border>

                      <!-- ── Inline merge-target search panel ── -->
                      <StackPanel Spacing="6"
                                  Margin="0,8,0,0"
                                  IsVisible="{Binding IsMergePending}">

                        <TextBlock Text="Move this source into another game:"
                                   FontSize="11"
                                   Classes="muted"/>

                        <!-- Search box + button -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                          <TextBox Grid.Column="0"
                                   Text="{Binding MergeSearchQuery}"
                                   PlaceholderText="Search by title…"
                                   FontSize="12"
                                   Padding="6,4"/>
                          <Button Grid.Column="1"
                                  FontSize="11"
                                  Padding="8,4"
                                  Content="Search"
                                  IsEnabled="{Binding !IsMergeSearching}"
                                  Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).SearchMergeTargetsCommand}"
                                  CommandParameter="{Binding}"/>
                        </Grid>

                        <!-- In-progress indicator -->
                        <TextBlock Text="Searching…"
                                   FontSize="11"
                                   Classes="muted"
                                   IsVisible="{Binding IsMergeSearching}"/>

                        <!-- Search results list -->
                        <ItemsControl ItemsSource="{Binding MergeSearchResults}"
                                      IsVisible="{Binding HasMergeSearchResults}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CanonicalSearchResultViewModel">
                              <Border Margin="0,2"
                                      Background="{DynamicResource MgaElevatedBrush}"
                                      CornerRadius="{DynamicResource MgaRadiusSm}"
                                      Padding="8,5">
                                <Grid ColumnDefinitions="*,Auto">
                                  <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="10"
                                               Classes="muted"/>
                                  </StackPanel>
                                  <Button Grid.Column="1"
                                          Classes="ghost"
                                          FontSize="10"
                                          Padding="6,2"
                                          Foreground="{DynamicResource MgaWarningBrush}"
                                          Content="↪ Merge here"
                                          Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ConfirmMergeSourceCommand}"
                                          CommandParameter="{Binding}"/>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Cancel -->
                        <Button Classes="ghost"
                                FontSize="11"
                                Padding="6,2"
                                Content="✕ Cancel merge"
                                Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).CancelMergeSourceCommand}"
                                CommandParameter="{Binding}"/>
                      </StackPanel>

                      <!-- ── Resolver matches (read-only, collapsible) ── -->
                      <Border Margin="0,6,0,0"
                              Background="{DynamicResource MgaElevatedBrush}"
                              CornerRadius="{DynamicResource MgaRadiusSm}"
                              Padding="8,6"
                              IsVisible="{Binding HasResolverMatches}">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding ResolverMatchCountText}"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     Classes="muted"/>
                          <ItemsControl ItemsSource="{Binding ResolverMatches}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:SourceResolverMatchViewModel">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            Margin="0,2">
                                  <!-- Plugin ID badge -->
                                  <Border Background="{DynamicResource MgaAccentMutedBrush}"
                                          CornerRadius="{DynamicResource MgaRadiusSm}"
                                          Padding="4,1">
                                    <TextBlock Text="{Binding DisplayPluginId}"
                                               FontSize="9"
                                               Foreground="#FFFFFF"/>
                                  </Border>
                                  <!-- Status badge -->
                                  <Border Background="{DynamicResource MgaBorderBrush}"
                                          CornerRadius="{DynamicResource MgaRadiusSm}"
                                          Padding="4,1">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="9"
                                               Classes="muted"/>
                                  </Border>
                                  <!-- Title -->
                                  <TextBlock Text="{Binding Title}"
                                             FontSize="11"
                                             VerticalAlignment="Center"/>
                                  <!-- Platform -->
                                  <TextBlock Text="{Binding Platform}"
                                             FontSize="10"
                                             Classes="muted"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding Platform,
                                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
