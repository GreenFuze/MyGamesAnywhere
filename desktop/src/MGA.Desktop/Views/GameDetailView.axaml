<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.GameDetailView"
             x:DataType="vm:GameDetailViewModel">

  <DockPanel>

    <!-- ======================================================================
         Loading state — centered spinner
         ====================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,64">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ======================================================================
         Main content (hidden while loading)
         ====================================================================== -->
    <ScrollViewer IsVisible="{Binding !IsLoading}">
      <StackPanel>

        <!-- ================================================================
             Hero image area with frosted overlay
             ================================================================ -->
        <Grid Height="300">

          <!-- Hero background image (async-loaded; background media or cover fallback) -->
          <Border ClipToBounds="True"
                  Background="{DynamicResource MgaElevatedBrush}">
            <asyncImage:AdvancedImage Source="{Binding HeroImageUrl}"
                                      Stretch="UniformToFill"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
          </Border>

          <!-- Frosted gradient overlay at the bottom of the hero -->
          <Border VerticalAlignment="Bottom"
                  Height="140">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#00000000" Offset="0"/>
                <GradientStop Color="#CC000000" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>

            <!-- Title, platform badge, and favorite indicator inside the overlay -->
            <StackPanel VerticalAlignment="Bottom"
                        Margin="24,0,24,16"
                        Spacing="6">

              <!-- Title -->
              <TextBlock Text="{Binding Title}"
                         FontSize="{DynamicResource MgaFontSize2xl}"
                         FontWeight="{DynamicResource MgaFontWeightBold}"
                         Foreground="#FFFFFF"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="2"/>

              <!-- Platform badge + favorite row -->
              <StackPanel Orientation="Horizontal" Spacing="12">

                <!-- Platform badge -->
                <Border Background="{DynamicResource MgaAccentMutedBrush}"
                        CornerRadius="{DynamicResource MgaRadiusFull}"
                        Padding="10,3">
                  <TextBlock Text="{Binding Platform}"
                             FontSize="{DynamicResource MgaFontSizeXs}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             Foreground="#FFFFFF"/>
                </Border>

                <!-- Favorite indicator -->
                <TextBlock Text="★ Favorite"
                           FontSize="{DynamicResource MgaFontSizeSm}"
                           Foreground="{DynamicResource MgaWarningBrush}"
                           IsVisible="{Binding Favorite}"
                           VerticalAlignment="Center"/>

              </StackPanel>
            </StackPanel>
          </Border>

        </Grid>

        <!-- ================================================================
             Action bar — Play button + Back button
             ================================================================ -->
        <StackPanel Orientation="Horizontal"
                    Spacing="12"
                    Margin="24,16,24,0">

          <!-- ============================================================
               Install detection section
               ============================================================ -->

          <!-- "Detecting…" label shown while detection is running -->
          <Border VerticalAlignment="Center"
                  IsVisible="{Binding IsDetectingInstall}">
            <TextBlock Text="Detecting…"
                       Classes="muted"
                       FontSize="{DynamicResource MgaFontSizeXs}"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Launch button — shown when game exe is known and installed -->
          <Button Classes="primary"
                  Command="{Binding LaunchGameCommand}"
                  IsVisible="{Binding IsInstalled}"
                  ToolTip.Tip="{Binding InstallStatus.ExePath}">
            <TextBlock Text="▶ Launch"/>
          </Button>

          <!-- Install button — shown when game is in library but not downloaded -->
          <Button Classes="primary"
                  Command="{Binding InstallGameCommand}"
                  Content="⬇ Install"
                  IsVisible="{Binding CanInstallGame}"/>

          <!-- Install client — shown when the storefront client is missing -->
          <Button Classes="ghost"
                  Command="{Binding OpenClientDownloadCommand}"
                  IsVisible="{Binding NeedsClientInstall}"
                  ToolTip.Tip="{Binding ClientDownloadUrl}">
            <TextBlock>
              <Run Text="⬇ "/>
              <Run Text="{Binding ClientMissingMessage}"/>
            </TextBlock>
          </Button>

          <!-- Browse for exe — shown when installed but exe could not be resolved -->
          <Button Classes="ghost"
                  Command="{Binding PickExePathCommand}"
                  Content="📂 Browse exe"
                  IsVisible="{Binding NeedsManualBind}"/>

          <!-- Open install folder — shown alongside Launch when path is known -->
          <Button Classes="ghost"
                  Command="{Binding OpenInstallFolderCommand}"
                  Content="📁 Folder"
                  IsVisible="{Binding IsInstalled}"
                  ToolTip.Tip="{Binding InstallStatus.InstallPath}"/>

          <!-- Installed state badge -->
          <Border Background="#223db8ff"
                  CornerRadius="{DynamicResource MgaRadiusFull}"
                  Padding="8,3"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsInstalled}">
            <TextBlock Text="✓ Installed"
                       Foreground="{DynamicResource MgaAccentBrush}"
                       FontSize="{DynamicResource MgaFontSizeXs}"
                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
          </Border>

          <!-- Separator between install section and standard actions -->
          <Border Width="1"
                  Background="{DynamicResource MgaBorderBrush}"
                  Margin="4,4"
                  VerticalAlignment="Stretch"/>

          <!-- Emulator launch button — visible only when emulator is configured -->
          <Button Classes="primary"
                  Command="{Binding LaunchWithEmulatorCommand}"
                  IsVisible="{Binding CanLaunchWithEmulator}"
                  ToolTip.Tip="{Binding EmulatorName}">
            <TextBlock>
              <Run Text="▶ Launch with "/>
              <Run Text="{Binding EmulatorName}"/>
            </TextBlock>
          </Button>

          <Button Classes="primary"
                  Command="{Binding PlayInBrowserCommand}"
                  Content="🌐 Open Web Page"/>

          <!-- Favorite toggle — label swaps based on current state -->
          <Button Classes="ghost"
                  Command="{Binding ToggleFavoriteCommand}"
                  Content="★ Unfavorite"
                  IsVisible="{Binding Favorite}"/>
          <Button Classes="ghost"
                  Command="{Binding ToggleFavoriteCommand}"
                  Content="☆ Add to Favorites"
                  IsVisible="{Binding !Favorite}"/>

          <Button Classes="ghost"
                  Command="{Binding RefreshMetadataCommand}"
                  Content="↻ Metadata"
                  IsEnabled="{Binding !IsRefreshingMetadata}"
                  ToolTip.Tip="Refresh metadata from online providers"/>

          <Button Classes="ghost"
                  Command="{Binding OpenMediaManagerCommand}"
                  Content="🖼 Media"
                  ToolTip.Tip="Manage cover art and media overrides"
                  IsVisible="{Binding HasMedia}"/>

          <Button Classes="ghost"
                  Command="{Binding GoBackCommand}"
                  Content="← Back"/>

        </StackPanel>

        <!-- ================================================================
             Media carousel — screenshots and header images
             ================================================================ -->
        <Border Margin="0,12,0,0"
                IsVisible="{Binding HasScreenshots}">
          <StackPanel Spacing="8">

            <TextBlock Text="Media"
                       Classes="subheading"
                       Margin="24,0"/>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="24,0">
              <ItemsControl ItemsSource="{Binding Screenshots}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:MediaItemModel">
                    <Border CornerRadius="{DynamicResource MgaRadiusMd}"
                            ClipToBounds="True"
                            Background="{DynamicResource MgaElevatedBrush}"
                            Width="280" Height="158">
                      <asyncImage:AdvancedImage Source="{Binding Url}"
                                               Stretch="UniformToFill"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </StackPanel>
        </Border>

        <!-- ================================================================
             Achievement summary row (only visible when game has achievements)
             ================================================================ -->
        <Border Margin="24,12,24,0"
                Classes="card"
                IsVisible="{Binding HasAchievements}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="🏆" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="{Binding AchievementUnlocked}"/>
              <Run Text=" / "/>
              <Run Text="{Binding AchievementTotal}"/>
              <Run Text=" achievements"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- ================================================================
             Metadata panel
             ================================================================ -->
        <Border Margin="24,12,24,12"
                Classes="card">
          <StackPanel Spacing="12">

            <!-- Description -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding Description,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="Description"
                         Classes="subheading"/>
              <TextBlock Text="{Binding Description}"
                         TextWrapping="Wrap"
                         Classes="muted"/>
            </StackPanel>

            <!-- Genres -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding GenresText,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="Genres" Classes="subheading"/>
              <TextBlock Text="{Binding GenresText}" Classes="muted"/>
            </StackPanel>

            <!-- Release date -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding ReleaseDate,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="Release Date" Classes="subheading"/>
              <TextBlock Text="{Binding ReleaseDate}" Classes="muted"/>
            </StackPanel>

            <!-- Developer -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding Developer,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="Developer" Classes="subheading"/>
              <TextBlock Text="{Binding Developer}" Classes="muted"/>
            </StackPanel>

            <!-- Publisher -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding Publisher,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="Publisher" Classes="subheading"/>
              <TextBlock Text="{Binding Publisher}" Classes="muted"/>
            </StackPanel>

            <!-- Rating -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding HasRating}">
              <TextBlock Text="Rating" Classes="subheading"/>
              <TextBlock Text="{Binding Rating, StringFormat='{}{0:0.0}'}"
                         Classes="muted"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- ================================================================
             External Links
             ================================================================ -->
        <Border Margin="24,0,24,12"
                Classes="card"
                IsVisible="{Binding HasExternalLinks}">
          <StackPanel Spacing="8">
            <TextBlock Text="External Links" Classes="subheading"/>
            <ItemsControl ItemsSource="{Binding ExternalLinks}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExternalLinkViewModel">
                  <Button Classes="ghost"
                          Margin="0,0,8,0"
                          Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).OpenExternalLinkCommand}"
                          CommandParameter="{Binding .}"
                          IsEnabled="{Binding HasUrl}">
                    <TextBlock>
                      <Run Text="{Binding Source}"/>
                      <Run Text=" ↗" Foreground="{DynamicResource MgaAccentBrush}"/>
                    </TextBlock>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ================================================================
             Source Games
             ================================================================ -->
        <Border Margin="24,0,24,24"
                Classes="card"
                IsVisible="{Binding HasSourceGames}">
          <StackPanel Spacing="8">
            <TextBlock Text="Sources" Classes="subheading"/>
            <ItemsControl ItemsSource="{Binding SourceGames}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SourceGameRowViewModel">
                  <Border Padding="0,8"
                          BorderThickness="0,0,0,1"
                          BorderBrush="{DynamicResource MgaBorderBrush}">
                    <StackPanel Spacing="0">

                      <!-- ── Main row: title (left) + status/actions (right) ── -->
                      <Grid ColumnDefinitions="*,Auto">

                        <!-- Left: raw title + metadata line -->
                        <StackPanel Grid.Column="0" Spacing="2">
                          <TextBlock Text="{Binding RawTitle}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding IntegrationLabel}" Classes="muted"/>
                            <TextBlock Text="·" Classes="muted"/>
                            <TextBlock Text="{Binding Platform}" Classes="muted"/>
                            <TextBlock Text="·" Classes="muted"/>
                            <TextBlock Text="{Binding FileSummary}" Classes="muted"/>
                          </StackPanel>
                        </StackPanel>

                        <!-- Right: status badge + action buttons -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Spacing="4"
                                    Margin="12,0,0,0">

                          <!-- Status badge -->
                          <Border Background="{DynamicResource MgaElevatedBrush}"
                                  CornerRadius="{DynamicResource MgaRadiusSm}"
                                  Padding="6,2"
                                  HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Status}" Classes="muted" FontSize="11"/>
                          </Border>

                          <!-- Normal action strip (hidden while delete or merge is pending) -->
                          <StackPanel Orientation="Horizontal"
                                      Spacing="4"
                                      HorizontalAlignment="Right"
                                      IsVisible="{Binding !IsDeletePending}">
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⌥ Split"
                                    ToolTip.Tip="Detach this source into its own game entry"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).SplitSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⊕ Merge"
                                    ToolTip.Tip="Move this source into another game"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).RequestMergeSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="⊘ Unpin"
                                    ToolTip.Tip="Remove the canonical pin for this source"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ClearPinCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Foreground="{DynamicResource MgaDangerBrush}"
                                    Content="🗑 Delete"
                                    ToolTip.Tip="Hard-delete this source and its files"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).RequestDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                          </StackPanel>

                          <!-- Inline delete confirmation strip -->
                          <StackPanel Orientation="Horizontal"
                                      Spacing="4"
                                      HorizontalAlignment="Right"
                                      IsVisible="{Binding IsDeletePending}">
                            <TextBlock Text="Delete files?"
                                       Classes="muted"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Foreground="{DynamicResource MgaDangerBrush}"
                                    Content="✓ Confirm"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ConfirmDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    FontSize="11"
                                    Padding="6,2"
                                    Content="✕ Cancel"
                                    Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).CancelDeleteSourceCommand}"
                                    CommandParameter="{Binding}"/>
                          </StackPanel>

                        </StackPanel>
                      </Grid>

                      <!-- ── Inline merge-target search panel ── -->
                      <StackPanel Spacing="6"
                                  Margin="0,8,0,0"
                                  IsVisible="{Binding IsMergePending}">

                        <TextBlock Text="Move this source into another game:"
                                   FontSize="11"
                                   Classes="muted"/>

                        <!-- Search box + button -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                          <TextBox Grid.Column="0"
                                   Text="{Binding MergeSearchQuery}"
                                   PlaceholderText="Search by title…"
                                   FontSize="12"
                                   Padding="6,4"/>
                          <Button Grid.Column="1"
                                  FontSize="11"
                                  Padding="8,4"
                                  Content="Search"
                                  IsEnabled="{Binding !IsMergeSearching}"
                                  Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).SearchMergeTargetsCommand}"
                                  CommandParameter="{Binding}"/>
                        </Grid>

                        <!-- In-progress indicator -->
                        <TextBlock Text="Searching…"
                                   FontSize="11"
                                   Classes="muted"
                                   IsVisible="{Binding IsMergeSearching}"/>

                        <!-- Search results list -->
                        <ItemsControl ItemsSource="{Binding MergeSearchResults}"
                                      IsVisible="{Binding HasMergeSearchResults}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CanonicalSearchResultViewModel">
                              <Border Margin="0,2"
                                      Background="{DynamicResource MgaElevatedBrush}"
                                      CornerRadius="{DynamicResource MgaRadiusSm}"
                                      Padding="8,5">
                                <Grid ColumnDefinitions="*,Auto">
                                  <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="10"
                                               Classes="muted"/>
                                  </StackPanel>
                                  <Button Grid.Column="1"
                                          Classes="ghost"
                                          FontSize="10"
                                          Padding="6,2"
                                          Foreground="{DynamicResource MgaWarningBrush}"
                                          Content="↪ Merge here"
                                          Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).ConfirmMergeSourceCommand}"
                                          CommandParameter="{Binding}"/>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Cancel -->
                        <Button Classes="ghost"
                                FontSize="11"
                                Padding="6,2"
                                Content="✕ Cancel merge"
                                Command="{Binding $parent[UserControl].((vm:GameDetailViewModel)DataContext).CancelMergeSourceCommand}"
                                CommandParameter="{Binding}"/>
                      </StackPanel>

                      <!-- ── Resolver matches (read-only, collapsible) ── -->
                      <Border Margin="0,6,0,0"
                              Background="{DynamicResource MgaElevatedBrush}"
                              CornerRadius="{DynamicResource MgaRadiusSm}"
                              Padding="8,6"
                              IsVisible="{Binding HasResolverMatches}">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding ResolverMatchCountText}"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     Classes="muted"/>
                          <ItemsControl ItemsSource="{Binding ResolverMatches}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:SourceResolverMatchViewModel">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            Margin="0,2">
                                  <!-- Plugin ID badge -->
                                  <Border Background="{DynamicResource MgaAccentMutedBrush}"
                                          CornerRadius="{DynamicResource MgaRadiusSm}"
                                          Padding="4,1">
                                    <TextBlock Text="{Binding PluginId}"
                                               FontSize="9"
                                               Foreground="#FFFFFF"/>
                                  </Border>
                                  <!-- Status badge -->
                                  <Border Background="{DynamicResource MgaBorderBrush}"
                                          CornerRadius="{DynamicResource MgaRadiusSm}"
                                          Padding="4,1">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="9"
                                               Classes="muted"/>
                                  </Border>
                                  <!-- Title -->
                                  <TextBlock Text="{Binding Title}"
                                             FontSize="11"
                                             VerticalAlignment="Center"/>
                                  <!-- Platform -->
                                  <TextBlock Text="{Binding Platform}"
                                             FontSize="10"
                                             Classes="muted"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding Platform,
                                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
