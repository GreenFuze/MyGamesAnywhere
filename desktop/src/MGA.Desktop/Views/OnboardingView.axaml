<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:ctrl="using:MGA.Desktop.Controls"
             xmlns:api="using:MGA.Api"
             x:Class="MGA.Desktop.Views.OnboardingView"
             x:DataType="vm:OnboardingViewModel">

  <!--
    First-Run Wizard.
    Steps: Welcome → Connect → Profile → Done
    Each step panel is shown / hidden via IsVisible bindings.
  -->
  <Border Background="{DynamicResource MgaBgBrush}">
    <Grid RowDefinitions="*,Auto,*"
          HorizontalAlignment="Center"
          Width="480">

      <!-- ====================================================================
           Centred wizard card
           ==================================================================== -->
      <Border Grid.Row="1"
              Classes="card"
              Padding="40,36">
        <StackPanel Spacing="0">

          <!-- MGA logo + app name (always visible) -->
          <StackPanel HorizontalAlignment="Center" Spacing="12" Margin="0,0,0,28">
            <Image Source="/Assets/mga.ico" Width="56" Height="56"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="MyGamesAnywhere"
                       Classes="heading"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- ==================================================================
               Step 0 — Welcome
               ================================================================== -->
          <StackPanel Spacing="20"
                      IsVisible="{Binding ShowWelcome}">
            <TextBlock Text="Welcome to MyGamesAnywhere!"
                       FontSize="{DynamicResource MgaFontSizeLg}"
                       FontWeight="{DynamicResource MgaFontWeightBold}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock TextWrapping="Wrap"
                       Classes="muted"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
              Your personal game library — all platforms, all sources,
              one beautiful interface. Let's connect to your server to get started.
            </TextBlock>
            <Button Classes="primary"
                    Content="Get Started →"
                    Command="{Binding GetStartedCommand}"
                    HorizontalAlignment="Center"
                    Padding="24,10"/>
          </StackPanel>

          <!-- ==================================================================
               Step 1 — Connect to server
               ================================================================== -->
          <StackPanel Spacing="16"
                      IsVisible="{Binding ShowConnect}">
            <TextBlock Text="Connect to Server"
                       FontSize="{DynamicResource MgaFontSizeLg}"
                       FontWeight="{DynamicResource MgaFontWeightBold}"/>
            <TextBlock Classes="muted"
                       TextWrapping="Wrap">
              Enter the address of your MGA server. You can find this in the server
              configuration file or its startup logs.
            </TextBlock>

            <!-- URL input -->
            <StackPanel Spacing="6">
              <TextBlock Text="Server URL"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         FontWeight="{DynamicResource MgaFontWeightMedium}"/>
              <TextBox Classes="mga"
                       Text="{Binding ServerUrl}"
                       PlaceholderText="http://hostname:8900"
                       IsEnabled="{Binding !IsTesting}"/>
            </StackPanel>

            <!-- Error message -->
            <Border Background="{DynamicResource MgaDangerBrush}"
                    CornerRadius="{DynamicResource MgaRadiusMd}"
                    Padding="12,10"
                    IsVisible="{Binding TestError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding TestError}"
                         Foreground="#ffffff"
                         TextWrapping="Wrap"
                         FontSize="{DynamicResource MgaFontSizeSm}"/>
            </Border>

            <!-- Connect button + spinner -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <Button Grid.Column="0"
                      Classes="primary"
                      Command="{Binding ConnectCommand}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      IsEnabled="{Binding !IsTesting}">
                <Panel>
                  <TextBlock Text="Connect"     IsVisible="{Binding !IsTesting}"/>
                  <TextBlock Text="Connecting…" IsVisible="{Binding IsTesting}"/>
                </Panel>
              </Button>
              <ctrl:LoadingSpinner Grid.Column="1"
                                   IsVisible="{Binding IsTesting}"
                                   Width="28" Height="28"/>
            </Grid>
          </StackPanel>

          <!-- ==================================================================
               Step 2 — Select Profile
               ================================================================== -->
          <StackPanel Spacing="16"
                      IsVisible="{Binding ShowProfile}">
            <TextBlock Text="Select Your Profile"
                       FontSize="{DynamicResource MgaFontSizeLg}"
                       FontWeight="{DynamicResource MgaFontWeightBold}"/>
            <TextBlock Classes="muted" TextWrapping="Wrap">
              Choose the gamer profile to use on this machine.
              You can change this later in Settings.
            </TextBlock>

            <!-- Profile loading spinner -->
            <Border IsVisible="{Binding IsLoadingProfiles}" HorizontalAlignment="Center">
              <ctrl:LoadingSpinner Width="28" Height="28"/>
            </Border>

            <!-- Profile list — each card is a button; clicking immediately selects & advances -->
            <ItemsControl ItemsSource="{Binding Profiles}"
                          IsVisible="{Binding !IsLoadingProfiles}"
                          MaxHeight="260">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="api:Profile">
                  <!--
                    Bind SelectAndConfirmCommand via the ancestor UserControl's DataContext.
                    CommandParameter passes the current Profile item.
                  -->
                  <Button Classes="profileCard"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Margin="0,0,0,6"
                          Command="{Binding $parent[UserControl].((vm:OnboardingViewModel)DataContext).SelectAndConfirmCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Spacing="2" Margin="0,2">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      <TextBlock Text="{Binding Role}"
                                 Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- No-profiles case: inline create-first-profile form -->
            <StackPanel Spacing="8"
                        IsVisible="{Binding ShowCreateProfile}">
              <TextBlock Classes="muted" FontSize="{DynamicResource MgaFontSizeSm}">
                No profiles found on this server. Enter a name to create the first one.
              </TextBlock>
              <TextBox Text="{Binding NewProfileName}"
                       PlaceholderText="Your name"
                       FontSize="{DynamicResource MgaFontSizeMd}"/>
              <Button Classes="primary"
                      Content="Create Profile"
                      Command="{Binding CreateProfileCommand}"
                      IsEnabled="{Binding NewProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
          </StackPanel>

          <!-- ==================================================================
               Step 3 — Done
               ================================================================== -->
          <StackPanel Spacing="20"
                      HorizontalAlignment="Center"
                      IsVisible="{Binding ShowDone}">
            <TextBlock Text="🎉 All Set!"
                       FontSize="{DynamicResource MgaFontSize2xl}"
                       FontWeight="{DynamicResource MgaFontWeightBold}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock TextWrapping="Wrap"
                       Classes="muted"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
              Your server is connected and your profile is ready.
              Dive into your game library!
            </TextBlock>
            <Button Classes="primary"
                    Content="Open Library →"
                    Command="{Binding OpenLibraryCommand}"
                    HorizontalAlignment="Center"
                    Padding="24,10"/>
          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>
  </Border>

</UserControl>
