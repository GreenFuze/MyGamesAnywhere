<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:settingsVm="using:MGA.Desktop.ViewModels.Settings"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:services="using:MGA.Desktop.Services"
             xmlns:mga="using:MGA.Api"
             x:Class="MGA.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <DockPanel>

    <!-- ================================================================
         Fixed heading
         ================================================================ -->
    <Border DockPanel.Dock="Top" Padding="32,32,32,0">
      <TextBlock Text="Settings" Classes="heading"/>
    </Border>

    <!-- ================================================================
         Tab control
         ================================================================ -->
    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                Margin="32,16,32,32">

      <!-- Integrations -->
      <TabItem Header="Integrations">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Integrations}">
          <DockPanel>

            <!-- ── Header row ── -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Integrations" Classes="subheading"/>
                <Button Classes="ghost"
                        Content="↻ Reload"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Manage game-source integrations. Add, configure, and scan."
                         Classes="muted"/>
            </StackPanel>

            <!-- ── Loading spinner ── -->
            <Border DockPanel.Dock="Top"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,8"
                    IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- ── Scan progress bar ── -->
            <Border DockPanel.Dock="Top"
                    Classes="card"
                    Margin="0,0,0,12"
                    MaxWidth="560"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding IsScanning}">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding ScanStatus}"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                <ProgressBar IsIndeterminate="True" Height="4"/>
                <Button Classes="ghost"
                        Content="Cancel Scan"
                        Command="{Binding CancelScanCommand}"
                        HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>

            <!-- ── Add / Edit integration form ── -->
            <Border DockPanel.Dock="Top"
                    Classes="card"
                    Margin="0,0,0,12"
                    MaxWidth="560"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding IsAddingIntegration}">
              <StackPanel Spacing="12">

                <!-- Step 1: Plugin selection (no plugin chosen yet) -->
                <StackPanel Spacing="10"
                            IsVisible="{Binding SelectedPlugin, Converter={x:Static ObjectConverters.IsNull}}">

                  <TextBlock Text="Step 1 — Choose a plugin:"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                  <ItemsControl ItemsSource="{Binding AvailablePlugins}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="settingsVm:PluginRowModel">
                        <Border Classes="card"
                                Margin="0,0,0,6">
                          <Grid ColumnDefinitions="*,Auto">

                            <!-- Plugin info -->
                            <StackPanel Grid.Column="0" Spacing="4">
                              <TextBlock Text="{Binding PluginId}"
                                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                              <TextBlock Text="{Binding ProvidesText}"
                                         Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                            </StackPanel>

                            <!-- Select button -->
                            <Button Grid.Column="1"
                                    Classes="ghost"
                                    Content="Select →"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).SelectPluginCommand}"
                                    CommandParameter="{Binding}"/>

                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Cancel -->
                  <Button Classes="ghost"
                          Content="Cancel"
                          Command="{Binding CancelAddCommand}"
                          HorizontalAlignment="Left"/>

                </StackPanel>

                <!-- Step 2: Configure (plugin chosen) -->
                <StackPanel Spacing="12"
                            IsVisible="{Binding SelectedPlugin, Converter={x:Static ObjectConverters.IsNotNull}}">

                  <!-- Back button -->
                  <Button Classes="ghost"
                          Content="← Back"
                          Command="{Binding BackToPluginSelectionCommand}"
                          HorizontalAlignment="Left"
                          IsVisible="{Binding EditingIntegration, Converter={x:Static ObjectConverters.IsNull}}"/>

                  <TextBlock Text="Step 2 — Configure integration:"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             IsVisible="{Binding EditingIntegration, Converter={x:Static ObjectConverters.IsNull}}"/>

                  <TextBlock Text="Edit integration:"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             IsVisible="{Binding EditingIntegration, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                  <!-- Label field -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Label" Classes="muted"/>
                    <TextBox Classes="mga"
                             PlaceholderText="My Steam Library"
                             Text="{Binding NewIntegrationLabel}"
                             MaxWidth="400"
                             HorizontalAlignment="Left"/>
                  </StackPanel>

                  <!-- Integration type -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Type" Classes="muted"/>
                    <ComboBox SelectedItem="{Binding NewIntegrationType}"
                              MinWidth="160"
                              HorizontalAlignment="Left">
                      <x:String>source</x:String>
                      <x:String>metadata</x:String>
                    </ComboBox>
                  </StackPanel>

                  <!-- Dynamic config fields -->
                  <ItemsControl ItemsSource="{Binding ConfigFields}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="settingsVm:ConfigFieldModel">
                        <StackPanel Spacing="4" Margin="0,0,0,10">

                          <!-- Field label + required indicator -->
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Label}"
                                       Classes="muted"/>
                            <TextBlock Text="*"
                                       Foreground="{DynamicResource MgaDangerBrush}"
                                       IsVisible="{Binding IsRequired}"/>
                          </StackPanel>

                          <!-- Optional description -->
                          <TextBlock Text="{Binding Description}"
                                     Classes="muted"
                                     FontSize="{DynamicResource MgaFontSizeXs}"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                          <!-- Boolean field (CheckBox) -->
                          <CheckBox IsChecked="{Binding BoolValue}"
                                    Content="{Binding Label}"
                                    IsVisible="{Binding IsBoolean}"
                                    HorizontalAlignment="Left"/>

                          <!-- Text / Number field (plain, non-secret) -->
                          <TextBox Classes="mga"
                                   Text="{Binding StringValue}"
                                   MaxWidth="400"
                                   HorizontalAlignment="Left"
                                   IsVisible="{Binding IsTextNotSecret}"/>

                          <!-- Folder-picker field: text input + Browse button -->
                          <Grid ColumnDefinitions="*,Auto"
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding IsFolderPicker}">
                            <TextBox Grid.Column="0"
                                     Classes="mga"
                                     Text="{Binding StringValue}"
                                     PlaceholderText="/path/to/folder"
                                     HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1"
                                    Classes="ghost"
                                    Content="📁 Browse…"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).OpenFolderBrowserCommand}"
                                    CommandParameter="{Binding}"/>
                          </Grid>

                          <!-- Secret field row: masked TextBox + show/hide toggle -->
                          <Grid ColumnDefinitions="*,Auto"
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding IsSecret}">

                            <!-- Masked input (shown when IsHidden = true) -->
                            <TextBox Grid.Column="0"
                                     Classes="mga"
                                     Text="{Binding StringValue}"
                                     PasswordChar="•"
                                     HorizontalAlignment="Stretch"
                                     IsVisible="{Binding IsHidden}"/>

                            <!-- Plain-text input (shown when !IsHidden) -->
                            <TextBox Grid.Column="0"
                                     Classes="mga"
                                     Text="{Binding StringValue}"
                                     HorizontalAlignment="Stretch"
                                     IsVisible="{Binding !IsHidden}"/>

                            <!-- Show/hide toggle button -->
                            <Button Grid.Column="1"
                                    Classes="ghost"
                                    Content="Show"
                                    Command="{Binding ToggleShowValueCommand}"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsHidden}"/>

                            <Button Grid.Column="1"
                                    Classes="ghost"
                                    Content="Hide"
                                    Command="{Binding ToggleShowValueCommand}"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding !IsHidden}"/>

                          </Grid>

                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Inline folder browser (opens when user clicks 📁 Browse… on a path field) -->
                  <Border Classes="card"
                          Padding="12"
                          IsVisible="{Binding IsFolderBrowserOpen}">
                    <StackPanel Spacing="8">

                      <TextBlock Text="Choose a folder:"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                      <!-- Navigation: Up button + current path -->
                      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="ghost"
                                Content="⬆ Up"
                                Command="{Binding BrowseFolderUpCommand}"
                                IsEnabled="{Binding FolderBrowserCurrentPath,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="{Binding FolderBrowserCurrentPath}"
                                   Classes="muted"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>

                      <!-- Loading indicator -->
                      <Border HorizontalAlignment="Left"
                              IsVisible="{Binding IsFolderBrowserLoading}">
                        <controls:LoadingSpinner Width="20" Height="20"/>
                      </Border>

                      <!-- Directory list -->
                      <ScrollViewer MaxHeight="180"
                                    IsVisible="{Binding !IsFolderBrowserLoading}">
                        <ItemsControl ItemsSource="{Binding FolderBrowserEntries}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="settingsVm:FolderBrowserEntry">
                              <Button Classes="ghost"
                                      HorizontalAlignment="Left"
                                      Margin="0,1"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).BrowseFolderEntryCommand}"
                                      CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>

                      <!-- Confirm + Cancel -->
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="primary"
                                Content="Select This Folder"
                                Command="{Binding SelectFolderPathCommand}"
                                IsEnabled="{Binding FolderBrowserCurrentPath,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <Button Classes="ghost"
                                Content="Cancel"
                                Command="{Binding CloseFolderBrowserCommand}"/>
                      </StackPanel>

                    </StackPanel>
                  </Border>

                  <!-- Save / Cancel buttons -->
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary"
                            Content="Save"
                            Command="{Binding SaveIntegrationCommand}"
                            IsEnabled="{Binding !IsSaving}"/>
                    <Button Classes="ghost"
                            Content="Cancel"
                            Command="{Binding CancelAddCommand}"/>
                  </StackPanel>

                </StackPanel>

              </StackPanel>
            </Border>

            <!-- ── Integration list + action bar ── -->
            <DockPanel DockPanel.Dock="Top"
                       IsVisible="{Binding !IsAddingIntegration}">

              <!-- Action bar -->
              <StackPanel DockPanel.Dock="Top"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,0,0,12">
                <Button Classes="primary"
                        Content="+ Add Integration"
                        Command="{Binding AddIntegrationCommand}"/>
                <Button Classes="ghost"
                        Content="↻ Reload"
                        Command="{Binding ReloadCommand}"/>
                <Button Classes="ghost"
                        Content="⊳ Scan"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding !IsScanning}"/>
                <Button Classes="ghost"
                        Content="⬇ Import from Sync"
                        Command="{Binding ImportFromSyncCommand}"
                        ToolTip.Tip="Pull the latest remote sync snapshot and merge integrations into this device. New integrations will be marked 'Auth Required'."/>
              </StackPanel>

              <!-- Scrollable list -->
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Integrations}"
                              IsVisible="{Binding !IsLoading}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settingsVm:IntegrationRowViewModel">
                      <Border Classes="card"
                              Margin="0,0,0,8"
                              MaxWidth="640"
                              HorizontalAlignment="Left">
                        <StackPanel Spacing="0">

                          <!-- ── Main row: info + actions ── -->
                          <Grid ColumnDefinitions="*,Auto">

                            <!-- Label + status badges + plugin id + error -->
                            <StackPanel Grid.Column="0" Spacing="4">

                              <TextBlock Text="{Binding Label}"
                                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- Status badge -->
                                <Border CornerRadius="{DynamicResource MgaRadiusFull}"
                                        Padding="8,2"
                                        Background="{DynamicResource MgaAccentMutedBrush}">
                                  <TextBlock Text="{Binding Status}"
                                             FontSize="{DynamicResource MgaFontSizeXs}"
                                             Foreground="#FFFFFF"/>
                                </Border>

                                <!-- Auth Required badge (shown when NeedsReauth) -->
                                <Border CornerRadius="{DynamicResource MgaRadiusFull}"
                                        Padding="8,2"
                                        Background="Transparent"
                                        BorderBrush="#7D6015"
                                        BorderThickness="1"
                                        IsVisible="{Binding NeedsReauth}">
                                  <TextBlock Text="Auth Required"
                                             FontSize="{DynamicResource MgaFontSizeXs}"
                                             Foreground="#F59E0B"/>
                                </Border>

                                <TextBlock Text="{Binding PluginId}"
                                           Classes="muted"
                                           VerticalAlignment="Center"/>

                                <TextBlock Text="{Binding IntegrationType}"
                                           Classes="muted"
                                           VerticalAlignment="Center"
                                           FontSize="{DynamicResource MgaFontSizeXs}"/>
                              </StackPanel>

                              <!-- Error message -->
                              <TextBlock Text="{Binding Message}"
                                         Classes="muted"
                                         TextWrapping="Wrap"
                                         IsVisible="{Binding HasError}"
                                         Foreground="{DynamicResource MgaDangerBrush}"/>

                              <!-- Validate-files result panel -->
                              <Border IsVisible="{Binding HasValidateResult}"
                                      Margin="0,4,0,0">
                                <StackPanel Spacing="4">

                                  <!-- Summary line -->
                                  <TextBlock Text="{Binding ValidateResultText}"
                                             Classes="muted"
                                             FontSize="{DynamicResource MgaFontSizeXs}"/>

                                  <!-- Missing files list + remove button -->
                                  <StackPanel Spacing="4"
                                              IsVisible="{Binding MissingFiles.Count}">
                                    <ItemsControl ItemsSource="{Binding MissingFiles}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="mga:MissingFileEntry">
                                          <TextBlock Text="{Binding Title}"
                                                     Classes="muted"
                                                     FontSize="{DynamicResource MgaFontSizeXs}"
                                                     TextTrimming="CharacterEllipsis"
                                                     ToolTip.Tip="{Binding Path}"/>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Classes="danger"
                                            Content="Remove Stale Records"
                                            FontSize="{DynamicResource MgaFontSizeXs}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).RemoveMissingFilesCommand}"
                                            CommandParameter="{Binding}"/>
                                  </StackPanel>

                                </StackPanel>
                              </Border>

                            </StackPanel>

                            <!-- Row action buttons -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,0">

                              <Button Classes="ghost"
                                      Content="Edit"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).EditIntegrationCommand}"
                                      CommandParameter="{Binding}"/>

                              <Button Classes="ghost"
                                      Content="↻ Refresh"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).RefreshIntegrationCommand}"
                                      CommandParameter="{Binding IntegrationId}"/>

                              <!-- Validate files: spinner while in-flight, button otherwise -->
                              <Border VerticalAlignment="Center"
                                      IsVisible="{Binding IsValidating}">
                                <controls:LoadingSpinner Width="18" Height="18"/>
                              </Border>
                              <Button Classes="ghost"
                                      Content="✔ Validate Files"
                                      IsVisible="{Binding !IsValidating}"
                                      ToolTip.Tip="Check whether the game files linked to this integration still exist on disk."
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).ValidateFilesCommand}"
                                      CommandParameter="{Binding}"/>

                              <!-- Games expand/collapse toggle -->
                              <Button Classes="ghost"
                                      Content="▶ Games"
                                      IsVisible="{Binding !IsGamesExpanded}"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).ToggleGamesCommand}"
                                      CommandParameter="{Binding}"/>
                              <Button Classes="ghost"
                                      Content="▼ Games"
                                      IsVisible="{Binding IsGamesExpanded}"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).ToggleGamesCommand}"
                                      CommandParameter="{Binding}"/>

                              <Button Classes="danger"
                                      Content="✕ Delete"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).DeleteIntegrationCommand}"
                                      CommandParameter="{Binding IntegrationId}"/>

                            </StackPanel>

                          </Grid>

                          <!-- ── Games expansion panel ── -->
                          <Border Margin="0,8,0,0"
                                  Background="{DynamicResource MgaElevatedBrush}"
                                  CornerRadius="{DynamicResource MgaRadiusSm}"
                                  Padding="8,6"
                                  IsVisible="{Binding IsGamesExpanded}">
                            <StackPanel Spacing="4">

                              <!-- Loading spinner -->
                              <Border HorizontalAlignment="Left"
                                      IsVisible="{Binding IsGamesLoading}">
                                <controls:LoadingSpinner Width="20" Height="20"/>
                              </Border>

                              <!-- Games list -->
                              <ItemsControl ItemsSource="{Binding Games}"
                                            IsVisible="{Binding !IsGamesLoading}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="settingsVm:IntegrationGameRowModel">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="0,2">
                                      <TextBlock Text="{Binding Title}"
                                                 FontSize="11"
                                                 VerticalAlignment="Center"/>
                                      <TextBlock Text="{Binding Platform}"
                                                 FontSize="10"
                                                 Classes="muted"
                                                 VerticalAlignment="Center"
                                                 IsVisible="{Binding Platform,
                                                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                            </StackPanel>
                          </Border>

                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

            </DockPanel>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Updates -->
      <TabItem Header="Updates">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Update}"
                x:DataType="settingsVm:UpdateTabViewModel">
          <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Spacing="4">
              <TextBlock Text="Updates" Classes="subheading"/>
              <TextBlock Text="Server version information and update management."
                         Classes="muted"/>
            </StackPanel>

            <!-- Loading spinner -->
            <Border HorizontalAlignment="Left" IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- Content (visible once loaded) -->
            <StackPanel Spacing="16" IsVisible="{Binding !IsLoading}">

              <!-- Server version card -->
              <Border Classes="card">
                <StackPanel Spacing="12">
                  <TextBlock Text="Server"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Version" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ServerVersion}"
                               Classes="muted" VerticalAlignment="Center"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Build date" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ServerBuildDate}"
                               Classes="muted" VerticalAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Update status card -->
              <Border Classes="card">
                <StackPanel Spacing="12">
                  <TextBlock Text="Update Status"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Current" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentVersion}"
                               Classes="muted" VerticalAlignment="Center"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Latest available" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding LatestVersion}"
                               Classes="muted" VerticalAlignment="Center"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                               Foreground="{DynamicResource MgaSuccessBrush}"
                               IsVisible="{Binding UpdateAvailable}"/>
                    <TextBlock Grid.Column="1" Text="{Binding LatestVersion}"
                               Classes="muted" VerticalAlignment="Center"
                               IsVisible="{Binding !UpdateAvailable}"/>
                  </Grid>

                  <!-- Status message (only shown when non-empty) -->
                  <TextBlock Text="{Binding StatusMessage}"
                             Classes="muted"
                             TextWrapping="Wrap"
                             IsVisible="{Binding HasStatusMessage}"/>
                </StackPanel>
              </Border>

              <!-- Actions -->
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="primary"
                        Content="Check for Updates"
                        Command="{Binding CheckForUpdatesCommand}"
                        IsEnabled="{Binding !IsChecking}"/>
                <Button Classes="ghost"
                        Content="↻ Reload"
                        Command="{Binding ReloadCommand}"/>
              </StackPanel>

            </StackPanel>
          </StackPanel>
        </Border>
      </TabItem>

      <!-- Profiles -->
      <TabItem Header="Profiles">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Profiles}">
          <DockPanel>

            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
              <TextBlock Text="Profiles" Classes="subheading"/>
              <TextBlock Text="User profiles configured on the connected server."
                         Classes="muted"/>
            </StackPanel>

            <Border DockPanel.Dock="Top"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"
                    IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <ItemsControl ItemsSource="{Binding Profiles}"
                          IsVisible="{Binding !IsLoading}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="mga:Profile">
                  <Border Classes="card"
                          Margin="0,0,0,8"
                          MaxWidth="480"
                          HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                 VerticalAlignment="Center"/>
                      <Border Background="{DynamicResource MgaAccentMutedBrush}"
                              CornerRadius="{DynamicResource MgaRadiusSm}"
                              Padding="8,3">
                        <TextBlock Text="{Binding Role}"
                                   FontSize="{DynamicResource MgaFontSizeXs}"
                                   Foreground="#FFFFFF"/>
                      </Border>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Plugins -->
      <TabItem Header="Plugins">
        <Border Padding="0,20,0,0" DataContext="{Binding Plugins}">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Plugins" Classes="subheading"/>
                <Button Classes="ghost" Content="↻ Reload" Command="{Binding ReloadCommand}" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Server-side plugins that provide game sources and enrichment." Classes="muted"/>
            </StackPanel>
            <Border DockPanel.Dock="Top" HorizontalAlignment="Left" IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>
            <ScrollViewer IsVisible="{Binding !IsLoading}">
              <ItemsControl ItemsSource="{Binding Plugins}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="settingsVm:PluginRowModel">
                    <Border Classes="card" Margin="0,0,0,8" MaxWidth="560" HorizontalAlignment="Left">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding PluginId}"
                                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                          <TextBlock Text="{Binding ProvidesText}" Classes="muted"
                                     FontSize="{DynamicResource MgaFontSizeXs}"/>
                          <!-- Capabilities (only shown when present) -->
                          <StackPanel Orientation="Horizontal" Spacing="4"
                                      IsVisible="{Binding HasCapabilities}">
                            <TextBlock Text="Capabilities:" Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"/>
                            <TextBlock Text="{Binding CapabilitiesText}" Classes="accent"
                                       FontSize="{DynamicResource MgaFontSizeXs}"/>
                          </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Version}" Classes="muted"
                                   VerticalAlignment="Top" Margin="12,0,0,0"
                                   FontSize="{DynamicResource MgaFontSizeXs}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </TabItem>

      <!-- Cache -->
      <TabItem Header="Cache">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Cache}"
                x:DataType="settingsVm:CacheTabViewModel">
          <DockPanel>

            <!-- ── Header ── -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Source Cache" Classes="subheading"/>
                <Button Classes="ghost" Content="↻ Reload"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Cached game source files used for fast library access."
                         Classes="muted"/>
            </StackPanel>

            <!-- ── Summary + actions bar ── -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="20"
                        Margin="0,0,0,12" IsVisible="{Binding !IsLoading}">
              <TextBlock VerticalAlignment="Center">
                <Run Text="{Binding EntryCount}"/>
                <Run Text=" entries ·"/>
                <Run Text="{Binding TotalSizeText}" FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
              </TextBlock>
              <Button Classes="danger"
                      Content="Clear All"
                      Command="{Binding ClearCacheCommand}"
                      IsEnabled="{Binding !IsClearing}"/>
            </StackPanel>

            <!-- ── Loading spinner ── -->
            <Border DockPanel.Dock="Top" HorizontalAlignment="Left"
                    Margin="0,8,0,8" IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- ── Entry list ── -->
            <ScrollViewer IsVisible="{Binding !IsLoading}">
              <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="settingsVm:CacheEntryRowViewModel">
                    <Border Classes="card" Margin="0,0,0,6"
                            MaxWidth="640" HorizontalAlignment="Left">
                      <Grid ColumnDefinitions="*,Auto,Auto">

                        <!-- Entry info -->
                        <StackPanel Grid.Column="0" Spacing="3">
                          <TextBlock Text="{Binding CanonicalTitle}"
                                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                     TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding IntegrationLabel}" Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"/>
                            <TextBlock Text="{Binding Status}" Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="muted" FontSize="{DynamicResource MgaFontSizeXs}">
                              <Run Text="{Binding FileCount}"/>
                              <Run Text=" file(s)"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SizeText}" Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"/>
                          </StackPanel>
                        </StackPanel>

                        <!-- Prepare spinner (visible while preparing) -->
                        <Border Grid.Column="1" Margin="8,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsPreparing}">
                          <controls:LoadingSpinner Width="16" Height="16"/>
                        </Border>

                        <!-- Prepare button -->
                        <Button Grid.Column="2"
                                Classes="ghost"
                                Content="Prepare"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding !IsPreparing}"
                                IsVisible="{Binding !IsPreparing}"
                                Command="{Binding $parent[ItemsControl].((settingsVm:CacheTabViewModel)DataContext).PrepareCacheCommand}"
                                CommandParameter="{Binding}"/>

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Duplicates -->
      <TabItem Header="Duplicates">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Duplicates}"
                x:DataType="settingsVm:DuplicatesTabViewModel">
          <DockPanel>

            <!-- ── Header ── -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Duplicates" Classes="subheading"/>
                <Button Classes="ghost" Content="↻ Reload"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Classes="muted">
                <Run Text="{Binding GroupCount}"/>
                <Run Text=" duplicate group(s) ·"/>
                <Run Text="{Binding Mode}"/>
                <Run Text=" mode"/>
              </TextBlock>
            </StackPanel>

            <!-- ── Mode toggle — show opposing mode as the action label ── -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                        Spacing="8" Margin="0,0,0,12"
                        IsVisible="{Binding !IsLoading}">
              <!-- In loose mode: offer switching to strict -->
              <Button Classes="ghost"
                      Content="Switch to Strict"
                      Command="{Binding ToggleModeCommand}"
                      IsVisible="{Binding IsLooseMode}"/>
              <!-- In strict mode: offer switching to loose -->
              <Button Classes="ghost"
                      Content="Switch to Loose"
                      Command="{Binding ToggleModeCommand}"
                      IsVisible="{Binding IsStrictMode}"/>
            </StackPanel>

            <!-- ── Loading spinner ── -->
            <Border DockPanel.Dock="Top" HorizontalAlignment="Left" IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- ── Group list ── -->
            <ScrollViewer IsVisible="{Binding !IsLoading}">
              <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="settingsVm:DuplicateGroupRowViewModel">
                    <StackPanel Margin="0,0,0,8">

                      <!-- Group header row -->
                      <Border Classes="card" MaxWidth="640" HorizontalAlignment="Left">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding RepresentativeTitle}"
                                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding SourceCountText}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                              <TextBlock Text="{Binding TotalSizeText}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                            </StackPanel>
                          </StackPanel>

                          <!-- Merging spinner -->
                          <Border Grid.Column="1" Margin="8,0"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsMerging}">
                            <controls:LoadingSpinner Width="18" Height="18"/>
                          </Border>

                          <!-- Expand toggle -->
                          <Button Grid.Column="2"
                                  Classes="ghost"
                                  Content="▶ Sources"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding !IsExpanded}"
                                  IsEnabled="{Binding !IsMerging}"
                                  Command="{Binding $parent[ItemsControl].((settingsVm:DuplicatesTabViewModel)DataContext).ToggleGroupCommand}"
                                  CommandParameter="{Binding}"/>
                          <Button Grid.Column="2"
                                  Classes="ghost"
                                  Content="▼ Sources"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsExpanded}"
                                  IsEnabled="{Binding !IsMerging}"
                                  Command="{Binding $parent[ItemsControl].((settingsVm:DuplicatesTabViewModel)DataContext).ToggleGroupCommand}"
                                  CommandParameter="{Binding}"/>
                          <Grid Grid.Column="3"/>
                        </Grid>
                      </Border>

                      <!-- Expanded source breakdown -->
                      <Border IsVisible="{Binding IsExpanded}"
                              Margin="16,0,0,0"
                              MaxWidth="624"
                              HorizontalAlignment="Left">
                        <ItemsControl ItemsSource="{Binding Sources}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="settingsVm:DuplicateSourceRowViewModel">
                              <StackPanel Margin="0,0,0,4">

                                <!-- Source info row -->
                                <Border Classes="card" Padding="10,8">
                                  <Grid ColumnDefinitions="*,Auto">

                                    <!-- Source info -->
                                    <StackPanel Grid.Column="0" Spacing="2">
                                      <TextBlock Text="{Binding CanonicalTitle}"
                                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding IntegrationLabel}" Classes="muted"
                                                   FontSize="{DynamicResource MgaFontSizeXs}"/>
                                        <TextBlock Text="{Binding Platform}" Classes="muted"
                                                   FontSize="{DynamicResource MgaFontSizeXs}"/>
                                        <TextBlock Text="{Binding Kind}" Classes="muted"
                                                   FontSize="{DynamicResource MgaFontSizeXs}"/>
                                      </StackPanel>
                                      <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Classes="muted" FontSize="{DynamicResource MgaFontSizeXs}">
                                          <Run Text="{Binding FileCount}"/>
                                          <Run Text=" file(s)"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding SizeText}" Classes="muted"
                                                   FontSize="{DynamicResource MgaFontSizeXs}"/>
                                        <Border Background="{DynamicResource MgaAccentMutedBrush}"
                                                CornerRadius="{DynamicResource MgaRadiusSm}"
                                                Padding="6,2"
                                                IsVisible="{Binding Cached}">
                                          <TextBlock Text="cached"
                                                     FontSize="{DynamicResource MgaFontSizeXs}"
                                                     Foreground="#FFFFFF"/>
                                        </Border>
                                      </StackPanel>
                                    </StackPanel>

                                    <!-- Merge-into button -->
                                    <Button Grid.Column="1"
                                            Classes="ghost"
                                            Content="⊕ Merge into this"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"
                                            IsVisible="{Binding !IsMergePending}"
                                            Command="{Binding $parent[ItemsControl].((settingsVm:DuplicatesTabViewModel)DataContext).RequestMergeIntoCommand}"
                                            CommandParameter="{Binding}"/>

                                  </Grid>
                                </Border>

                                <!-- Inline merge confirm strip -->
                                <Border IsVisible="{Binding IsMergePending}"
                                        Classes="card"
                                        Background="{DynamicResource MgaElevatedBrush}"
                                        Padding="10,8"
                                        Margin="0,2,0,0">
                                  <StackPanel Spacing="6">
                                    <TextBlock Text="Merge all other sources in this group into this canonical?"
                                               Classes="muted" TextWrapping="Wrap"
                                               FontSize="{DynamicResource MgaFontSizeXs}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <Button Classes="primary"
                                              Content="Confirm Merge"
                                              Command="{Binding $parent[ItemsControl].((settingsVm:DuplicatesTabViewModel)DataContext).ConfirmMergeIntoCommand}"
                                              CommandParameter="{Binding}"/>
                                      <Button Classes="ghost"
                                              Content="Cancel"
                                              Command="{Binding $parent[ItemsControl].((settingsVm:DuplicatesTabViewModel)DataContext).CancelMergeIntoCommand}"
                                              CommandParameter="{Binding}"/>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                              </StackPanel>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Border>

                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Appearance — theme switcher only -->
      <TabItem Header="Appearance">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Appearance}"
                x:DataType="settingsVm:AppearanceTabViewModel">
          <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">

            <!-- Theme selector — wrapped in a card for visual containment -->
            <Border Classes="card">
              <StackPanel Spacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Text="Theme"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                  <TextBlock Text="Choose between dark (Midnight) and light (Daylight) modes."
                             Classes="muted"/>
                </StackPanel>
                <ComboBox ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding SelectedTheme}"
                          MinWidth="200"
                          HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>
      </TabItem>

      <!-- Connection — server management -->
      <TabItem Header="Connection">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Connection}"
                x:DataType="settingsVm:ConnectionTabViewModel">
          <StackPanel Spacing="20" MaxWidth="520" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Spacing="4">
              <TextBlock Text="Connection" Classes="subheading"/>
              <TextBlock Text="Manage server connections. Switch between servers or add a new one."
                         Classes="muted"/>
            </StackPanel>

            <!-- Active server — accent-border card for prominent status display -->
            <Border Background="{DynamicResource MgaElevatedBrush}"
                    BorderBrush="{DynamicResource MgaAccentBrush}"
                    BorderThickness="3,0,0,0"
                    CornerRadius="{DynamicResource MgaRadiusSm}"
                    Padding="16,14"
                    IsVisible="{Binding ActiveServerUrl,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <StackPanel Spacing="4">
                <TextBlock Text="ACTIVE SERVER"
                           Classes="muted"
                           FontSize="10"
                           LetterSpacing="1.5"/>
                <TextBlock Text="{Binding ActiveServerUrl}"
                           Classes="accent"
                           FontSize="15"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
              </StackPanel>
            </Border>

            <!-- Saved servers list — each row in a card -->
            <StackPanel Spacing="10">
              <TextBlock Text="Saved Servers"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
              <ItemsControl ItemsSource="{Binding KnownServers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="services:ServerProfile">
                    <Border Classes="card"
                            Margin="0,0,0,6">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}"
                                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding Url}"
                                     Classes="muted"
                                     FontSize="{DynamicResource MgaFontSizeXs}"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="ghost"
                                Content="Switch"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Command="{Binding $parent[ItemsControl].((settingsVm:ConnectionTabViewModel)DataContext).SwitchToServerCommand}"
                                CommandParameter="{Binding}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Add server — contained card form -->
            <Border Classes="card">
              <StackPanel Spacing="12">
                <TextBlock Text="Add Server"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                <TextBox Classes="mga"
                         PlaceholderText="Name (optional)"
                         Text="{Binding NewServerName}"/>
                <TextBox Classes="mga"
                         PlaceholderText="http://hostname:8900"
                         Text="{Binding NewServerUrl}"/>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Classes="primary"
                          Content="Connect"
                          Command="{Binding AddServerCommand}"
                          IsEnabled="{Binding !IsConnecting}"/>
                  <Border IsVisible="{Binding IsConnecting}" VerticalAlignment="Center">
                    <controls:LoadingSpinner Width="20" Height="20"/>
                  </Border>
                </StackPanel>
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>
      </TabItem>

      <!-- Undetected Games -->
      <TabItem Header="Undetected">
        <Border Padding="0,20,0,0"
                DataContext="{Binding UndetectedGames}"
                x:DataType="settingsVm:UndetectedGamesTabViewModel">
          <DockPanel>

            <!-- ── Header row ── -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Undetected Games" Classes="subheading"/>
                <Button Classes="ghost"
                        Content="↻ Reload"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Review game files that could not be auto-identified. Classify, search, or delete."
                         Classes="muted"/>
            </StackPanel>

            <!-- ── Action bar ── -->
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,0,0,8">
              <Button Classes="ghost"
                      Content="← Active"
                      Command="{Binding ToggleScopeCommand}"
                      IsVisible="{Binding ShowArchive}"/>
              <Button Classes="ghost"
                      Content="Archive →"
                      Command="{Binding ToggleScopeCommand}"
                      IsVisible="{Binding !ShowArchive}"/>
              <Button Classes="ghost"
                      Content="⊳ Re-detect All"
                      Command="{Binding RedetectAllCommand}"
                      IsEnabled="{Binding !IsRedetecting}"/>
              <Border HorizontalAlignment="Left" IsVisible="{Binding IsRedetecting}" VerticalAlignment="Center">
                <controls:LoadingSpinner Width="20" Height="20"/>
              </Border>
            </StackPanel>

            <!-- ── List filter ── -->
            <TextBox DockPanel.Dock="Top"
                     Classes="mga"
                     PlaceholderText="Filter by title, platform, integration…"
                     Text="{Binding ListFilter}"
                     Margin="0,0,0,8"
                     MaxWidth="400"
                     HorizontalAlignment="Left"
                     IsVisible="{Binding !IsLoading}"/>

            <!-- ── Status message ── -->
            <Border DockPanel.Dock="Top"
                    Classes="card"
                    Margin="0,0,0,8"
                    IsVisible="{Binding HasStatusMessage}">
              <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
            </Border>

            <!-- ── Loading spinner ── -->
            <Border DockPanel.Dock="Top"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,8"
                    IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- ── Two-column layout: list + detail panel ── -->
            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsLoading}">

              <!-- Left: candidate list -->
              <ScrollViewer Grid.Column="0" Margin="0,0,12,0">
                <ItemsControl ItemsSource="{Binding Candidates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settingsVm:ReviewCandidateRowViewModel">
                      <Border Classes="card"
                              Margin="0,0,0,6"
                              MaxWidth="480"
                              HorizontalAlignment="Left">
                        <Grid ColumnDefinitions="*,Auto">

                          <!-- Candidate info -->
                          <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding Platform}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                              <TextBlock Text="{Binding Kind}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                              <TextBlock Text="{Binding IntegrationLabel}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Classes="muted" FontSize="{DynamicResource MgaFontSizeXs}">
                                <Run Text="{Binding FileCount}"/>
                                <Run Text=" file(s)"/>
                              </TextBlock>
                              <TextBlock Classes="muted" FontSize="{DynamicResource MgaFontSizeXs}"
                                         IsVisible="{Binding HasResolverMatches}">
                                <Run Text="{Binding ResolverMatches}"/>
                                <Run Text=" match(es)"/>
                              </TextBlock>
                              <TextBlock Text="{Binding ReasonsText}" Classes="muted"
                                         FontSize="{DynamicResource MgaFontSizeXs}"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                          </StackPanel>

                          <!-- Select button -->
                          <Button Grid.Column="1"
                                  Classes="ghost"
                                  Content="Review →"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Command="{Binding $parent[ItemsControl].((settingsVm:UndetectedGamesTabViewModel)DataContext).SelectCandidateCommand}"
                                  CommandParameter="{Binding}"/>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <!-- Right: detail / action panel (shown when candidate selected) -->
              <ScrollViewer Grid.Column="1"
                            Width="340"
                            MaxHeight="700"
                            VerticalScrollBarVisibility="Auto"
                            IsVisible="{Binding SelectedCandidate, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Border Classes="card" VerticalAlignment="Top">
                  <StackPanel Spacing="12">

                    <!-- Title + reasons -->
                    <TextBlock Text="{Binding SelectedCandidate.Title}"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedCandidate.ReasonsText}"
                               Classes="muted"
                               FontSize="{DynamicResource MgaFontSizeXs}"
                               TextWrapping="Wrap"/>

                    <!-- Detail loading spinner -->
                    <Border HorizontalAlignment="Left" IsVisible="{Binding IsLoadingDetail}">
                      <controls:LoadingSpinner Width="20" Height="20"/>
                    </Border>

                    <!-- File inventory (lazy-loaded) -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasFiles}">
                      <TextBlock Text="Files" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      <ItemsControl ItemsSource="{Binding SelectedFiles}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="settingsVm:CandidateFileRowViewModel">
                            <StackPanel Margin="0,0,0,4">
                              <TextBlock Text="{Binding FileName}"
                                         FontSize="{DynamicResource MgaFontSizeXs}"
                                         TextTrimming="CharacterEllipsis"
                                         ToolTip.Tip="{Binding Path}"/>
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Role}" Classes="muted"
                                           FontSize="{DynamicResource MgaFontSizeXs}"/>
                                <TextBlock Text="{Binding SizeText}" Classes="muted"
                                           FontSize="{DynamicResource MgaFontSizeXs}"/>
                              </StackPanel>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <!-- Resolver matches (lazy-loaded) -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasMatches}">
                      <TextBlock Text="Resolver Suggestions" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      <ItemsControl ItemsSource="{Binding SelectedMatches}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="settingsVm:CandidateMatchRowViewModel">
                            <Border Classes="card" Margin="0,0,0,4" Padding="6">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="{DynamicResource MgaFontSizeXs}"
                                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding Provider}" Classes="muted"
                                             FontSize="{DynamicResource MgaFontSizeXs}"/>
                                  <TextBlock Text="{Binding Platform}" Classes="muted"
                                             FontSize="{DynamicResource MgaFontSizeXs}"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <!-- Classification actions -->
                    <StackPanel Spacing="6">
                      <TextBlock Text="Classify" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      <WrapPanel>
                        <Button Classes="ghost"
                                Content="Not a Game"
                                Margin="0,0,4,4"
                                Command="{Binding MarkNotGameCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                        <Button Classes="ghost"
                                Content="DLC / Add-on"
                                Margin="0,0,4,4"
                                Command="{Binding MarkDlcCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                        <Button Classes="ghost"
                                Content="Base Game"
                                Margin="0,0,4,4"
                                Command="{Binding MarkBaseGameCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                      </WrapPanel>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Classes="ghost"
                                Content="↺ Re-detect"
                                Command="{Binding RedetectOneCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                        <Button Classes="ghost"
                                Content="Restore"
                                IsVisible="{Binding SelectedCandidate.IsArchived}"
                                Command="{Binding UnarchiveCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                        <Button Classes="danger"
                                Content="Delete Files"
                                Command="{Binding DeleteFilesCommand}"
                                CommandParameter="{Binding SelectedCandidate}"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Metadata search -->
                    <StackPanel Spacing="6">
                      <TextBlock Text="Find Metadata" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      <TextBox Classes="mga"
                               PlaceholderText="Search query…"
                               Text="{Binding SearchQuery}"/>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Classes="primary"
                                Content="Search"
                                Command="{Binding SearchCommand}"
                                IsEnabled="{Binding !IsSearching}"/>
                        <Border IsVisible="{Binding IsSearching}" VerticalAlignment="Center">
                          <controls:LoadingSpinner Width="20" Height="20"/>
                        </Border>
                      </StackPanel>
                    </StackPanel>

                    <!-- Search results -->
                    <ItemsControl ItemsSource="{Binding SearchResults}"
                                  IsVisible="{Binding SearchResults.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="settingsVm:ReviewSearchResultRowViewModel">
                          <Border Classes="card"
                                  Margin="0,0,0,4"
                                  Padding="8">
                            <Grid ColumnDefinitions="*,Auto">
                              <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding ProviderLabel}" Classes="muted"
                                             FontSize="{DynamicResource MgaFontSizeXs}"/>
                                  <TextBlock Text="{Binding Platform}" Classes="muted"
                                             FontSize="{DynamicResource MgaFontSizeXs}"/>
                                </StackPanel>
                              </StackPanel>
                              <Button Grid.Column="1"
                                      Classes="primary"
                                      Content="Apply"
                                      VerticalAlignment="Center"
                                      Margin="6,0,0,0"
                                      IsEnabled="{Binding $parent[ItemsControl].((settingsVm:UndetectedGamesTabViewModel)DataContext).IsApplying, Converter={x:Static BoolConverters.Not}}"
                                      Command="{Binding $parent[ItemsControl].((settingsVm:UndetectedGamesTabViewModel)DataContext).ApplyMatchCommand}"
                                      CommandParameter="{Binding}"/>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                  </StackPanel>
                </Border>
              </ScrollViewer>

            </Grid>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Emulators -->
      <TabItem Header="Emulators">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Emulators}"
                x:DataType="settingsVm:EmulatorsTabViewModel">
          <DockPanel>

            <!-- ── Header ── -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
              <TextBlock Text="Emulators" Classes="subheading"/>
              <TextBlock Text="Configure local emulator executables for running ROM-based games."
                         Classes="muted"/>
            </StackPanel>

            <!-- ── Action bar ── -->
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,0,0,12"
                        IsVisible="{Binding !IsEditing}">
              <Button Classes="primary"
                      Content="+ Add Emulator"
                      Command="{Binding AddEmulatorCommand}"/>
            </StackPanel>

            <!-- ── Edit panel ── -->
            <Border DockPanel.Dock="Top"
                    Classes="card"
                    Margin="0,0,0,12"
                    MaxWidth="520"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding IsEditing}">
              <StackPanel Spacing="12">

                <TextBlock Text="Add Emulator"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                           IsVisible="{Binding EditingId, Converter={x:Static ObjectConverters.IsNull}}"/>
                <TextBlock Text="Edit Emulator"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                           IsVisible="{Binding EditingId, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <StackPanel Spacing="4">
                  <TextBlock Text="Name *" Classes="muted"/>
                  <TextBox Classes="mga"
                           PlaceholderText="e.g. RetroArch"
                           Text="{Binding EditName}"
                           MaxWidth="400"
                           HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Executable Path *" Classes="muted"/>
                  <TextBox Classes="mga"
                           PlaceholderText="C:\RetroArch\retroarch.exe"
                           Text="{Binding EditExecutablePath}"
                           MaxWidth="400"
                           HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Platforms (comma-separated)" Classes="muted"/>
                  <TextBox Classes="mga"
                           PlaceholderText="nes,snes,gba"
                           Text="{Binding EditPlatforms}"
                           MaxWidth="400"
                           HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Arguments Template" Classes="muted"/>
                  <TextBox Classes="mga"
                           PlaceholderText="{}{rom}"
                           Text="{Binding EditArgsTemplate}"
                           MaxWidth="400"
                           HorizontalAlignment="Left"/>
                  <TextBlock Text="Use {{rom}} as a placeholder for the ROM file path."
                             Classes="muted"
                             FontSize="{DynamicResource MgaFontSizeXs}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="primary"
                          Content="Save"
                          Command="{Binding SaveEmulatorCommand}"/>
                  <Button Classes="ghost"
                          Content="Cancel"
                          Command="{Binding CancelEditCommand}"/>
                </StackPanel>

              </StackPanel>
            </Border>

            <!-- ── Scrollable content: directories + BIOS + emulator list ── -->
            <ScrollViewer>
              <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left">

                <!-- ─ Storage Directories ──────────────────────────────────── -->
                <Border Classes="card">
                  <StackPanel Spacing="14">

                    <TextBlock Text="Storage Directories"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                    <!-- BIOS Directory row -->
                    <StackPanel Spacing="4">
                      <TextBlock Text="BIOS Directory" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"/>
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0"
                                 Classes="mga"
                                 Text="{Binding BiosDirectory}"
                                 IsReadOnly="True"
                                 FontSize="{DynamicResource MgaFontSizeXs}"/>
                        <Button Grid.Column="1"
                                Classes="ghost"
                                Content="Browse…"
                                Margin="6,0,0,0"
                                Command="{Binding BrowseBiosDirectoryCommand}"/>
                        <Button Grid.Column="2"
                                Classes="ghost"
                                Content="Open"
                                Margin="4,0,0,0"
                                Command="{Binding OpenBiosDirectoryCommand}"/>
                      </Grid>
                    </StackPanel>

                    <!-- Library Directory row -->
                    <StackPanel Spacing="4">
                      <TextBlock Text="Library Directory" Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"/>
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0"
                                 Classes="mga"
                                 Text="{Binding LibraryDirectory}"
                                 IsReadOnly="True"
                                 FontSize="{DynamicResource MgaFontSizeXs}"/>
                        <Button Grid.Column="1"
                                Classes="ghost"
                                Content="Browse…"
                                Margin="6,0,0,0"
                                Command="{Binding BrowseLibraryDirectoryCommand}"/>
                        <Button Grid.Column="2"
                                Classes="ghost"
                                Content="Open"
                                Margin="4,0,0,0"
                                Command="{Binding OpenLibraryDirectoryCommand}"/>
                      </Grid>
                    </StackPanel>

                  </StackPanel>
                </Border>

                <!-- ─ BIOS Status ───────────────────────────────────────────── -->
                <Border Classes="card">
                  <StackPanel Spacing="14">

                    <!-- Section header + Refresh button -->
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="BIOS Status"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                 VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center">
                        <Border IsVisible="{Binding IsBiosCheckInProgress}"
                                VerticalAlignment="Center">
                          <controls:LoadingSpinner Width="16" Height="16"/>
                        </Border>
                        <Button Classes="ghost"
                                Content="↺ Refresh"
                                IsEnabled="{Binding !IsBiosCheckInProgress}"
                                Command="{Binding RefreshBiosStatusCommand}"/>
                      </StackPanel>
                    </Grid>

                    <!-- Empty state — shown when no emulators have BIOS requirements -->
                    <TextBlock Text="No emulators with BIOS requirements detected. Install an emulator above and click Refresh."
                               Classes="muted"
                               TextWrapping="Wrap"
                               FontSize="{DynamicResource MgaFontSizeXs}"
                               IsVisible="{Binding !HasBiosStatusRows}"/>

                    <!-- Status rows -->
                    <ItemsControl ItemsSource="{Binding BiosStatusRows}"
                                  IsVisible="{Binding HasBiosStatusRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="settingsVm:BiosStatusRowViewModel">
                          <Border Padding="12,8"
                                  Margin="0,0,0,4"
                                  CornerRadius="6"
                                  Background="{DynamicResource MgaElevatedBrush}">
                            <Grid ColumnDefinitions="Auto,*">

                              <!-- Status icon -->
                              <TextBlock Grid.Column="0"
                                         Text="{Binding StatusIcon}"
                                         FontSize="18"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>

                              <!-- Emulator name · platform + detail text -->
                              <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                           FontSize="{DynamicResource MgaFontSizeSm}">
                                  <Run Text="{Binding EmulatorName}"/>
                                  <Run Text=" · "/>
                                  <Run Text="{Binding Platform}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding StatusText}"
                                           Classes="muted"
                                           FontSize="{DynamicResource MgaFontSizeXs}"
                                           TextWrapping="Wrap"/>
                              </StackPanel>

                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Drag-and-drop BIOS file zone -->
                    <Border x:Name="BiosDropZone"
                            Background="{DynamicResource MgaSurfaceBrush}"
                            BorderBrush="{DynamicResource MgaBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="16,20"
                            MinHeight="80"
                            HorizontalAlignment="Stretch">
                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Spacing="6">
                        <TextBlock Text="Drop a BIOS file here to identify and install it"
                                   Classes="muted"
                                   FontSize="{DynamicResource MgaFontSizeXs}"
                                   HorizontalAlignment="Center"/>
                        <!-- Drop result feedback -->
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="{DynamicResource MgaFontSizeXs}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding BiosDropMessage,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock.Text>
                            <Binding Path="BiosDropMessage"/>
                          </TextBlock.Text>
                        </TextBlock>
                      </StackPanel>
                    </Border>

                  </StackPanel>
                </Border>

                <!-- ─ Installed Emulators ────────────────────────────────────── -->
                <TextBlock Text="Installed Emulators"
                           FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

                <ItemsControl ItemsSource="{Binding Emulators}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settingsVm:EmulatorRowViewModel">
                      <Border Classes="card"
                              Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto">

                          <!-- Emulator info -->
                          <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                            <TextBlock Text="{Binding ExecutablePath}"
                                       Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Classes="muted"
                                       FontSize="{DynamicResource MgaFontSizeXs}"
                                       IsVisible="{Binding Platforms,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <Run Text="Platforms: "/>
                              <Run Text="{Binding Platforms}"/>
                            </TextBlock>
                          </StackPanel>

                          <!-- Row action buttons -->
                          <StackPanel Grid.Column="1"
                                      Orientation="Horizontal"
                                      Spacing="6"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0">
                            <!-- Test spinner while running -->
                            <Border VerticalAlignment="Center" IsVisible="{Binding IsTesting}">
                              <controls:LoadingSpinner Width="18" Height="18"/>
                            </Border>
                            <Button Classes="ghost"
                                    Content="Test"
                                    IsVisible="{Binding !IsTesting}"
                                    Command="{Binding $parent[ItemsControl].((settingsVm:EmulatorsTabViewModel)DataContext).TestEmulatorCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="ghost"
                                    Content="Edit"
                                    IsEnabled="{Binding !IsTesting}"
                                    Command="{Binding $parent[ItemsControl].((settingsVm:EmulatorsTabViewModel)DataContext).EditEmulatorCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Classes="danger"
                                    Content="✕ Delete"
                                    IsEnabled="{Binding !IsTesting}"
                                    Command="{Binding $parent[ItemsControl].((settingsVm:EmulatorsTabViewModel)DataContext).DeleteEmulatorCommand}"
                                    CommandParameter="{Binding}"/>
                          </StackPanel>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>

          </DockPanel>
        </Border>
      </TabItem>

    </TabControl>
  </DockPanel>
</UserControl>
