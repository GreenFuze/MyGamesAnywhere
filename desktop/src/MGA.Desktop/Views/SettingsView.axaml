<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels.Settings"
             xmlns:settingsVm="using:MGA.Desktop.ViewModels.Settings"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:services="using:MGA.Desktop.Services"
             x:Class="MGA.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <DockPanel>

    <!-- ================================================================
         Fixed heading
         ================================================================ -->
    <Border DockPanel.Dock="Top" Padding="32,32,32,0">
      <TextBlock Text="Settings" Classes="heading"/>
    </Border>

    <!-- ================================================================
         Tab control
         ================================================================ -->
    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                Margin="32,16,32,32">

      <!-- Integrations -->
      <TabItem Header="Integrations">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Integrations}">
          <DockPanel>

            <!-- Header row -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Integrations" Classes="subheading"/>
                <Button Classes="ghost"
                        Content="↻ Reload"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Status of all configured game-source integrations."
                         Classes="muted"/>
            </StackPanel>

            <!-- Loading spinner -->
            <Border DockPanel.Dock="Top"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"
                    IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- Integration rows -->
            <ItemsControl ItemsSource="{Binding Integrations}"
                          IsVisible="{Binding !IsLoading}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settingsVm:IntegrationRowModel">
                  <Border Classes="card" Margin="0,0,0,8" MaxWidth="560" HorizontalAlignment="Left">
                    <Grid ColumnDefinitions="*,Auto">

                      <!-- Label + status -->
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding Label}"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <!-- Status badge -->
                          <Border CornerRadius="{DynamicResource MgaRadiusFull}"
                                  Padding="8,2">
                            <Border.Background>
                              <SolidColorBrush Color="{Binding Status,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty},
                                FallbackValue=#1e6faf}"/>
                            </Border.Background>
                            <TextBlock Text="{Binding Status}"
                                       FontSize="{DynamicResource MgaFontSizeXs}"
                                       Foreground="#FFFFFF"/>
                          </Border>
                          <TextBlock Text="{Binding PluginId}"
                                     Classes="muted"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Error message if present -->
                        <TextBlock Text="{Binding Message}"
                                   Classes="muted"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding HasError}"
                                   Foreground="{DynamicResource MgaDangerBrush}"/>
                      </StackPanel>

                      <!-- Refresh button -->
                      <Button Grid.Column="1"
                              Classes="ghost"
                              Content="↻ Refresh"
                              Command="{Binding $parent[ItemsControl].((settingsVm:IntegrationsTabViewModel)DataContext).RefreshIntegrationCommand}"
                              CommandParameter="{Binding IntegrationId}"
                              VerticalAlignment="Top"
                              Margin="12,0,0,0"/>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Updates -->
      <TabItem Header="Updates">
        <Border Padding="0,20,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Updates" Classes="subheading"/>
            <TextBlock Text="Check for server and plugin updates." Classes="muted"/>
            <TextBlock Text="Full implementation coming soon." Classes="muted"/>
          </StackPanel>
        </Border>
      </TabItem>

      <!-- Profiles -->
      <TabItem Header="Profiles">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Profiles}">
          <DockPanel>

            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
              <TextBlock Text="Profiles" Classes="subheading"/>
              <TextBlock Text="User profiles configured on the connected server."
                         Classes="muted"/>
            </StackPanel>

            <Border DockPanel.Dock="Top"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"
                    IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <ItemsControl ItemsSource="{Binding Profiles}"
                          IsVisible="{Binding !IsLoading}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settingsVm:ProfileRowModel">
                  <Border Classes="card"
                          Margin="0,0,0,8"
                          MaxWidth="480"
                          HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                                 VerticalAlignment="Center"/>
                      <Border Background="{DynamicResource MgaAccentMutedBrush}"
                              CornerRadius="{DynamicResource MgaRadiusSm}"
                              Padding="8,3">
                        <TextBlock Text="{Binding Role}"
                                   FontSize="{DynamicResource MgaFontSizeXs}"
                                   Foreground="#FFFFFF"/>
                      </Border>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </DockPanel>
        </Border>
      </TabItem>

      <!-- Plugins -->
      <TabItem Header="Plugins">
        <Border Padding="0,20,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Plugins" Classes="subheading"/>
            <TextBlock Text="Install, update, and remove server-side plugins." Classes="muted"/>
            <TextBlock Text="Full implementation coming soon." Classes="muted"/>
          </StackPanel>
        </Border>
      </TabItem>

      <!-- Cache -->
      <TabItem Header="Cache">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Cache}">
          <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Spacing="4">
              <TextBlock Text="Source Cache" Classes="subheading"/>
              <TextBlock Text="Cached game source files used for fast library access."
                         Classes="muted"/>
            </StackPanel>

            <!-- Loading spinner -->
            <Border HorizontalAlignment="Left" IsVisible="{Binding IsLoading}">
              <controls:LoadingSpinner Width="32" Height="32"/>
            </Border>

            <!-- Stats card -->
            <Border Classes="card" IsVisible="{Binding !IsLoading}">
              <StackPanel Spacing="12">

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Cached entries" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding EntryCount}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             VerticalAlignment="Center"/>
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Total size" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding TotalSizeText}"
                             FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                             VerticalAlignment="Center"/>
                </Grid>

              </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding !IsLoading}">
              <Button Classes="danger"
                      Content="Clear All Cache"
                      Command="{Binding ClearCacheCommand}"
                      IsEnabled="{Binding !IsClearing}"/>
              <Button Classes="ghost"
                      Content="↻ Reload"
                      Command="{Binding ReloadCommand}"/>
            </StackPanel>

          </StackPanel>
        </Border>
      </TabItem>

      <!-- Duplicates -->
      <TabItem Header="Duplicates">
        <Border Padding="0,20,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Duplicates" Classes="subheading"/>
            <TextBlock Text="Review and resolve duplicate game entries." Classes="muted"/>
            <TextBlock Text="Full implementation coming soon." Classes="muted"/>
          </StackPanel>
        </Border>
      </TabItem>

      <!-- Appearance — FUNCTIONAL: theme switcher -->
      <TabItem Header="Appearance">
        <Border Padding="0,20,0,0"
                DataContext="{Binding Appearance}">
          <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">

            <!-- Theme selector -->
            <StackPanel Spacing="8">
              <TextBlock Text="Theme"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
              <TextBlock Text="Choose between dark (Midnight) and light (Daylight) modes."
                         Classes="muted"/>
              <ComboBox ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding SelectedTheme}"
                        MinWidth="200"/>
            </StackPanel>

            <!-- Server management -->
            <StackPanel Spacing="8">
              <TextBlock Text="Connection"
                         FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>

              <!-- Active server -->
              <StackPanel Spacing="4">
                <TextBlock Text="Active server" Classes="muted"/>
                <TextBlock Text="{Binding ActiveServerUrl}"
                           Classes="accent"
                           IsVisible="{Binding ActiveServerUrl,
                                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              </StackPanel>

              <!-- Known servers list -->
              <TextBlock Text="Saved servers" Classes="muted" Margin="0,4,0,0"/>
              <ItemsControl ItemsSource="{Binding KnownServers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="services:ServerProfile">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                      <TextBlock Text="{Binding Name}"
                                 VerticalAlignment="Center"
                                 MinWidth="100"/>
                      <TextBlock Text="{Binding Url}"
                                 Classes="muted"
                                 VerticalAlignment="Center"/>
                      <Button Classes="ghost"
                              Content="Switch"
                              Command="{Binding $parent[ItemsControl].((settingsVm:AppearanceTabViewModel)DataContext).SwitchToServerCommand}"
                              CommandParameter="{Binding}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Add new server form -->
              <TextBlock Text="Add server" Classes="muted" Margin="0,8,0,0"/>
              <TextBox Classes="mga"
                       PlaceholderText="Name (optional)"
                       Text="{Binding NewServerName}"
                       MaxWidth="400"
                       HorizontalAlignment="Left"/>
              <TextBox Classes="mga"
                       PlaceholderText="http://hostname:8900"
                       Text="{Binding NewServerUrl}"
                       MaxWidth="400"
                       HorizontalAlignment="Left"/>
              <Button Classes="primary"
                      Content="Connect"
                      Command="{Binding AddServerCommand}"
                      IsEnabled="{Binding !IsConnecting}"
                      HorizontalAlignment="Left"/>
            </StackPanel>

          </StackPanel>
        </Border>
      </TabItem>

      <!-- Undetected -->
      <TabItem Header="Undetected">
        <Border Padding="0,20,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Undetected Games" Classes="subheading"/>
            <TextBlock Text="Manually add games that weren't auto-detected." Classes="muted"/>
            <TextBlock Text="Full implementation coming soon." Classes="muted"/>
          </StackPanel>
        </Border>
      </TabItem>

    </TabControl>
  </DockPanel>
</UserControl>
