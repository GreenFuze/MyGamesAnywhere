<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             x:Class="MGA.Desktop.Views.StatsView"
             x:DataType="vm:StatsViewModel">

  <DockPanel>

    <!-- ======================================================================
         Fixed header
         ====================================================================== -->
    <StackPanel DockPanel.Dock="Top" Margin="32,32,32,16">
      <TextBlock Text="Stats" Classes="heading"/>
    </StackPanel>

    <!-- ======================================================================
         Loading spinner
         ====================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            Margin="0,24">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ======================================================================
         Tab control
         ====================================================================== -->
    <TabControl IsVisible="{Binding !IsLoading}"
                Margin="24,0,24,24"
                SelectedIndex="{Binding SelectedTabIndex}">

      <!-- ==================================================================
           Library tab
           ================================================================== -->
      <TabItem Header="Library">
        <ScrollViewer Margin="0,16,0,0">
          <StackPanel Spacing="28">

            <!-- ── Stat tiles row ── -->
            <ItemsControl ItemsSource="{Binding StatTiles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StatTileModel">
                  <Border Classes="card"
                          MinWidth="140"
                          Margin="0,0,12,12"
                          Padding="20,16">
                    <StackPanel Spacing="6">
                      <!-- Icon -->
                      <TextBlock Text="{Binding Icon}"
                                 FontSize="24"
                                 Margin="0,0,0,4"/>
                      <!-- Primary value -->
                      <TextBlock Text="{Binding Value}"
                                 FontSize="{DynamicResource MgaFontSizeLg}"
                                 FontWeight="{DynamicResource MgaFontWeightBold}"/>
                      <!-- Sub-text (e.g. unlock percent) -->
                      <TextBlock Text="{Binding SubText}"
                                 Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeXs}"
                                 IsVisible="{Binding SubText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <!-- Label -->
                      <TextBlock Text="{Binding Label}"
                                 Classes="muted"
                                 FontSize="{DynamicResource MgaFontSizeSm}"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Platform breakdown ── -->
            <StackPanel Spacing="8">
              <TextBlock Text="By Platform" Classes="subheading"/>
              <ItemsControl ItemsSource="{Binding PlatformBreakdown}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CountStatModel">
                    <StackPanel Spacing="2" Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Count}"
                                   Classes="muted"
                                   MinWidth="40"
                                   TextAlignment="Right"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      </Grid>
                      <ProgressBar Minimum="0"
                                   Maximum="{Binding MaxCount}"
                                   Value="{Binding Count}"
                                   Height="5"
                                   CornerRadius="{DynamicResource MgaRadiusFull}"
                                   Foreground="{DynamicResource MgaAccentBrush}"
                                   Background="{DynamicResource MgaElevatedBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- ── Kind breakdown ── -->
            <StackPanel Spacing="8">
              <TextBlock Text="By Kind" Classes="subheading"/>
              <ItemsControl ItemsSource="{Binding KindBreakdown}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CountStatModel">
                    <StackPanel Spacing="2" Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Count}"
                                   Classes="muted"
                                   MinWidth="40"
                                   TextAlignment="Right"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      </Grid>
                      <ProgressBar Minimum="0"
                                   Maximum="{Binding MaxCount}"
                                   Value="{Binding Count}"
                                   Height="5"
                                   CornerRadius="{DynamicResource MgaRadiusFull}"
                                   Foreground="{DynamicResource MgaSuccessBrush}"
                                   Background="{DynamicResource MgaElevatedBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- ── Genre breakdown ── -->
            <StackPanel Spacing="8">
              <TextBlock Text="By Genre" Classes="subheading"/>
              <ItemsControl ItemsSource="{Binding GenreBreakdown}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CountStatModel">
                    <StackPanel Spacing="2" Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Count}"
                                   Classes="muted"
                                   MinWidth="40"
                                   TextAlignment="Right"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      </Grid>
                      <ProgressBar Minimum="0"
                                   Maximum="{Binding MaxCount}"
                                   Value="{Binding Count}"
                                   Height="5"
                                   CornerRadius="{DynamicResource MgaRadiusFull}"
                                   Foreground="{DynamicResource MgaAccentBrush}"
                                   Background="{DynamicResource MgaElevatedBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- ── Integration / Source breakdown ── -->
            <StackPanel Spacing="8"
                        IsVisible="{Binding HasIntegrationBreakdown}">
              <TextBlock Text="By Source" Classes="subheading"/>
              <ItemsControl ItemsSource="{Binding IntegrationBreakdown}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CountStatModel">
                    <StackPanel Spacing="2" Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Count}"
                                   Classes="muted"
                                   MinWidth="40"
                                   TextAlignment="Right"
                                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                      </Grid>
                      <ProgressBar Minimum="0"
                                   Maximum="{Binding MaxCount}"
                                   Value="{Binding Count}"
                                   Height="5"
                                   CornerRadius="{DynamicResource MgaRadiusFull}"
                                   Foreground="{DynamicResource MgaAccentMutedBrush}"
                                   Background="{DynamicResource MgaElevatedBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- ── Metadata coverage ── -->
            <StackPanel Spacing="8"
                        IsVisible="{Binding HasCoverage}">
              <TextBlock Text="Metadata Coverage" Classes="subheading"/>
              <TextBlock Text="Percentage of games that have each metadata field populated."
                         Classes="muted"
                         FontSize="{DynamicResource MgaFontSizeSm}"
                         Margin="0,0,0,4"/>

              <ItemsControl ItemsSource="{Binding Coverage}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CoverageStatModel">
                    <Border Classes="card"
                            MinWidth="120"
                            Margin="0,0,12,12"
                            Padding="16,12">
                      <StackPanel Spacing="6">
                        <!-- Percentage value -->
                        <TextBlock Text="{Binding PercentText}"
                                   FontSize="{DynamicResource MgaFontSizeLg}"
                                   FontWeight="{DynamicResource MgaFontWeightBold}"
                                   Foreground="{DynamicResource MgaAccentBrush}"/>
                        <!-- Label -->
                        <TextBlock Text="{Binding Label}"
                                   Classes="muted"
                                   FontSize="{DynamicResource MgaFontSizeSm}"/>
                        <!-- Mini progress bar -->
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Percent}"
                                     Height="4"
                                     CornerRadius="{DynamicResource MgaRadiusFull}"
                                     Foreground="{DynamicResource MgaAccentBrush}"
                                     Background="{DynamicResource MgaElevatedBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ==================================================================
           Gamer tab
           ================================================================== -->
      <TabItem Header="Gamer">
        <ScrollViewer Margin="0,16,0,0">
          <StackPanel Spacing="24">

            <!-- Favorite games -->
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding FavoriteGames}"
                         FontSize="{DynamicResource MgaFontSize2xl}"
                         FontWeight="{DynamicResource MgaFontWeightBold}"/>
              <TextBlock Text="favorite games" Classes="muted"/>
            </StackPanel>

            <!-- Achievement unlock summary -->
            <Border Classes="card">
              <StackPanel Spacing="8">
                <TextBlock Text="Achievements" Classes="subheading"/>
                <TextBlock Classes="muted">
                  <Run Text="{Binding UnlockedAchievements}"/>
                  <Run Text=" / "/>
                  <Run Text="{Binding TotalAchievements}"/>
                  <Run Text=" unlocked ("/>
                  <Run Text="{Binding UnlockPercent}"/>
                  <Run Text=")"/>
                </TextBlock>
                <ProgressBar Minimum="0"
                             Maximum="{Binding TotalAchievements}"
                             Value="{Binding UnlockedAchievements}"
                             Height="8"
                             CornerRadius="{DynamicResource MgaRadiusFull}"
                             Foreground="{DynamicResource MgaAccentBrush}"
                             Background="{DynamicResource MgaElevatedBrush}"/>
              </StackPanel>
            </Border>

            <!-- Achievement systems breakdown -->
            <StackPanel Spacing="8">
              <TextBlock Text="By Source" Classes="subheading"/>
              <ItemsControl ItemsSource="{Binding AchievementSystems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AchievementSystemRowModel">
                    <Border Classes="card" Margin="0,0,0,6">
                      <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding Source}"
                                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                          <TextBlock Grid.Column="1" Classes="muted">
                            <Run Text="{Binding Unlocked}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding Total}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding PercentText}"/>
                            <Run Text=")"/>
                          </TextBlock>
                        </Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding Total}"
                                     Value="{Binding Unlocked}"
                                     Height="5"
                                     CornerRadius="{DynamicResource MgaRadiusFull}"
                                     Foreground="{DynamicResource MgaAccentBrush}"
                                     Background="{DynamicResource MgaElevatedBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ==================================================================
           Scans tab
           ================================================================== -->
      <TabItem Header="Scans">
        <ScrollViewer Margin="0,16,0,0">
          <StackPanel Spacing="24">

            <Border Classes="card" IsVisible="{Binding HasScanReports}">
              <StackPanel Spacing="8">
                <TextBlock Text="Recent Scans" Classes="subheading"/>
                <ItemsControl ItemsSource="{Binding ScanReports}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ScanReportRowViewModel">
                      <Border Padding="0,6"
                              BorderThickness="0,0,0,1"
                              BorderBrush="{DynamicResource MgaBorderBrush}">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding StartedAt}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Summary}" Classes="muted"/>
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Duration}"
                                     Classes="muted"
                                     VerticalAlignment="Center"
                                     Margin="12,0"/>
                          <TextBlock Grid.Column="2"
                                     Text="{Binding TotalGames, StringFormat='{}{0} games'}"
                                     Classes="muted"
                                     VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <TextBlock Text="No scan reports available."
                       Classes="muted"
                       IsVisible="{Binding !HasScanReports}"/>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>

  </DockPanel>
</UserControl>
