<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             x:Class="MGA.Desktop.Views.StatsView"
             x:DataType="vm:StatsViewModel">

  <Border Padding="32">
    <StackPanel Spacing="8">
      <TextBlock Text="Stats" Classes="heading"/>
      <TextBlock Text="Library and Gamer statistics with animated charts — coming soon."
                 Classes="muted"/>
    </StackPanel>
  </Border>
</UserControl>
