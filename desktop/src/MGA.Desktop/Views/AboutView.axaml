<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             x:Class="MGA.Desktop.Views.AboutView"
             x:DataType="vm:AboutViewModel">

  <ScrollViewer>
    <Border Padding="48">
      <StackPanel Spacing="0" MaxWidth="560">

        <!-- Logo + app name -->
        <StackPanel Spacing="16" Margin="0,0,0,32">
          <Image Source="/Assets/mga.ico" Width="72" Height="72"
                 HorizontalAlignment="Left"/>
          <TextBlock Text="MyGamesAnywhere" Classes="heading"/>
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding ClientVersion, StringFormat='Client version {0}'}"
                       Classes="muted"/>
            <TextBlock Text="{Binding ClientBuildDate, StringFormat='Built {0}'}"
                       Classes="muted"/>
          </StackPanel>
        </StackPanel>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource MgaBorderBrush}"
                Margin="0,0,0,24"/>

        <!-- Server info -->
        <Border Margin="0,0,0,24"
                IsVisible="{Binding HasServerInfo}">
          <StackPanel Spacing="8">
            <TextBlock Text="Server"
                       FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Version:" Classes="muted" Width="80"/>
                <TextBlock Text="{Binding ServerVersion}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8"
                          IsVisible="{Binding ServerBuildDate,
                                      Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="Built:" Classes="muted" Width="80"/>
                <TextBlock Text="{Binding ServerBuildDate}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8"
                          IsVisible="{Binding ServerCommit,
                                      Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="Commit:" Classes="muted" Width="80"/>
                <TextBlock Text="{Binding ServerCommit}"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           FontSize="{DynamicResource MgaFontSizeSm}"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource MgaBorderBrush}"
                Margin="0,0,0,24"/>

        <!-- Description -->
        <TextBlock Text="MyGamesAnywhere is an open-source self-hosted game library manager and desktop client. Discover, organize, and launch your games from anywhere."
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <!-- Repository link -->
        <StackPanel Spacing="8" Margin="0,0,0,24">
          <TextBlock Text="Repository"
                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
          <Button Classes="ghost"
                  Command="{Binding OpenRepositoryCommand}"
                  HorizontalAlignment="Left">
            <TextBlock Text="github.com/GreenFuze/MyGamesAnywhere"
                       Foreground="{DynamicResource MgaAccentBrush}"/>
          </Button>
        </StackPanel>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource MgaBorderBrush}"
                Margin="0,0,0,24"/>

        <!-- License notice -->
        <StackPanel Spacing="8">
          <TextBlock Text="Licenses"
                     FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
          <TextBlock Text="© GreenFuze. Open-source licenses for all bundled dependencies are available in the repository's LICENSES directory."
                     Classes="muted"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource MgaBorderBrush}"
                Margin="0,24,0,0"/>

        <!-- Third-party credits -->
        <TextBlock Text="Powered By"
                   FontWeight="{DynamicResource MgaFontWeightSemiBold}"
                   Margin="0,24,0,4"/>
        <TextBlock Text="External services, data providers, and runtimes that power MyGamesAnywhere."
                   Classes="muted"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <ItemsControl ItemsSource="{Binding ThirdPartyCredits}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ThirdPartyCredit">
              <Border Padding="0,8"
                      BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource MgaBorderBrush}">
                <Grid ColumnDefinitions="*,Auto">

                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Name}"
                               FontWeight="{DynamicResource MgaFontWeightSemiBold}"/>
                    <TextBlock Text="{Binding Description}"
                               Classes="muted"
                               TextWrapping="Wrap"/>
                  </StackPanel>

                  <Button Grid.Column="1"
                          Classes="ghost"
                          Content="Visit ↗"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0"
                          IsVisible="{Binding WebsiteUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Command="{Binding $parent[ItemsControl].((vm:AboutViewModel)DataContext).OpenUrlCommand}"
                          CommandParameter="{Binding WebsiteUrl}"/>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
