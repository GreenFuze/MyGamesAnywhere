<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:ac="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:al="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

  <DockPanel>

    <!-- ==========================================================================
         Fixed header + filter bar
         ========================================================================== -->
    <StackPanel DockPanel.Dock="Top"
                Spacing="10"
                Margin="32,32,32,12">

      <!-- Heading row -->
      <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
        <TextBlock Text="Library" Classes="heading"/>
        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} games'}"
                   Classes="muted"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Search box -->
      <TextBox Classes="mga"
               PlaceholderText="Search by title, platform, developer…"
               Text="{Binding SearchText}"
               MaxWidth="480"
               HorizontalAlignment="Left"/>

      <!-- ── Row 1: filter chips ── -->
      <WrapPanel Orientation="Horizontal">

        <!-- Platform multi-select chip -->
        <Button Classes="filter" Margin="0,0,6,6">
          <Button.Content>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="{Binding SelectedPlatformsText}" VerticalAlignment="Center"/>
              <TextBlock Text="▾" FontSize="9" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.7"/>
            </StackPanel>
          </Button.Content>
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <Border MaxHeight="260" MinWidth="200"
                      Background="{DynamicResource MgaSurfaceBrush}"
                      CornerRadius="8"
                      Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding PlatformOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:FilterOptionModel">
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="4,3"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Genre multi-select chip -->
        <Button Classes="filter" Margin="0,0,6,6">
          <Button.Content>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="{Binding SelectedGenresText}" VerticalAlignment="Center"/>
              <TextBlock Text="▾" FontSize="9" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.7"/>
            </StackPanel>
          </Button.Content>
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <Border MaxHeight="260" MinWidth="200"
                      Background="{DynamicResource MgaSurfaceBrush}"
                      CornerRadius="8"
                      Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding GenreOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:FilterOptionModel">
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="4,3"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Developer dropdown -->
        <ComboBox ItemsSource="{Binding Developers}"
                  SelectedItem="{Binding SelectedDeveloper}"
                  MinWidth="160"
                  Height="32"
                  Margin="0,0,6,6"/>

        <!-- Publisher dropdown -->
        <ComboBox ItemsSource="{Binding Publishers}"
                  SelectedItem="{Binding SelectedPublisher}"
                  MinWidth="160"
                  Height="32"
                  Margin="0,0,6,6"/>

        <!-- Integration / source dropdown -->
        <ComboBox ItemsSource="{Binding Integrations}"
                  SelectedItem="{Binding SelectedIntegration}"
                  MinWidth="140"
                  Height="32"
                  Margin="0,0,6,6"/>

        <!-- Year range inputs -->
        <Border Background="{DynamicResource MgaElevatedBrush}"
                BorderBrush="{DynamicResource MgaBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource MgaRadiusFull}"
                Height="32"
                Margin="0,0,6,6"
                Padding="12,0">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Year" VerticalAlignment="Center"
                       FontSize="{DynamicResource MgaFontSizeSm}"
                       Foreground="{DynamicResource MgaMutedBrush}"/>
            <TextBox PlaceholderText="From"
                     Text="{Binding YearFrom}"
                     Width="52"
                     Height="24"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="4,0"
                     VerticalContentAlignment="Center"
                     FontSize="{DynamicResource MgaFontSizeSm}"/>
            <TextBlock Text="–" VerticalAlignment="Center"
                       Foreground="{DynamicResource MgaMutedBrush}"/>
            <TextBox PlaceholderText="To"
                     Text="{Binding YearTo}"
                     Width="52"
                     Height="24"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="4,0"
                     VerticalContentAlignment="Center"
                     FontSize="{DynamicResource MgaFontSizeSm}"/>
          </StackPanel>
        </Border>

      </WrapPanel>

      <!-- ── Row 2: sort + view + actions ── -->
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

        <!-- Sort dropdown -->
        <ComboBox ItemsSource="{Binding SortOptions}"
                  SelectedIndex="{Binding SelectedSortIndex}"
                  MinWidth="160"
                  Height="32"/>

        <!-- Divider -->
        <Border Width="1" Height="20" Background="{DynamicResource MgaBorderBrush}"
                VerticalAlignment="Center" Margin="4,0"/>

        <!-- Favorites toggle -->
        <Button Classes="filter active"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding ShowFavoritesOnly}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="★" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="Favorites" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Classes="filter"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding !ShowFavoritesOnly}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="☆" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="Favorites" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- View mode cycle -->
        <Button Classes="filter"
                Command="{Binding ToggleViewModeCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="{Binding ViewModeNextLabel}" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Divider -->
        <Border Width="1" Height="20" Background="{DynamicResource MgaBorderBrush}"
                VerticalAlignment="Center" Margin="4,0"/>

        <!-- Bulk-select mode toggle -->
        <Button Classes="filter active"
                Command="{Binding ToggleBulkSelectModeCommand}"
                IsVisible="{Binding IsBulkSelectMode}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="☑" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="Select" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Classes="filter"
                Command="{Binding ToggleBulkSelectModeCommand}"
                IsVisible="{Binding !IsBulkSelectMode}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="☐" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="Select" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Clear filters -->
        <Button Classes="filter"
                Command="{Binding ClearFiltersCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="Clear Filters" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Spacer -->
        <Border HorizontalAlignment="Stretch" Width="8"/>

        <!-- Scan Library — right edge -->
        <Button Classes="ghost"
                Command="{Binding ScanCommand}"
                IsEnabled="{Binding !IsScanning}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="↻" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock Text="Scan Library" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

      </StackPanel>

    </StackPanel>

    <!-- ==========================================================================
         Bulk-action toolbar — visible only when IsBulkSelectMode is active
         ========================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsBulkSelectMode}"
            Background="{DynamicResource MgaElevatedBrush}"
            Padding="32,8"
            Margin="0,0,0,4">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Classes="muted">
          <Run Text="{Binding SelectedCount}"/>
          <Run Text=" selected"/>
        </TextBlock>
        <Button Classes="ghost"
                Content="Select All"
                Command="{Binding SelectAllCommand}"/>
        <Button Classes="ghost"
                Content="Clear"
                Command="{Binding ClearSelectionCommand}"/>
        <Button Classes="ghost"
                Content="{Binding BulkReclassifyLabel}"
                Command="{Binding BulkReclassifyCommand}"
                IsEnabled="{Binding HasSelectedGames}"
                ToolTip.Tip="Clear canonical pins — games will be re-grouped automatically"/>
        <Button Classes="danger"
                Content="{Binding BulkDeleteLabel}"
                Command="{Binding BulkHardDeleteCommand}"
                IsEnabled="{Binding HasSelectedGames}"/>
      </StackPanel>
    </Border>

    <!-- ==========================================================================
         Loading indicator
         ========================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            Margin="0,16">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ==========================================================================
         List view — tabular rows (title, platform, developer, year)
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowListView}">
      <StackPanel Margin="32,0,32,32">

        <!-- Column header row -->
        <Border Padding="0,8" Background="{DynamicResource MgaElevatedBrush}">
          <Grid ColumnDefinitions="Auto,*,180,60" Margin="8,0">
            <Border Grid.Column="0" Width="32" IsVisible="{Binding IsBulkSelectMode}"/>
            <TextBlock Grid.Column="1" Text="Title"     Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="Developer" Classes="muted" FontWeight="SemiBold" Margin="8,0,0,0"/>
            <TextBlock Grid.Column="3" Text="Year"      Classes="muted" FontWeight="SemiBold" Margin="8,0,0,0"/>
          </Grid>
        </Border>

        <!-- List rows -->
        <ItemsControl ItemsSource="{Binding FilteredGames}"
                      HorizontalAlignment="Stretch">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel HorizontalAlignment="Stretch"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:GameCardModel">
              <Grid ColumnDefinitions="Auto,*" HorizontalAlignment="Stretch">
                <!-- Checkbox column (only visible in bulk mode) -->
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsSelected}"
                          Width="32"
                          VerticalAlignment="Center"
                          IsVisible="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode}"/>
                <!-- Row content — navigates when NOT in bulk mode -->
                <Button Grid.Column="1"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                        CommandParameter="{Binding Id}"
                        IsEnabled="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode, Converter={x:Static BoolConverters.Not}}"
                        Cursor="Hand">
                  <Border Padding="8,10"
                          Background="Transparent"
                          HorizontalAlignment="Stretch">
                    <!-- 3-column data grid: Title+badge | Developer | Year -->
                    <Grid ColumnDefinitions="*,180,60" HorizontalAlignment="Stretch">

                      <!-- Title with inline platform badge, badge right-aligned so title truncates cleanly -->
                      <Grid Grid.Column="0" ColumnDefinitions="*,Auto" Margin="0,0,8,0">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Background="{Binding PlatformBadgeColor}"
                                CornerRadius="4"
                                Padding="7,2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding Platform}"
                                     FontSize="10" FontWeight="Bold"
                                     Foreground="#FFFFFF"
                                     TextTrimming="CharacterEllipsis" MaxWidth="90"/>
                        </Border>
                      </Grid>

                      <TextBlock Grid.Column="1" Text="{Binding Developer}"
                                 Classes="muted" TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" Margin="8,0,0,0"/>
                      <TextBlock Grid.Column="2" Text="{Binding ReleaseYearDisplay}"
                                 Classes="muted" VerticalAlignment="Center"
                                 Margin="8,0,0,0"/>
                    </Grid>
                  </Border>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Timeline view — games grouped by release year, newest-first
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowTimelineView}">
      <StackPanel Margin="32,0,32,32" Spacing="32">

        <ItemsControl ItemsSource="{Binding TimelineGroups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="32"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:TimelineYearGroupViewModel">
              <StackPanel Spacing="12">

                <!-- Year heading with accent underline -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                  <TextBlock Text="{Binding YearLabel}"
                             FontSize="22"
                             FontWeight="Bold"
                             Foreground="{DynamicResource MgaAccentBrush}"/>
                  <Border Height="2"
                          VerticalAlignment="Center"
                          Background="{DynamicResource MgaBorderBrush}"
                          HorizontalAlignment="Stretch"
                          MinWidth="60"/>
                </StackPanel>

                <!-- Games in a wrapping card grid -->
                <ItemsControl ItemsSource="{Binding Games}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" ItemWidth="184" ItemHeight="254"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameCardModel">
                      <Button Classes="game-card"
                              Command="{Binding $parent[UserControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                              CommandParameter="{Binding Id}"
                              Width="170" Height="240" Margin="0,0,14,14"
                              Background="Transparent" BorderThickness="0" Padding="0"
                              Cursor="Hand">
                        <Panel>
                          <!-- Accent glow shadow -->
                          <Border Classes="card-glow"
                                  CornerRadius="{DynamicResource MgaRadiusLg}"
                                  BoxShadow="0 0 28 6 #703db8ff"
                                  Background="Transparent"/>
                          <!-- Card surface -->
                          <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                                  Background="{DynamicResource MgaSurfaceBrush}"
                                  ClipToBounds="True">
                            <Grid>
                              <!-- Gradient placeholder background -->
                              <Border>
                                <Border.Background>
                                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="{DynamicResource MgaElevatedColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource MgaBgColor}" Offset="1"/>
                                  </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="NoWrap"
                                           FontSize="80"
                                           FontWeight="Bold"
                                           Opacity="0.06"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MgaAccentBrush}"
                                           Margin="-20,0"/>
                              </Border>
                              <!-- Cover art -->
                              <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                                       Stretch="UniformToFill"
                                                       VerticalAlignment="Top"/>
                              <!-- Platform badge — top-right corner -->
                              <Border VerticalAlignment="Top"
                                      HorizontalAlignment="Right"
                                      Background="{Binding PlatformBadgeColor}"
                                      CornerRadius="0,12,0,8"
                                      Padding="6,3">
                                <TextBlock Text="{Binding Platform}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="72"/>
                              </Border>
                              <!-- Gradient title + source overlay -->
                              <Border Classes="card-title"
                                      VerticalAlignment="Bottom"
                                      Padding="8,32,8,9">
                                <Border.Background>
                                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#CC000000" Offset="0.6"/>
                                    <GradientStop Color="#EE000000" Offset="1"/>
                                  </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="3">
                                  <!-- Source integration chip -->
                                  <Border Background="#22FFFFFF"
                                          CornerRadius="3"
                                          Padding="5,2"
                                          HorizontalAlignment="Left"
                                          IsVisible="{Binding SourceBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding SourceBadge}"
                                               FontSize="8"
                                               FontWeight="Bold"
                                               Foreground="#BBFFFFFF"/>
                                  </Border>
                                  <TextBlock Text="{Binding Title}"
                                             FontSize="12"
                                             FontWeight="SemiBold"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="#FFFFFF"/>
                                </StackPanel>
                              </Border>
                              <!-- Hover overlay: action buttons appear on hover -->
                              <Border Classes="card-hover-overlay"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      IsHitTestVisible="False">
                                <Border VerticalAlignment="Bottom"
                                        Padding="7,0,7,8">
                                  <StackPanel Spacing="4">
                                    <Border Background="#AA000000"
                                            CornerRadius="6"
                                            Padding="0,5">
                                      <TextBlock Text="▶  Play"
                                                 FontSize="11" FontWeight="SemiBold"
                                                 Foreground="#FFFFFF"
                                                 HorizontalAlignment="Center"/>
                                    </Border>
                                  </StackPanel>
                                </Border>
                              </Border>
                            </Grid>
                          </Border>
                        </Panel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Shelf view — horizontal scroll rows (Favorites + per-platform)
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowShelfView}">
      <StackPanel Margin="32,0,32,32" Spacing="32">

        <ItemsControl ItemsSource="{Binding ShelfRows}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="32"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ShelfRowViewModel">
              <StackPanel Spacing="10">

                <!-- Row heading with accent bar -->
                <Grid ColumnDefinitions="3,Auto">
                  <Border Grid.Column="0"
                          Background="{DynamicResource MgaAccentBrush}"
                          CornerRadius="2"
                          Width="3"
                          Margin="0,3,0,3"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource MgaTextBrush}"
                             Margin="10,0,0,0"/>
                </Grid>

                <!-- Horizontal scroll strip of game cards -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:GameCardModel">
                        <Button Classes="game-card"
                                Command="{Binding $parent[UserControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                                CommandParameter="{Binding Id}"
                                Width="170" Height="240"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Cursor="Hand">
                          <Panel>
                            <Border Classes="card-glow"
                                    CornerRadius="{DynamicResource MgaRadiusLg}"
                                    BoxShadow="0 0 28 6 #703db8ff"
                                    Background="Transparent"/>
                            <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                                    Background="{DynamicResource MgaSurfaceBrush}"
                                    ClipToBounds="True">
                              <Grid>
                                <Border>
                                  <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                      <GradientStop Color="{DynamicResource MgaElevatedColor}" Offset="0"/>
                                      <GradientStop Color="{DynamicResource MgaBgColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                  </Border.Background>
                                  <TextBlock Text="{Binding Title}"
                                             TextWrapping="NoWrap"
                                             FontSize="80"
                                             FontWeight="Bold"
                                             Opacity="0.06"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MgaAccentBrush}"
                                             Margin="-20,0"/>
                                </Border>
                                <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                                         Stretch="UniformToFill"
                                                         VerticalAlignment="Top"/>
                                <Border VerticalAlignment="Top"
                                        HorizontalAlignment="Right"
                                        Background="{Binding PlatformBadgeColor}"
                                        CornerRadius="0,12,0,8"
                                        Padding="6,3">
                                  <TextBlock Text="{Binding Platform}"
                                             FontSize="9"
                                             FontWeight="Bold"
                                             Foreground="#FFFFFF"
                                             TextTrimming="CharacterEllipsis"
                                             MaxWidth="72"/>
                                </Border>
                                <Border Classes="card-title"
                                        VerticalAlignment="Bottom"
                                        Padding="8,32,8,9">
                                  <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                      <GradientStop Color="#00000000" Offset="0"/>
                                      <GradientStop Color="#CC000000" Offset="0.6"/>
                                      <GradientStop Color="#EE000000" Offset="1"/>
                                    </LinearGradientBrush>
                                  </Border.Background>
                                  <StackPanel Spacing="3">
                                    <!-- Source integration chip -->
                                    <Border Background="#22FFFFFF"
                                            CornerRadius="3"
                                            Padding="5,2"
                                            HorizontalAlignment="Left"
                                            IsVisible="{Binding SourceBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                      <TextBlock Text="{Binding SourceBadge}"
                                                 FontSize="8"
                                                 FontWeight="Bold"
                                                 Foreground="#BBFFFFFF"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#FFFFFF"/>
                                  </StackPanel>
                                </Border>
                                <!-- Hover overlay: action buttons appear on hover -->
                                <Border Classes="card-hover-overlay"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        IsHitTestVisible="False">
                                  <Border VerticalAlignment="Bottom"
                                          Padding="7,0,7,8">
                                    <StackPanel Spacing="4">
                                      <Border Background="#AA000000"
                                              CornerRadius="6"
                                              Padding="0,5">
                                        <TextBlock Text="▶  Play"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   HorizontalAlignment="Center"/>
                                      </Border>
                                    </StackPanel>
                                  </Border>
                                </Border>
                              </Grid>
                            </Border>
                          </Panel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Justified game grid — shown in Grid mode (Google-Photos-style layout)
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowGridView}">
      <ItemsControl ItemsSource="{Binding FilteredGames}"
                    Margin="32,0,32,32">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <controls:JustifiedPanel TargetRowHeight="210" Spacing="12"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:GameCardModel">
            <!--
              AspectRatio tells JustifiedPanel how wide this card wants to be at the target row height.
              The panel reads this attached property from the DataTemplate root (Grid) via ContentPresenter.Child.
            -->
            <Grid controls:JustifiedPanel.AspectRatio="{Binding CoverAspectRatio}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">

              <!-- Normal navigation card — hidden in bulk-select mode -->
              <Button Classes="game-card"
                      Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                      CommandParameter="{Binding Id}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Transparent" BorderThickness="0" Padding="0"
                      Cursor="Hand"
                      IsVisible="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode, Converter={x:Static BoolConverters.Not}}">
                <Panel>
                  <Border Classes="card-glow"
                          CornerRadius="{DynamicResource MgaRadiusLg}"
                          BoxShadow="0 0 28 6 #703db8ff"
                          Background="Transparent"/>
                  <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                          Background="{DynamicResource MgaSurfaceBrush}"
                          ClipToBounds="True">
                    <Grid>
                      <!-- Gradient placeholder background with faint title watermark -->
                      <Border>
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="{DynamicResource MgaElevatedColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource MgaBgColor}" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding Title}"
                                   TextWrapping="NoWrap"
                                   FontSize="80"
                                   FontWeight="Bold"
                                   Opacity="0.06"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource MgaAccentBrush}"
                                   Margin="-20,0"/>
                      </Border>
                      <!-- Cover art — top-anchored so title/logo is preserved -->
                      <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                               Stretch="UniformToFill"
                                               VerticalAlignment="Top"/>
                      <!-- Platform badge — top-right corner -->
                      <Border VerticalAlignment="Top"
                              HorizontalAlignment="Right"
                              Background="{Binding PlatformBadgeColor}"
                              CornerRadius="0,12,0,8"
                              Padding="6,3">
                        <TextBlock Text="{Binding Platform}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="72"/>
                      </Border>
                      <!-- Gradient title + source overlay -->
                      <Border Classes="card-title"
                              VerticalAlignment="Bottom"
                              Padding="8,32,8,9">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#CC000000" Offset="0.6"/>
                            <GradientStop Color="#EE000000" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="3">
                          <!-- Source integration chip -->
                          <Border Background="#22FFFFFF"
                                  CornerRadius="3"
                                  Padding="5,2"
                                  HorizontalAlignment="Left"
                                  IsVisible="{Binding SourceBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding SourceBadge}"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="#BBFFFFFF"/>
                          </Border>
                          <TextBlock Text="{Binding Title}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="#FFFFFF"/>
                        </StackPanel>
                      </Border>
                      <!-- Hover overlay: Play button on hover -->
                      <Border Classes="card-hover-overlay"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              IsHitTestVisible="False">
                        <Border VerticalAlignment="Bottom"
                                Padding="7,0,7,8">
                          <StackPanel Spacing="4">
                            <Border Background="#AA000000"
                                    CornerRadius="6"
                                    Padding="0,5">
                              <TextBlock Text="▶  Play"
                                         FontSize="11" FontWeight="SemiBold"
                                         Foreground="#FFFFFF"
                                         HorizontalAlignment="Center"/>
                            </Border>
                          </StackPanel>
                        </Border>
                      </Border>
                    </Grid>
                  </Border>
                </Panel>
              </Button>

              <!-- Bulk-select overlay — visible in bulk-select mode -->
              <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                      Background="{DynamicResource MgaSurfaceBrush}"
                      ClipToBounds="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      IsVisible="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode}">
                <Grid>
                  <!-- Gradient placeholder -->
                  <Border>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource MgaElevatedColor}" Offset="0"/>
                        <GradientStop Color="{DynamicResource MgaBgColor}" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="{Binding Title}"
                               TextWrapping="NoWrap"
                               FontSize="80"
                               FontWeight="Bold"
                               Opacity="0.06"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MgaAccentBrush}"
                               Margin="-20,0"/>
                  </Border>
                  <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Top"/>
                  <!-- Gradient title + source overlay -->
                  <Border VerticalAlignment="Bottom" Padding="8,32,8,9">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#CC000000" Offset="0.6"/>
                        <GradientStop Color="#EE000000" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Spacing="3">
                      <Border Background="#22FFFFFF"
                              CornerRadius="3"
                              Padding="5,2"
                              HorizontalAlignment="Left"
                              IsVisible="{Binding SourceBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding SourceBadge}"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="#BBFFFFFF"/>
                      </Border>
                      <TextBlock Text="{Binding Title}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="#FFFFFF"/>
                    </StackPanel>
                  </Border>
                  <!-- Selection tint when checked -->
                  <Border Background="#553db8ff"
                          IsVisible="{Binding IsSelected}"/>
                  <!-- Checkbox — top-left corner -->
                  <CheckBox IsChecked="{Binding IsSelected}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="6"/>
                </Grid>
              </Border>

            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>

</UserControl>
