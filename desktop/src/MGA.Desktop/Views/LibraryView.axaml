<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:ac="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:al="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

  <DockPanel>

    <!-- ==========================================================================
         Fixed header + search bar
         ========================================================================== -->
    <StackPanel DockPanel.Dock="Top"
                Spacing="12"
                Margin="32,32,32,16">

      <!-- Heading row -->
      <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
        <TextBlock Text="Library" Classes="heading"/>
        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} games'}"
                   Classes="muted"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Search box -->
      <TextBox Classes="mga"
               PlaceholderText="Search games…"
               Text="{Binding SearchText}"
               MaxWidth="400"
               HorizontalAlignment="Left"/>

      <!-- Filter / sort / scan row -->
      <StackPanel Orientation="Horizontal" Spacing="8">

        <!-- Platform dropdown -->
        <ComboBox ItemsSource="{Binding Platforms}"
                  SelectedItem="{Binding SelectedPlatform}"
                  MinWidth="160"/>

        <!-- Genre dropdown -->
        <ComboBox ItemsSource="{Binding Genres}"
                  SelectedItem="{Binding SelectedGenre}"
                  MinWidth="140"/>

        <!-- Sort dropdown -->
        <ComboBox ItemsSource="{Binding SortOptions}"
                  SelectedIndex="{Binding SelectedSortIndex}"
                  MinWidth="140"/>

        <!-- Favorites toggle — two overlapping buttons -->
        <Button Classes="primary"
                Content="★ Favorites Only"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding ShowFavoritesOnly}"/>
        <Button Classes="ghost"
                Content="☆ Favorites Only"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding !ShowFavoritesOnly}"/>

        <!-- View mode toggle — shows opposite of current mode -->
        <Button Classes="ghost"
                Content="▦ Grid"
                Command="{Binding ToggleViewModeCommand}"
                IsVisible="{Binding IsListView}"/>
        <Button Classes="ghost"
                Content="☰ List"
                Command="{Binding ToggleViewModeCommand}"
                IsVisible="{Binding !IsListView}"/>

        <!-- Scan trigger -->
        <Button Classes="ghost"
                Content="↻ Scan Library"
                Command="{Binding ScanCommand}"
                IsEnabled="{Binding !IsScanning}"/>

      </StackPanel>

    </StackPanel>

    <!-- ==========================================================================
         Loading indicator
         ========================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            Margin="0,16">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ==========================================================================
         List view — shown when IsListView = true and not loading
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowListView}">
      <StackPanel Margin="32,0,32,32">

        <!-- Column header row -->
        <Border Padding="8,8" Background="{DynamicResource MgaElevatedBrush}">
          <Grid ColumnDefinitions="*,140,80,160">
            <TextBlock Grid.Column="0" Text="Title" Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="Platform" Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="Kind" Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="3" Text="Developer" Classes="muted" FontWeight="SemiBold"/>
          </Grid>
        </Border>

        <!-- List rows -->
        <ItemsControl ItemsSource="{Binding FilteredGames}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:GameCardModel">
              <Button Background="Transparent" BorderThickness="0" Padding="0"
                      HorizontalContentAlignment="Stretch"
                      Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                      CommandParameter="{Binding Id}"
                      Cursor="Hand">
                <Border Padding="8,10" Background="Transparent">
                  <Grid ColumnDefinitions="*,140,80,160">
                    <TextBlock Grid.Column="0" Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Platform}" Classes="muted" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Kind}" Classes="muted" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding Developer}" Classes="muted" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Virtualized game grid — shown when IsListView = false and not loading
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowGridView}">
      <ac:ItemsRepeater ItemsSource="{Binding FilteredGames}"
                     Margin="32,0,32,32">
        <ac:ItemsRepeater.Layout>
          <al:UniformGridLayout MinItemWidth="160" MinItemHeight="220"
                             MinColumnSpacing="12" MinRowSpacing="12"/>
        </ac:ItemsRepeater.Layout>
        <ac:ItemsRepeater.ItemTemplate>
          <DataTemplate x:DataType="vm:GameCardModel">
            <Button Classes="game-card"
                    Command="{Binding $parent[ac:ItemsRepeater].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                    CommandParameter="{Binding Id}"
                    Width="160" Height="220"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    Cursor="Hand">
              <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                      Background="{DynamicResource MgaSurfaceBrush}"
                      ClipToBounds="True">
                <Grid>
                  <!-- Placeholder shown when cover art is absent -->
                  <Border Background="{DynamicResource MgaElevatedBrush}">
                    <TextBlock Text="{Binding Title}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="8"
                               Classes="muted"/>
                  </Border>
                  <!-- Cover art — AdvancedImage renders nothing when Source is null -->
                  <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                           Stretch="UniformToFill"/>
                  <!-- Title overlay at bottom -->
                  <Border VerticalAlignment="Bottom"
                          Background="#CC000000"
                          Padding="8,6">
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#FFFFFF"/>
                  </Border>
                </Grid>
              </Border>
            </Button>
          </DataTemplate>
        </ac:ItemsRepeater.ItemTemplate>
      </ac:ItemsRepeater>
    </ScrollViewer>

  </DockPanel>

</UserControl>
