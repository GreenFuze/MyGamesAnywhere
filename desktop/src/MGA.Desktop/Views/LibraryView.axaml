<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MGA.Desktop.ViewModels"
             xmlns:controls="using:MGA.Desktop.Controls"
             xmlns:ac="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:al="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:asyncImage="using:AsyncImageLoader"
             x:Class="MGA.Desktop.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

  <DockPanel>

    <!-- ==========================================================================
         Fixed header + filter bar
         ========================================================================== -->
    <StackPanel DockPanel.Dock="Top"
                Spacing="10"
                Margin="32,32,32,12">

      <!-- Heading row -->
      <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
        <TextBlock Text="Library" Classes="heading"/>
        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} games'}"
                   Classes="muted"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Search box -->
      <TextBox Classes="mga"
               PlaceholderText="Search by title, platform, developer…"
               Text="{Binding SearchText}"
               MaxWidth="480"
               HorizontalAlignment="Left"/>

      <!-- ── Row 1: multi-select filters + year range ── -->
      <WrapPanel Orientation="Horizontal">

        <!-- Platform multi-select flyout -->
        <Button Classes="ghost" Margin="0,0,6,6">
          <Button.Content>
            <TextBlock Text="{Binding SelectedPlatformsText}"/>
          </Button.Content>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border MaxHeight="240" MinWidth="180">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding PlatformOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:FilterOptionModel">
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="4,2"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Genre multi-select flyout -->
        <Button Classes="ghost" Margin="0,0,6,6">
          <Button.Content>
            <TextBlock Text="{Binding SelectedGenresText}"/>
          </Button.Content>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border MaxHeight="240" MinWidth="180">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding GenreOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:FilterOptionModel">
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="4,2"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Developer dropdown -->
        <ComboBox ItemsSource="{Binding Developers}"
                  SelectedItem="{Binding SelectedDeveloper}"
                  MinWidth="160"
                  Margin="0,0,6,6"/>

        <!-- Publisher dropdown -->
        <ComboBox ItemsSource="{Binding Publishers}"
                  SelectedItem="{Binding SelectedPublisher}"
                  MinWidth="160"
                  Margin="0,0,6,6"/>

        <!-- Integration / source dropdown -->
        <ComboBox ItemsSource="{Binding Integrations}"
                  SelectedItem="{Binding SelectedIntegration}"
                  MinWidth="140"
                  Margin="0,0,6,6"/>

        <!-- Year from / to -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,6,6">
          <TextBlock Text="Year" VerticalAlignment="Center" Classes="muted"/>
          <TextBox Classes="mga"
                   PlaceholderText="From"
                   Text="{Binding YearFrom}"
                   Width="70"/>
          <TextBlock Text="–" VerticalAlignment="Center" Classes="muted"/>
          <TextBox Classes="mga"
                   PlaceholderText="To"
                   Text="{Binding YearTo}"
                   Width="70"/>
        </StackPanel>

      </WrapPanel>

      <!-- ── Row 2: sort + toggles + actions ── -->
      <StackPanel Orientation="Horizontal" Spacing="8">

        <!-- Sort dropdown -->
        <ComboBox ItemsSource="{Binding SortOptions}"
                  SelectedIndex="{Binding SelectedSortIndex}"
                  MinWidth="160"/>

        <!-- Favorites toggle -->
        <Button Classes="primary"
                Content="★ Favorites"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding ShowFavoritesOnly}"/>
        <Button Classes="ghost"
                Content="☆ Favorites"
                Command="{Binding ToggleFavoritesOnlyCommand}"
                IsVisible="{Binding !ShowFavoritesOnly}"/>

        <!-- View mode cycle button — label shows the NEXT mode -->
        <Button Classes="ghost"
                Content="{Binding ViewModeNextLabel}"
                Command="{Binding ToggleViewModeCommand}"/>

        <!-- Clear all filters -->
        <Button Classes="ghost"
                Content="✕ Clear Filters"
                Command="{Binding ClearFiltersCommand}"/>

        <!-- Bulk-select mode toggle -->
        <Button Classes="primary"
                Content="☑ Select"
                Command="{Binding ToggleBulkSelectModeCommand}"
                IsVisible="{Binding IsBulkSelectMode}"/>
        <Button Classes="ghost"
                Content="☐ Select"
                Command="{Binding ToggleBulkSelectModeCommand}"
                IsVisible="{Binding !IsBulkSelectMode}"/>

        <!-- Scan trigger -->
        <Button Classes="ghost"
                Content="↻ Scan Library"
                Command="{Binding ScanCommand}"
                IsEnabled="{Binding !IsScanning}"/>

      </StackPanel>

    </StackPanel>

    <!-- ==========================================================================
         Bulk-action toolbar — visible only when IsBulkSelectMode is active
         ========================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsBulkSelectMode}"
            Background="{DynamicResource MgaElevatedBrush}"
            Padding="32,8"
            Margin="0,0,0,4">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Classes="muted">
          <Run Text="{Binding SelectedCount}"/>
          <Run Text=" selected"/>
        </TextBlock>
        <Button Classes="ghost"
                Content="Select All"
                Command="{Binding SelectAllCommand}"/>
        <Button Classes="ghost"
                Content="Clear"
                Command="{Binding ClearSelectionCommand}"/>
        <Button Classes="danger"
                Content="{Binding BulkDeleteLabel}"
                Command="{Binding BulkHardDeleteCommand}"
                IsEnabled="{Binding HasSelectedGames}"/>
      </StackPanel>
    </Border>

    <!-- ==========================================================================
         Loading indicator
         ========================================================================== -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Center"
            Margin="0,16">
      <controls:LoadingSpinner/>
    </Border>

    <!-- ==========================================================================
         List view — tabular rows (title, platform, developer, year)
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowListView}">
      <StackPanel Margin="32,0,32,32">

        <!-- Column header row -->
        <Border Padding="8,8" Background="{DynamicResource MgaElevatedBrush}">
          <Grid ColumnDefinitions="Auto,*,140,160,60">
            <Border Grid.Column="0" Width="32" IsVisible="{Binding IsBulkSelectMode}"/>
            <TextBlock Grid.Column="1" Text="Title"     Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="Platform"  Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="3" Text="Developer" Classes="muted" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="4" Text="Year"      Classes="muted" FontWeight="SemiBold"/>
          </Grid>
        </Border>

        <!-- List rows -->
        <ItemsControl ItemsSource="{Binding FilteredGames}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:GameCardModel">
              <Grid ColumnDefinitions="Auto,*">
                <!-- Checkbox column (only visible in bulk mode) -->
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsSelected}"
                          Width="32"
                          VerticalAlignment="Center"
                          IsVisible="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode}"/>
                <!-- Row content — navigates when NOT in bulk mode -->
                <Button Grid.Column="1"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                        CommandParameter="{Binding Id}"
                        IsEnabled="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).IsBulkSelectMode, Converter={x:Static BoolConverters.Not}}"
                        Cursor="Hand">
                  <Border Padding="8,10" Background="Transparent">
                    <Grid ColumnDefinitions="*,140,160,60">
                      <TextBlock Grid.Column="0" Text="{Binding Title}"
                                 TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Platform}"
                                 Classes="muted" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding Developer}"
                                 Classes="muted" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="3"
                                 Classes="muted" VerticalAlignment="Center">
                        <TextBlock.Text>
                          <Binding Path="ReleaseYear"
                                   StringFormat="{}{0}"
                                   FallbackValue="–"
                                   TargetNullValue="–"/>
                        </TextBlock.Text>
                      </TextBlock>
                    </Grid>
                  </Border>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Timeline view — games grouped by release year, newest-first
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowTimelineView}">
      <StackPanel Margin="32,0,32,32" Spacing="32">

        <ItemsControl ItemsSource="{Binding TimelineGroups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="32"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:TimelineYearGroupViewModel">
              <StackPanel Spacing="12">

                <!-- Year heading with accent underline -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                  <TextBlock Text="{Binding YearLabel}"
                             FontSize="22"
                             FontWeight="Bold"
                             Foreground="{DynamicResource MgaAccentBrush}"/>
                  <Border Height="2"
                          VerticalAlignment="Center"
                          Background="{DynamicResource MgaBorderBrush}"
                          HorizontalAlignment="Stretch"
                          MinWidth="60"/>
                </StackPanel>

                <!-- Games in a wrapping card grid -->
                <ItemsControl ItemsSource="{Binding Games}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="220"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameCardModel">
                      <Button Classes="game-card"
                              Command="{Binding $parent[UserControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                              CommandParameter="{Binding Id}"
                              Width="160" Height="220" Margin="0,0,12,12"
                              Background="Transparent" BorderThickness="0" Padding="0"
                              Cursor="Hand">
                        <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                                Background="{DynamicResource MgaSurfaceBrush}"
                                ClipToBounds="True">
                          <Grid>
                            <!-- Placeholder shown when cover art is absent -->
                            <Border Background="{DynamicResource MgaElevatedBrush}">
                              <TextBlock Text="{Binding Title}"
                                         TextWrapping="Wrap"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Margin="8"
                                         Classes="muted"/>
                            </Border>
                            <!-- Cover art -->
                            <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                                     Stretch="UniformToFill"/>
                            <!-- Title overlay at bottom -->
                            <Border VerticalAlignment="Bottom"
                                    Background="#CC000000"
                                    Padding="8,6">
                              <TextBlock Text="{Binding Title}"
                                         FontSize="12"
                                         TextTrimming="CharacterEllipsis"
                                         Foreground="#FFFFFF"/>
                            </Border>
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Shelf view — horizontal scroll rows (Favorites + per-platform)
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowShelfView}">
      <StackPanel Margin="32,0,32,32" Spacing="32">

        <ItemsControl ItemsSource="{Binding ShelfRows}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="32"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ShelfRowViewModel">
              <StackPanel Spacing="10">

                <!-- Row heading -->
                <TextBlock Text="{Binding Title}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MgaTextBrush}"/>

                <!-- Horizontal scroll strip of game cards -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:GameCardModel">
                        <Button Classes="game-card"
                                Command="{Binding $parent[UserControl].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                                CommandParameter="{Binding Id}"
                                Width="160" Height="220"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Cursor="Hand">
                          <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                                  Background="{DynamicResource MgaSurfaceBrush}"
                                  ClipToBounds="True">
                            <Grid>
                              <!-- Placeholder when no cover art -->
                              <Border Background="{DynamicResource MgaElevatedBrush}">
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="8"
                                           Classes="muted"/>
                              </Border>
                              <!-- Cover art -->
                              <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                                       Stretch="UniformToFill"/>
                              <!-- Title overlay -->
                              <Border VerticalAlignment="Bottom"
                                      Background="#CC000000"
                                      Padding="8,6">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#FFFFFF"/>
                              </Border>
                            </Grid>
                          </Border>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ==========================================================================
         Virtualized game grid — shown in Grid mode
         ========================================================================== -->
    <ScrollViewer IsVisible="{Binding ShowGridView}">
      <ac:ItemsRepeater ItemsSource="{Binding FilteredGames}"
                     Margin="32,0,32,32">
        <ac:ItemsRepeater.Layout>
          <al:UniformGridLayout MinItemWidth="160" MinItemHeight="220"
                             MinColumnSpacing="12" MinRowSpacing="12"/>
        </ac:ItemsRepeater.Layout>
        <ac:ItemsRepeater.ItemTemplate>
          <DataTemplate x:DataType="vm:GameCardModel">
            <Grid Width="160" Height="220">
              <!-- Game card button (navigates when not in bulk mode) -->
              <Button Classes="game-card"
                      Command="{Binding $parent[ac:ItemsRepeater].((vm:LibraryViewModel)DataContext).OpenGameCommand}"
                      CommandParameter="{Binding Id}"
                      Width="160" Height="220"
                      Background="Transparent" BorderThickness="0" Padding="0"
                      Cursor="Hand"
                      IsVisible="{Binding $parent[ac:ItemsRepeater].((vm:LibraryViewModel)DataContext).IsBulkSelectMode, Converter={x:Static BoolConverters.Not}}">
                <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                        Background="{DynamicResource MgaSurfaceBrush}"
                        ClipToBounds="True">
                  <Grid>
                    <Border Background="{DynamicResource MgaElevatedBrush}">
                      <TextBlock Text="{Binding Title}"
                                 TextWrapping="Wrap"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="8"
                                 Classes="muted"/>
                    </Border>
                    <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                             Stretch="UniformToFill"/>
                    <Border VerticalAlignment="Bottom"
                            Background="#CC000000"
                            Padding="8,6">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="12"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="#FFFFFF"/>
                    </Border>
                  </Grid>
                </Border>
              </Button>
              <!-- Bulk-select overlay: card + checkbox (visible in bulk mode) -->
              <Border CornerRadius="{DynamicResource MgaRadiusLg}"
                      Background="{DynamicResource MgaSurfaceBrush}"
                      ClipToBounds="True"
                      IsVisible="{Binding $parent[ac:ItemsRepeater].((vm:LibraryViewModel)DataContext).IsBulkSelectMode}">
                <Grid>
                  <Border Background="{DynamicResource MgaElevatedBrush}">
                    <TextBlock Text="{Binding Title}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="8"
                               Classes="muted"/>
                  </Border>
                  <asyncImage:AdvancedImage Source="{Binding CoverUrl}"
                                           Stretch="UniformToFill"/>
                  <Border VerticalAlignment="Bottom"
                          Background="#CC000000"
                          Padding="8,6">
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#FFFFFF"/>
                  </Border>
                  <!-- Selection tint when checked -->
                  <Border Background="#553db8ff"
                          IsVisible="{Binding IsSelected}"/>
                  <!-- Checkbox in top-left corner -->
                  <CheckBox IsChecked="{Binding IsSelected}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="6"/>
                </Grid>
              </Border>
            </Grid>
          </DataTemplate>
        </ac:ItemsRepeater.ItemTemplate>
      </ac:ItemsRepeater>
    </ScrollViewer>

  </DockPanel>

</UserControl>
