<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MGA.Desktop.ViewModels"
        xmlns:ctrl="using:MGA.Desktop.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="MGA.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/mga.ico"
        Title="MyGamesAnywhere"
        MinWidth="900" MinHeight="600"
        Width="1280" Height="800"
        Classes="MgaWindow"
        WindowDecorations="BorderOnly"
        CanResize="True">

  <!--
    Custom-chrome window.
    Row 0: custom title bar (handles drag + min/max/close)
    Row 1: sidebar (col 0) + page content area (col 1)
    Onboarding overlay covers everything when IsShowingOnboarding=true.
  -->
  <Grid RowDefinitions="48,*">

    <!-- ============================================================
         Row 0 — Title bar + chrome buttons overlay
         ============================================================ -->
    <!-- Chrome buttons live inside TitleBar.axaml (wired in TitleBar.axaml.cs) -->
    <ctrl:TitleBar Grid.Row="0"/>

    <!-- ============================================================
         Row 1 — Shell body: sidebar + page area
         ============================================================ -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

      <!-- Collapsible sidebar -->
      <ctrl:Sidebar Grid.Column="0"
                    Name="SidebarControl"
                    Width="220"/>

      <!-- Page content area -->
      <Border Grid.Column="1"
              Background="{DynamicResource MgaBgBrush}"
              ClipToBounds="True">
        <!--
          TransitioningContentControl gives CrossFade page transitions.
          Content is driven by CurrentPage via NavigationService.
        -->
        <TransitioningContentControl Content="{Binding CurrentPage}"
                                     Name="PageHost"
                                     HorizontalContentAlignment="Stretch"
                                     VerticalContentAlignment="Stretch"/>
      </Border>

    </Grid>

    <!-- ============================================================
         Onboarding overlay — covers the full window on first run.
         OnboardingVm is set by MainWindowViewModel.BeginOnboarding().
         ViewLocator resolves OnboardingViewModel → OnboardingView.
         ============================================================ -->
    <ContentControl Grid.Row="0" Grid.RowSpan="2"
                    Content="{Binding OnboardingVm}"
                    IsVisible="{Binding IsShowingOnboarding}"
                    ZIndex="100"/>

    <!-- ============================================================
         Toast notifications — bottom-right corner overlay
         ============================================================ -->
    <ctrl:ToastHost Grid.Row="0" Grid.RowSpan="2"
                    Name="ToastHostControl"
                    ZIndex="200"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"/>

  </Grid>
</Window>
