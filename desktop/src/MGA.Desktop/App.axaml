<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MGA.Desktop.App"
             xmlns:local="using:MGA.Desktop">

  <!--
    ViewLocator maps FooViewModel → FooView for ContentPresenter data templates.
    Theme resources are loaded dynamically by ThemeService at runtime.
  -->
  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Styles>
    <!--
      Fluent provides reset styles and base control templates.
      MGA ThemeBase overrides all visual styles; no Fluent colors bleed through.
    -->
    <FluentTheme/>
    <StyleInclude Source="avares://MGA.Desktop/Themes/ThemeBase.axaml"/>
  </Application.Styles>

  <!--
    MergedDictionaries[0] is reserved for the active color token dictionary
    (Midnight.axaml or Daylight.axaml). ThemeService swaps it at runtime.
    We pre-populate with Midnight so the designer and cold start are correct.
  -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://MGA.Desktop/Themes/Midnight.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
